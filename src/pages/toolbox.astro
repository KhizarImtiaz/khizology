---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { calculatorCategories, mvpCalculators } from '../data/calculators';
import { toolCategories, mvpTools } from '../data/toolbox';
import { monsters } from '../data/monsters';

const ACCENT = '#F7933C';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const webTools = [
  { name: 'Instagram Bio Score', desc: 'Analyze and score your Instagram bio for max impact.', icon: '📸', badge: 'New', color: '#F7933C', slug: 'instagram-bio-score' },
  { name: 'Readability Checker', desc: 'Check how readable your writing is for any audience.', icon: '📖', badge: 'Soon', color: '#B699FF', slug: '' },
  { name: 'Color Contrast Checker', desc: 'Verify WCAG-compliant color contrast for accessibility.', icon: '🎨', badge: 'Soon', color: '#93B96A', slug: '' },
  { name: 'SEO Title Checker', desc: 'Check if your page title is SEO-optimized and compelling.', icon: '🔍', badge: 'Soon', color: '#5CCFAF', slug: '' },
  { name: 'Word Counter', desc: 'Count words, characters, sentences, and reading time.', icon: '📝', badge: 'Soon', color: '#5DB3D7', slug: '' },
  { name: 'Base64 Encoder', desc: 'Encode and decode text and files in Base64 format.', icon: '⚙️', badge: 'Soon', color: '#6CA6FF', slug: '' },
];
---

<BaseLayout
  title="toolooo — Toolbox by khizooo"
  description="Free online tools and calculators for creators, builders, and professionals. Profit margin, age calculator, percentage, website cost, and more."
  accentColor={ACCENT}
>
  <!-- Hero -->
  <section class="tb-hero">
    <div class="k-container">
      <Breadcrumb crumbs={[{ label: 'toolooo', href: '/toolbox' }]} accentColor={ACCENT} />
      <div class="tb-hero-inner">
        <div class="tb-hero-text">
          <div class="tb-hero-badge">
            <img src={`${base}/images/Monsters/toolooo.png`} alt="toolooo" width="40" height="40" class="tb-hero-monster" />
            <span class="k-section-label" style={`color: ${ACCENT}`}>toolooo · Toolbox</span>
          </div>
          <h1 class="tb-hero-title">
            Free Tools.<br />
            <span class="tb-hero-accent">Actually Useful.</span>
          </h1>
          <p class="tb-hero-lead">
            Calculators, web tools, and utilities crafted to save time,
            solve problems, and make your work easier. Always free.
          </p>
          <div class="tb-hero-stats">
            <div class="tb-stat">
              <span class="tb-stat-num">200+</span>
              <span class="tb-stat-label">Calculators</span>
            </div>
            <div class="tb-stat">
              <span class="tb-stat-num">14</span>
              <span class="tb-stat-label">Categories</span>
            </div>
            <div class="tb-stat">
              <span class="tb-stat-num">Free</span>
              <span class="tb-stat-label">Always</span>
            </div>
          </div>
        </div>
        <div class="tb-hero-visual">
          <div class="tb-tool-preview">
            {mvpCalculators.map((t, i) => (
              <div class="tb-preview-chip" style={`--idx: ${i}`}>
                <span>{t.icon}</span>
                <span>{t.name}</span>
                <span class="tb-preview-new">MVP</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MVP Section -->
  <section class="k-section tb-mvp-section">
    <div class="k-container">
      <div class="tb-section-header">
        <span class="k-section-label" style={`color: ${ACCENT}`}>Priority Tools</span>
        <h2 class="tb-section-title">5 MVP Calculators</h2>
        <p class="tb-section-sub">These launch first. Fully functional, carefully crafted for real use cases.</p>
      </div>
      <div class="tb-mvp-grid">
        {mvpCalculators.map(tool => (
          <div class="tb-mvp-card" style="--ta: #F7933C">
            <div class="tb-mvp-top">
              <div class="tb-mvp-icon-wrap">
                <span class="tb-mvp-icon">{tool.icon}</span>
              </div>
              <div class="tb-mvp-badges">
                {tool.isPopular && <span class="tb-badge popular">Popular</span>}
                {tool.isNew && <span class="tb-badge new">New</span>}
                <span class="tb-badge soon">Building</span>
              </div>
            </div>
            <h3 class="tb-mvp-name">{tool.name}</h3>
            <p class="tb-mvp-desc">{tool.description}</p>
            <div class="tb-mvp-footer">
              <span class="tb-mvp-cat">{tool.category.replace(/-/g, ' ')}</span>
              <button class="tb-mvp-btn" disabled>Coming Soon</button>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Calculator Categories -->
  <section class="k-section tb-calc-section">
    <div class="k-container">
      <div class="tb-section-header">
        <span class="k-section-label" style={`color: ${ACCENT}`}>Calculators</span>
        <h2 class="tb-section-title">200+ Calculators Across 14 Categories</h2>
        <p class="tb-section-sub">From finance to physics, everyday life to sports — a calculator for every problem.</p>
      </div>
      <div class="tb-calc-grid">
        {calculatorCategories.map(cat => (
          <div class={`tb-calc-card${cat.featured ? ' featured' : ''}`} style={`--cc: ${cat.color}`}>
            <div class="tb-calc-glow"></div>
            <div class="tb-calc-top">
              <div class="tb-calc-icon-wrap">
                <span class="tb-calc-icon">{cat.icon}</span>
              </div>
              <div class="tb-calc-meta">
                {cat.featured && <span class="tb-badge featured">Featured</span>}
                {!cat.live && <span class="tb-badge soon">Soon</span>}
              </div>
            </div>
            <h3 class="tb-calc-name">{cat.title}</h3>
            <p class="tb-calc-desc">{cat.description}</p>
            <div class="tb-calc-count">{cat.count} calculators</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Web Tools -->
  <section class="k-section tb-webtools-section">
    <div class="k-container">
      <div class="tb-section-header">
        <span class="k-section-label" style={`color: ${ACCENT}`}>Web Tools</span>
        <h2 class="tb-section-title">Creator & Developer Tools</h2>
        <p class="tb-section-sub">Utility tools for creators, developers, and everyday builders.</p>
      </div>
      <div class="tb-webtools-grid">
        {webTools.map(tool => (
          <div class="tb-web-card" style={`--tc: ${tool.color}`}>
            <div class="tb-web-top">
              <span class="tb-web-icon">{tool.icon}</span>
              <span class={`tb-badge ${tool.badge === 'New' ? 'new' : 'soon'}`}>{tool.badge}</span>
            </div>
            <h3 class="tb-web-name">{tool.name}</h3>
            <p class="tb-web-desc">{tool.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Toolooo -->
  <section class="tb-why-section">
    <div class="k-container">
      <div class="tb-why-inner">
        <div class="tb-why-text">
          <span class="k-section-label" style={`color: ${ACCENT}`}>Why toolooo?</span>
          <h2 class="tb-why-title">Tools that don't waste your time.</h2>
          <p class="tb-why-desc">
            Most online calculators are cluttered with ads, slow to load, and painful to use.
            toolooo is different — fast, clean, and focused on one thing: solving your problem immediately.
          </p>
          <div class="tb-features">
            {[
              { icon: '⚡', label: 'Instant results' },
              { icon: '🎯', label: 'No ads, no clutter' },
              { icon: '📱', label: 'Mobile-first design' },
              { icon: '🌙', label: 'Dark mode support' },
              { icon: '🔒', label: 'No data stored' },
              { icon: '♾️', label: 'Always free' },
            ].map(f => (
              <div class="tb-feature">
                <span class="tb-feature-icon">{f.icon}</span>
                <span class="tb-feature-label">{f.label}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="tb-why-img">
          <img src={`${base}/images/Monsters/toolooo.png`} alt="toolooo monster" width="220" height="220" class="tb-why-monster" />
        </div>
      </div>
    </div>
  </section>

  <!-- Other monsters -->
  <section class="tb-other-section">
    <div class="k-container">
      <div class="tb-other-inner">
        <p class="tb-other-label">More khizology monsters →</p>
        <div class="tb-other-links">
          {monsters.filter(m => m.status === 'active' && m.id !== 'toolooo').map(m => (
            <a href={m.route} class="tb-other-link" style={`--mc: ${m.color}`}>
              <img src={`${base}${m.image}`} alt={m.name} width="28" height="28" />
              <span>{m.module}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .tb-hero {
    background: var(--k-bg); padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--k-border);
  }
  .tb-hero-inner {
    display: grid; grid-template-columns: 1fr; gap: 3rem;
    align-items: center; margin-top: 1rem;
  }
  @media (min-width: 900px) { .tb-hero-inner { grid-template-columns: 1fr 1fr; } }
  .tb-hero-badge { display: flex; align-items: center; gap: .625rem; margin-bottom: .5rem; }
  .tb-hero-monster { border-radius: .5rem; object-fit: contain; }
  .tb-hero-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 900; line-height: 1.1; color: var(--k-text); margin: .25rem 0 1rem;
  }
  .tb-hero-accent { color: #F7933C; }
  .tb-hero-lead {
    font-size: 1rem; color: var(--k-text-muted); line-height: 1.7;
    max-width: 480px; margin: 0 0 1.5rem;
  }
  .tb-hero-stats { display: flex; gap: 2rem; }
  .tb-stat { display: flex; flex-direction: column; gap: .125rem; }
  .tb-stat-num {
    font-family: 'Poppins', sans-serif; font-size: 1.5rem;
    font-weight: 900; color: #F7933C; line-height: 1;
  }
  .tb-stat-label {
    font-size: .72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--k-text-muted);
  }

  .tb-tool-preview { display: flex; flex-direction: column; gap: .625rem; }
  .tb-preview-chip {
    display: flex; align-items: center; gap: .75rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-radius: .875rem; padding: .875rem 1.125rem;
    font-size: .875rem; color: var(--k-text); font-family: 'Poppins', sans-serif;
    font-weight: 600; animation: slideIn .3s ease both;
    animation-delay: calc(var(--idx) * .08s);
  }
  .tb-preview-new {
    margin-left: auto; font-size: .65rem; font-weight: 700;
    text-transform: uppercase; color: #F7933C;
    background: color-mix(in srgb, #F7933C 12%, transparent);
    padding: .15rem .5rem; border-radius: 999px;
  }
  @keyframes slideIn {
    from { opacity: 0; transform: translateX(20px); }
    to { opacity: 1; transform: translateX(0); }
  }

  /* Sections */
  .tb-section-header { margin-bottom: 2rem; }
  .tb-section-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800;
    color: var(--k-text); margin: .25rem 0 .5rem;
  }
  .tb-section-sub { font-size: .9rem; color: var(--k-text-muted); margin: 0; }

  /* Badges */
  .tb-badge {
    font-size: .65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; padding: .15rem .5rem; border-radius: 999px;
    font-family: 'Poppins', sans-serif;
  }
  .tb-badge.popular { background: color-mix(in srgb, #F5CF5C 15%, transparent); color: #c49d10; border: 1px solid color-mix(in srgb, #F5CF5C 30%, transparent); }
  .tb-badge.new { background: color-mix(in srgb, #5CCFAF 15%, transparent); color: #2a9175; border: 1px solid color-mix(in srgb, #5CCFAF 30%, transparent); }
  .tb-badge.soon { background: var(--k-bg); color: var(--k-text-muted); border: 1px solid var(--k-border); }
  .tb-badge.featured { background: color-mix(in srgb, #F7933C 12%, transparent); color: #c45e10; border: 1px solid color-mix(in srgb, #F7933C 25%, transparent); }

  /* MVP */
  .tb-mvp-section { background: var(--k-bg-card); border-top: 1px solid var(--k-border); }
  .tb-mvp-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem;
  }
  .tb-mvp-card {
    background: var(--k-bg); border: 1.5px solid var(--k-border);
    border-radius: 1.25rem; padding: 1.5rem;
    display: flex; flex-direction: column; gap: .625rem;
    transition: border-color .2s, transform .2s;
  }
  .tb-mvp-card:hover { border-color: #F7933C; transform: translateY(-3px); }
  .tb-mvp-top { display: flex; align-items: center; justify-content: space-between; }
  .tb-mvp-icon-wrap {
    width: 48px; height: 48px; border-radius: .875rem;
    background: color-mix(in srgb, #F7933C 15%, transparent);
    display: flex; align-items: center; justify-content: center; font-size: 1.5rem;
  }
  .tb-mvp-badges { display: flex; gap: .375rem; flex-wrap: wrap; justify-content: flex-end; }
  .tb-mvp-name {
    font-family: 'Poppins', sans-serif; font-size: 1rem;
    font-weight: 800; color: var(--k-text); margin: 0;
  }
  .tb-mvp-desc { font-size: .8rem; color: var(--k-text-muted); line-height: 1.5; margin: 0; flex: 1; }
  .tb-mvp-footer { display: flex; align-items: center; justify-content: space-between; margin-top: .5rem; }
  .tb-mvp-cat {
    font-size: .7rem; font-weight: 600; text-transform: capitalize;
    color: var(--k-text-muted);
  }
  .tb-mvp-btn {
    padding: .4rem .875rem; background: #F7933C; color: #fff;
    border: none; border-radius: .5rem; font-weight: 700; font-size: .75rem;
    cursor: not-allowed; opacity: .5; font-family: 'Poppins', sans-serif;
  }

  /* Calc categories */
  .tb-calc-section { background: var(--k-bg); border-top: 1px solid var(--k-border); }
  .tb-calc-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem;
  }
  .tb-calc-card {
    position: relative; background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-radius: 1rem; padding: 1.25rem; overflow: hidden;
    transition: border-color .2s, transform .2s;
  }
  .tb-calc-card:hover, .tb-calc-card.featured { border-color: var(--cc); }
  .tb-calc-card:hover { transform: translateY(-2px); }
  .tb-calc-glow {
    position: absolute; top: -15px; right: -15px;
    width: 60px; height: 60px; border-radius: 50%;
    background: var(--cc); opacity: .07; filter: blur(15px);
    pointer-events: none;
  }
  .tb-calc-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: .75rem; }
  .tb-calc-icon-wrap {
    width: 40px; height: 40px; border-radius: .625rem;
    background: color-mix(in srgb, var(--cc) 15%, transparent);
    display: flex; align-items: center; justify-content: center; font-size: 1.25rem;
  }
  .tb-calc-meta { display: flex; gap: .25rem; }
  .tb-calc-name {
    font-family: 'Poppins', sans-serif; font-size: .9rem;
    font-weight: 800; color: var(--k-text); margin: 0 0 .25rem;
  }
  .tb-calc-desc { font-size: .76rem; color: var(--k-text-muted); line-height: 1.4; margin: 0 0 .625rem; }
  .tb-calc-count {
    font-size: .7rem; font-weight: 700; color: var(--cc);
    font-family: 'Poppins', sans-serif;
  }

  /* Web tools */
  .tb-webtools-section { background: var(--k-bg-card); border-top: 1px solid var(--k-border); }
  .tb-webtools-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem;
  }
  .tb-web-card {
    background: var(--k-bg); border: 1px solid var(--k-border);
    border-radius: 1rem; padding: 1.25rem;
    transition: border-color .2s;
  }
  .tb-web-card:hover { border-color: var(--tc); }
  .tb-web-top {
    display: flex; align-items: center; justify-content: space-between; margin-bottom: .75rem;
  }
  .tb-web-icon { font-size: 1.5rem; }
  .tb-web-name {
    font-family: 'Poppins', sans-serif; font-size: .9rem;
    font-weight: 800; color: var(--k-text); margin: 0 0 .375rem;
  }
  .tb-web-desc { font-size: .78rem; color: var(--k-text-muted); line-height: 1.5; margin: 0; }

  /* Why */
  .tb-why-section { background: var(--k-bg); padding: 5rem 0; border-top: 1px solid var(--k-border); }
  .tb-why-inner {
    display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center;
  }
  @media (min-width: 768px) { .tb-why-inner { grid-template-columns: 1fr auto; } }
  .tb-why-title {
    font-family: 'Poppins', sans-serif; font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 900; color: var(--k-text); margin: .5rem 0 1rem;
  }
  .tb-why-desc { font-size: .95rem; color: var(--k-text-muted); line-height: 1.7; margin: 0 0 1.5rem; }
  .tb-features {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: .75rem;
  }
  @media (min-width: 480px) { .tb-features { grid-template-columns: repeat(3, 1fr); } }
  .tb-feature {
    display: flex; align-items: center; gap: .5rem;
    font-size: .8rem; color: var(--k-text-muted);
  }
  .tb-feature-icon { font-size: 1.125rem; }
  .tb-feature-label { font-weight: 600; }
  .tb-why-monster {
    opacity: .9; filter: drop-shadow(0 20px 40px rgba(247, 147, 60, .2));
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  /* Other */
  .tb-other-section {
    background: var(--k-bg-card); border-top: 1px solid var(--k-border); padding: 2rem 0;
  }
  .tb-other-inner {
    display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; justify-content: space-between;
  }
  .tb-other-label { font-size: .8rem; font-weight: 700; color: var(--k-text-muted); }
  .tb-other-links { display: flex; gap: .625rem; flex-wrap: wrap; }
  .tb-other-link {
    display: flex; flex-direction: column; align-items: center; gap: .25rem;
    padding: .625rem; background: var(--k-bg);
    border: 1px solid var(--k-border); border-radius: .75rem;
    text-decoration: none; color: var(--k-text-muted);
    font-size: .7rem; font-weight: 600; min-width: 64px;
    transition: border-color .2s, color .2s;
  }
  .tb-other-link:hover { border-color: var(--mc); color: var(--mc); }
</style>
