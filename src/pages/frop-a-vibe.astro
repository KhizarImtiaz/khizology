---
// Redirect alias for the typo in original PDF: "frop-a-vibe" → "drop-a-vibe"
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const target = `${base}/drop-a-vibe`;
---
<meta http-equiv="refresh" content={`0; url=${target}`} />
<link rel="canonical" href={target} />
<script define:vars={{ target }}>window.location.replace(target);</script>
<p>Redirecting to <a href={target}>Drop a Vibe</a>...</p>
