---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';

const vibeModes = [
  { emoji: '💬', label: 'General Feedback', desc: 'Thoughts on khizology, ideas, suggestions' },
  { emoji: '🤝', label: 'Collaboration', desc: 'Art commissions, creative partnerships' },
  { emoji: '🐛', label: 'Bug Report', desc: 'Something broken? Let me know' },
  { emoji: '💡', label: 'Feature Idea', desc: 'A tool or monster you\'d like to see' },
  { emoji: '👋', label: 'Just Saying Hi', desc: 'No agenda, just good vibes' },
];
---

<BaseLayout
  title="Drop a Vibe"
  description="Drop a message, idea, feedback, or collaboration request to khizooo. Every vibe is welcome."
  accentColor="#5CCFAF"
>
  <div class="k-container" style="padding-top: 2rem;">
    <Breadcrumb crumbs={[{ label: 'Drop a Vibe' }]} accentColor="#5CCFAF" />
  </div>

  <section class="k-section dav-section">
    <div class="k-container dav-inner">

      <!-- Left: Form -->
      <div class="dav-form-side">
        <span class="k-section-label" style="color: #5CCFAF">Drop a Vibe</span>
        <h1 class="dav-title">Say Hello.</h1>
        <p class="dav-lead">
          Whether it's feedback, a collab idea, a bug, or just a good-vibe message —
          this is the place. Every message gets read.
        </p>

        <!-- Vibe type selector -->
        <div class="vibe-types">
          {vibeModes.map((v, i) => (
            <label class="vibe-type-label">
              <input type="radio" name="vibetype" value={v.label} class="vibe-radio" checked={i === 0} />
              <span class="vibe-type-card">
                <span class="vt-emoji">{v.emoji}</span>
                <span class="vt-label">{v.label}</span>
              </span>
            </label>
          ))}
        </div>

        <!-- Form -->
        <form class="dav-form" action="#" method="post" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Name</label>
              <input type="text" id="name" name="name" placeholder="Your name or alias" required autocomplete="name" />
            </div>
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="your@email.com" required autocomplete="email" />
            </div>
          </div>
          <div class="form-group">
            <label for="subject">Subject</label>
            <input type="text" id="subject" name="subject" placeholder="What's this about?" />
          </div>
          <div class="form-group">
            <label for="message">Your Vibe</label>
            <textarea id="message" name="message" rows="5" placeholder="Type your message here... no formality required." required></textarea>
          </div>
          <div class="form-footer">
            <span class="form-note">📬 No backend yet — form integration coming soon. For now, social links work too.</span>
            <button type="submit" class="dav-submit" disabled>
              Drop it 🚀
              <span class="submit-badge">Coming Soon</span>
            </button>
          </div>
        </form>
      </div>

      <!-- Right: Sidebar -->
      <div class="dav-sidebar">
        <div class="dav-monster-card">
          <img src="/public/images/Monsters/infooo.png" alt="infooo" width="80" height="80" />
          <p>"Every conversation starts with a small vibe. Don't hold back."</p>
        </div>

        <div class="dav-connect">
          <h3>Other Ways to Connect</h3>
          <ul class="connect-list">
            <li>
              <span class="connect-icon">🐙</span>
              <div>
                <strong>GitHub</strong>
                <a href="https://github.com/khizarooo" target="_blank" rel="noopener">@khizarooo</a>
              </div>
            </li>
            <li>
              <span class="connect-icon">📸</span>
              <div>
                <strong>Instagram</strong>
                <span class="coming-link">Coming soon</span>
              </div>
            </li>
            <li>
              <span class="connect-icon">🐦</span>
              <div>
                <strong>Twitter / X</strong>
                <span class="coming-link">Coming soon</span>
              </div>
            </li>
          </ul>
        </div>

        <div class="dav-promise">
          <h3>The Promise</h3>
          <ul class="promise-list">
            <li>✓ Every message gets read</li>
            <li>✓ No spam, ever</li>
            <li>✓ Genuine replies only</li>
            <li>✓ Good vibes only</li>
          </ul>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>

<style>
  .dav-section { background: var(--k-bg); }
  .dav-inner {
    display: grid; grid-template-columns: 1fr 340px; gap: 4rem; align-items: flex-start;
  }

  .dav-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1.1;
    color: var(--k-text); margin: 0.5rem 0 1rem;
  }
  .dav-lead {
    font-size: 1rem; color: var(--k-text-muted); line-height: 1.7; margin: 0 0 1.75rem;
  }

  /* Vibe types */
  .vibe-types {
    display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.75rem;
  }
  .vibe-type-label { cursor: pointer; }
  .vibe-radio { position: absolute; opacity: 0; width: 0; height: 0; }
  .vibe-type-card {
    display: inline-flex; align-items: center; gap: 0.375rem;
    padding: 0.375rem 0.75rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-radius: 999px; transition: all 0.2s;
    font-size: 0.8rem; font-weight: 600; color: var(--k-text-muted);
  }
  .vibe-radio:checked + .vibe-type-card {
    background: #5CCFAF; border-color: #5CCFAF; color: #2A3439; font-weight: 700;
  }
  .vt-emoji { font-size: 0.9rem; }

  /* Form */
  .dav-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.375rem; }
  .form-group label {
    font-size: 0.8rem; font-weight: 700; font-family: 'Poppins', sans-serif;
    color: var(--k-text);
  }
  .form-group input,
  .form-group textarea {
    background: var(--k-bg-card);
    border: 1px solid var(--k-border);
    border-radius: 0.625rem;
    padding: 0.75rem 1rem;
    font-size: 0.9rem; font-family: 'Mulish', sans-serif;
    color: var(--k-text); outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }
  .form-group input:focus,
  .form-group textarea:focus {
    border-color: #5CCFAF;
  }
  .form-group input::placeholder,
  .form-group textarea::placeholder { color: var(--k-text-muted); }

  .form-footer {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 0.75rem;
    padding-top: 0.5rem;
  }
  .form-note { font-size: 0.75rem; color: var(--k-text-muted); max-width: 320px; }

  .dav-submit {
    display: inline-flex; align-items: center; gap: 0.5rem;
    padding: 0.65rem 1.5rem;
    background: var(--k-dark); color: var(--k-bg);
    border: none; border-radius: 0.625rem;
    font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 0.875rem;
    cursor: not-allowed; opacity: 0.7;
    white-space: nowrap;
  }
  .submit-badge {
    display: inline-flex; padding: 0.15rem 0.5rem;
    background: #5CCFAF; color: var(--k-dark);
    border-radius: 999px; font-size: 0.65rem; font-weight: 700;
    font-family: 'Poppins', sans-serif; text-transform: uppercase;
  }

  /* SIDEBAR */
  .dav-sidebar {
    position: sticky; top: 5rem;
    display: flex; flex-direction: column; gap: 1.25rem;
  }

  .dav-monster-card {
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-left: 4px solid #5CCFAF;
    border-radius: 0 1rem 1rem 0;
    padding: 1.25rem; display: flex; align-items: center; gap: 1rem;
  }
  .dav-monster-card img { flex-shrink: 0; }
  .dav-monster-card p { font-size: 0.85rem; font-style: italic; color: var(--k-text-muted); margin: 0; line-height: 1.5; }

  .dav-connect,
  .dav-promise {
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-radius: 1rem; padding: 1.25rem;
  }
  .dav-connect h3, .dav-promise h3 {
    font-family: 'Poppins', sans-serif; font-size: 0.8rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em;
    color: var(--k-text-muted); margin: 0 0 0.875rem;
  }

  .connect-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.875rem; }
  .connect-list li { display: flex; align-items: center; gap: 0.75rem; }
  .connect-icon { font-size: 1.25rem; flex-shrink: 0; }
  .connect-list div { display: flex; flex-direction: column; gap: 0.1rem; }
  .connect-list strong { font-size: 0.8rem; color: var(--k-text); }
  .connect-list a { font-size: 0.8rem; color: #5CCFAF; text-decoration: none; }
  .connect-list a:hover { text-decoration: underline; }
  .coming-link { font-size: 0.75rem; color: var(--k-text-muted); font-style: italic; }

  .promise-list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.5rem;
  }
  .promise-list li { font-size: 0.85rem; color: var(--k-text-muted); }

  @media (max-width: 900px) {
    .dav-inner { grid-template-columns: 1fr; }
    .dav-sidebar { position: static; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
