---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { webToolCategories } from '../../data/webtools';
import { monsters } from '../../data/monsters';
import { url } from '../../utils/url';

const ACCENT = '#F7933C';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const totalTools = webToolCategories.reduce((n, c) => n + c.tools.length, 0);
---

<BaseLayout
  title="Free Web Tools — toolooo by khizooo"
  description={`${totalTools}+ free web tools across ${webToolCategories.length} categories — developer utilities, AI prompt generators, SEO tools, design tools, and more. Always free.`}
  accentColor={ACCENT}
>
  <!-- Hero -->
  <section class="tl-hero">
    <div class="k-container">
      <Breadcrumb
        crumbs={[{ label: 'toolooo', href: url('/toolbox') }, { label: 'Web Tools' }]}
        accentColor={ACCENT}
      />
      <div class="tl-hero-inner">
        <div class="tl-hero-text">
          <div class="tl-hero-badge">
            <img src={`${base}/images/Monsters/toolooo.png`} alt="toolooo" width="36" height="36" />
            <span class="k-section-label" style={`color: ${ACCENT}`}>toolooo · Web Tools</span>
          </div>
          <h1 class="tl-hero-title">
            800+ Free Tools.<br />
            <span class="tl-hero-accent">Coming Soon.</span>
          </h1>
          <p class="tl-hero-lead">
            Developer utilities, AI prompt generators, SEO helpers, design tools, productivity apps,
            and more — all free. Browse all categories below.
          </p>
          <div class="tl-hero-stats">
            <div class="tl-stat"><span class="tl-stat-num">{totalTools}+</span><span class="tl-stat-label">Web Tools</span></div>
            <div class="tl-stat"><span class="tl-stat-num">{webToolCategories.length}</span><span class="tl-stat-label">Categories</span></div>
            <div class="tl-stat"><span class="tl-stat-num">Free</span><span class="tl-stat-label">Always</span></div>
          </div>
        </div>
        <div class="tl-hero-visual">
          <div class="tl-cat-chips">
            {webToolCategories.slice(0, 8).map((cat, i) => (
              <div class="tl-cat-chip" style={`--idx: ${i}`}>
                <span>{cat.icon}</span>
                <span>{cat.title}</span>
                <span class="tl-chip-count">{cat.tools.length}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- All Categories -->
  <section class="k-section tl-cats-section">
    <div class="k-container">
      <div class="tl-section-header">
        <span class="k-section-label" style={`color: ${ACCENT}`}>All Categories</span>
        <h2 class="tl-section-title">{webToolCategories.length} Tool Categories</h2>
        <p class="tl-section-sub">Every tool is coming soon — browse categories and see what's planned.</p>
      </div>

      <div class="tl-cats-grid">
        {webToolCategories.map(cat => (
          <div class="tl-cat-card">
            <div class="tl-cat-top">
              <div class="tl-cat-icon-wrap">
                <span class="tl-cat-icon">{cat.icon}</span>
              </div>
              <span class="tl-badge-soon">Soon</span>
            </div>
            <h3 class="tl-cat-name">{cat.title}</h3>
            <p class="tl-cat-desc">{cat.description}</p>
            <div class="tl-cat-count">{cat.tools.length} tools</div>
            <div class="tl-chip-list">
              {cat.tools.slice(0, 8).map(tool => (
                <span class="tl-chip">{tool}</span>
              ))}
              {cat.tools.length > 8 && (
                <span class="tl-chip tl-chip-more">+{cat.tools.length - 8} more</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Switch nav -->
  <section class="tl-switch-section">
    <div class="k-container">
      <div class="tl-switch-inner">
        <div class="tl-switch-card active">
          <span>🔧</span>
          <strong>Web Tools</strong>
          <span class="tl-switch-you">← You are here</span>
        </div>
        <a href={url("/toolbox/calculators")} class="tl-switch-card link">
          <span>🧮</span>
          <strong>Calculators</strong>
          <span class="tl-switch-arrow">Explore 200+ →</span>
        </a>
        <a href={url("/toolbox")} class="tl-switch-card link">
          <span>🏠</span>
          <strong>All Toolbox</strong>
          <span class="tl-switch-arrow">Back to hub →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Other monsters strip -->
  <section class="tl-other-section">
    <div class="k-container">
      <div class="tl-other-inner">
        <p class="tl-other-label">More khizology →</p>
        <div class="tl-other-links">
          {monsters.filter(m => m.status === 'active' && m.id !== 'toolooo').map(m => (
            <a href={url(m.route)} class="tl-other-link" style={`--mc: ${m.color}`}>
              <img src={`${base}${m.image}`} alt={m.name} width="28" height="28" />
              <span>{m.module}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .tl-hero { background: var(--k-bg); padding: 3rem 0 2rem; border-bottom: 1px solid var(--k-border); }
  .tl-hero-inner { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: start; margin-top: 1rem; }
  @media (min-width: 900px) { .tl-hero-inner { grid-template-columns: 1fr 1fr; } }
  .tl-hero-badge { display: flex; align-items: center; gap: .625rem; margin-bottom: .5rem; }
  .tl-hero-badge img { border-radius: .5rem; }
  .tl-hero-title { font-family: 'Poppins', sans-serif; font-size: clamp(2rem, 4.5vw, 3rem); font-weight: 900; line-height: 1.1; color: var(--k-text); margin: .25rem 0 1rem; }
  .tl-hero-accent { color: #F7933C; }
  .tl-hero-lead { font-size: 1rem; color: var(--k-text-muted); line-height: 1.7; max-width: 460px; margin: 0 0 1.5rem; }
  .tl-hero-stats { display: flex; gap: 2rem; }
  .tl-stat { display: flex; flex-direction: column; gap: .125rem; }
  .tl-stat-num { font-family: 'Poppins', sans-serif; font-size: 1.5rem; font-weight: 900; color: #F7933C; line-height: 1; }
  .tl-stat-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--k-text-muted); }

  /* Hero cat chips */
  .tl-cat-chips { display: flex; flex-direction: column; gap: .5rem; }
  .tl-cat-chip {
    display: flex; align-items: center; gap: .75rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-left: 3px solid #F7933C;
    border-radius: 0 .875rem .875rem 0;
    padding: .625rem 1rem;
    font-size: .8rem; color: var(--k-text); font-family: 'Poppins', sans-serif; font-weight: 600;
    animation: slideIn .3s ease both; animation-delay: calc(var(--idx) * .06s);
  }
  .tl-chip-count {
    margin-left: auto; font-size: .65rem; font-weight: 700;
    color: #F7933C; background: color-mix(in srgb, #F7933C 12%, transparent);
    padding: .15rem .5rem; border-radius: 999px;
  }
  @keyframes slideIn { from { opacity: 0; transform: translateX(16px); } to { opacity: 1; transform: translateX(0); } }

  /* Section */
  .tl-cats-section { background: var(--k-bg-card); border-top: 1px solid var(--k-border); }
  .tl-section-header { margin-bottom: 2rem; }
  .tl-section-title { font-family: 'Poppins', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem); font-weight: 800; color: var(--k-text); margin: .25rem 0 .375rem; }
  .tl-section-sub { font-size: .875rem; color: var(--k-text-muted); margin: 0; }

  /* Category cards */
  .tl-cats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.125rem;
  }
  .tl-cat-card {
    background: var(--k-bg);
    border: 1px solid var(--k-border);
    border-left: 3px solid #F7933C;
    border-radius: 0 1.125rem 1.125rem 0;
    padding: 1.375rem;
    display: flex; flex-direction: column; gap: .625rem;
    transition: box-shadow .2s, border-color .2s;
  }
  .tl-cat-card:hover {
    border-color: #F7933C;
    box-shadow: 0 4px 20px rgba(247,147,60,.1);
  }
  .tl-cat-top { display: flex; align-items: center; justify-content: space-between; }
  .tl-cat-icon-wrap {
    width: 44px; height: 44px; border-radius: .75rem;
    background: color-mix(in srgb, #F7933C 12%, transparent);
    display: flex; align-items: center; justify-content: center; font-size: 1.375rem;
  }
  .tl-cat-name { font-family: 'Poppins', sans-serif; font-size: .9rem; font-weight: 800; color: var(--k-text); margin: 0; }
  .tl-cat-desc { font-size: .78rem; color: var(--k-text-muted); line-height: 1.5; margin: 0; flex: 1; }
  .tl-cat-count { font-size: .7rem; font-weight: 700; color: #F7933C; }

  /* Soon badge */
  .tl-badge-soon {
    font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em;
    padding: .15rem .5rem; border-radius: 999px; font-family: 'Poppins', sans-serif;
    background: var(--k-bg-card); color: var(--k-text-muted); border: 1px solid var(--k-border);
  }

  /* Tool chips */
  .tl-chip-list { display: flex; gap: .3rem; flex-wrap: wrap; }
  .tl-chip {
    font-size: .65rem; font-weight: 600; padding: .15rem .5rem;
    border-radius: 999px; background: var(--k-bg-card);
    border: 1px solid var(--k-border); color: var(--k-text-muted);
    font-family: 'Poppins', sans-serif;
  }
  .tl-chip-more {
    background: color-mix(in srgb, #F7933C 10%, transparent);
    border-color: color-mix(in srgb, #F7933C 25%, transparent);
    color: #F7933C;
  }

  /* Switch nav */
  .tl-switch-section { background: var(--k-bg); border-top: 1px solid var(--k-border); padding: 2rem 0; }
  .tl-switch-inner { display: flex; gap: 1rem; flex-wrap: wrap; }
  .tl-switch-card {
    flex: 1; min-width: 180px; background: var(--k-bg-card); border: 1.5px solid var(--k-border);
    border-radius: 1rem; padding: 1.25rem;
    display: flex; flex-direction: column; gap: .25rem;
    font-size: .875rem; color: var(--k-text); font-family: 'Poppins', sans-serif;
  }
  .tl-switch-card strong { font-size: 1rem; font-weight: 800; }
  .tl-switch-card.active { border-color: #F7933C; }
  .tl-switch-card.link { text-decoration: none; transition: border-color .2s, transform .2s; cursor: pointer; }
  .tl-switch-card.link:hover { border-color: #F7933C; transform: translateY(-2px); }
  .tl-switch-you { font-size: .72rem; color: #F7933C; font-weight: 700; }
  .tl-switch-arrow { font-size: .78rem; color: var(--k-text-muted); }

  /* Other monsters */
  .tl-other-section { background: var(--k-bg-card); border-top: 1px solid var(--k-border); padding: 2rem 0; }
  .tl-other-inner { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; justify-content: space-between; }
  .tl-other-label { font-size: .8rem; font-weight: 700; color: var(--k-text-muted); }
  .tl-other-links { display: flex; gap: .625rem; flex-wrap: wrap; }
  .tl-other-link {
    display: flex; flex-direction: column; align-items: center; gap: .25rem; padding: .625rem;
    background: var(--k-bg); border: 1px solid var(--k-border); border-radius: .75rem;
    text-decoration: none; color: var(--k-text-muted); font-size: .7rem; font-weight: 600; min-width: 64px;
    transition: border-color .2s, color .2s;
  }
  .tl-other-link:hover { border-color: var(--mc); color: var(--mc); }
</style>
