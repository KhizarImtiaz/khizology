---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import { calculatorCategories } from '../../../data/calculators';
import { monsters } from '../../../data/monsters';
import { url } from '../../../utils/url';
import ProfitMarginCalc from '../../../components/calculators/ProfitMarginCalc';
import WebsiteCostCalc from '../../../components/calculators/WebsiteCostCalc';
import PercentageCalc from '../../../components/calculators/PercentageCalc';
import AgeCalc from '../../../components/calculators/AgeCalc';

// Category slug map
const CATEGORY_SLUG_MAP: Record<string, string> = {
  'finance-calculator':          'finance',
  'math-calculator':             'math',
  'everyday-life-calculator':    'everyday-life',
  'biology-calculator':          'physics',
  'chemistry-calculator':        'physics',
  'physics-calculator':          'physics',
  'health-calculator':           'health',
  'construction-calculator':     'construction',
  'unit-conversion-calculator':  'unit-conversion',
  'food-calculator':             'food',
  'sports-calculator':           'sports',
  'time-date-calculator':        'time-date',
  'photography-calculator':      'photography',
  'automotive-calculator':       'automotive',
  'travel-calculator':           'travel',
};

// Functional MVP calculators (hardcoded)
const MVP_CALCS = [
  { slug: 'profit-margin-calculator', name: 'Profit Margin Calculator', icon: '💰', description: 'Calculate gross, net, and operating profit margins instantly.', category: 'finance' },
  { slug: 'website-cost-calculator',  name: 'Website Cost Calculator',  icon: '🌐', description: 'Estimate how much a website will cost to design and build.', category: 'everyday-life' },
  { slug: 'percentage-calculator',    name: 'Percentage Calculator',    icon: '📊', description: 'Calculate percentages, increases, decreases, and differences.', category: 'math' },
  { slug: 'age-calculator',           name: 'Age Calculator',           icon: '🎂', description: 'Calculate exact age in years, months, days, hours, and minutes.', category: 'everyday-life' },
];

export async function getStaticPaths() {
  const CATEGORY_SLUG_MAP: Record<string, string> = {
    'finance-calculator':          'finance',
    'math-calculator':             'math',
    'everyday-life-calculator':    'everyday-life',
    'biology-calculator':          'physics',
    'chemistry-calculator':        'physics',
    'physics-calculator':          'physics',
    'health-calculator':           'health',
    'construction-calculator':     'construction',
    'unit-conversion-calculator':  'unit-conversion',
    'food-calculator':             'food',
    'sports-calculator':           'sports',
    'time-date-calculator':        'time-date',
    'photography-calculator':      'photography',
    'automotive-calculator':       'automotive',
    'travel-calculator':           'travel',
  };

  const MVP_CALCS = [
    { slug: 'profit-margin-calculator', name: 'Profit Margin Calculator', icon: '💰', description: 'Calculate gross, net, and operating profit margins instantly.', category: 'finance' },
    { slug: 'website-cost-calculator',  name: 'Website Cost Calculator',  icon: '🌐', description: 'Estimate how much a website will cost to design and build.', category: 'everyday-life' },
    { slug: 'percentage-calculator',    name: 'Percentage Calculator',    icon: '📊', description: 'Calculate percentages, increases, decreases, and differences.', category: 'math' },
    { slug: 'age-calculator',           name: 'Age Calculator',           icon: '🎂', description: 'Calculate exact age in years, months, days, hours, and minutes.', category: 'everyday-life' },
  ];

  const categoryRoutes = Object.entries(CATEGORY_SLUG_MAP).map(([routeSlug, categorySlug]) => ({
    params: { slug: routeSlug },
    props: { type: 'category' as const, routeSlug, categorySlug, calc: null },
  }));

  const calcRoutes = MVP_CALCS.map(calc => ({
    params: { slug: calc.slug },
    props: { type: 'calculator' as const, routeSlug: calc.slug, categorySlug: calc.category, calc },
  }));

  return [...categoryRoutes, ...calcRoutes];
}

const { type, routeSlug, categorySlug, calc } = Astro.props;

const ACCENT = '#F7933C';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const category = calculatorCategories.find(c => c.slug === categorySlug)!;
const relatedCats = calculatorCategories.filter(c => c.slug !== categorySlug).slice(0, 8);

const isMVP = type === 'calculator';

// FAQ data per calc
const calcFaqs: Record<string, {q:string;a:string}[]> = {
  'profit-margin-calculator': [
    { q: 'What is profit margin?', a: 'Profit margin is the percentage of revenue that becomes profit after all costs are deducted.' },
    { q: 'What is a good profit margin?', a: 'It varies by industry. Retail averages 2-5%, SaaS can be 60-80%, service businesses 15-40%.' },
    { q: 'What is markup vs margin?', a: 'Markup is calculated on cost, while margin is calculated on revenue. They measure different things.' },
    { q: 'Is this calculator free?', a: 'Yes — 100% free with no signup required.' },
  ],
  'website-cost-calculator': [
    { q: 'How accurate are these estimates?', a: 'These are indicative ranges based on industry averages. Actual costs vary by location and requirements.' },
    { q: 'Does the estimate include hosting?', a: 'The estimate focuses on build costs. Hosting typically adds $5-100/month depending on your platform.' },
    { q: 'Should I hire a freelancer or agency?', a: 'Freelancers are often 30-50% cheaper than agencies. Agencies offer more oversight and team support.' },
    { q: 'How do I reduce website costs?', a: 'Use templates over custom design, start with fewer pages, choose CMS platforms like WordPress or Webflow.' },
  ],
  'percentage-calculator': [
    { q: 'How do you calculate percentage?', a: 'Divide the part by the whole and multiply by 100. E.g., 30 out of 200 = (30/200) × 100 = 15%.' },
    { q: 'What is a percentage increase formula?', a: 'Percentage increase = ((new value - old value) / old value) × 100.' },
    { q: 'How do I find what percent one number is of another?', a: 'Divide the first number by the second and multiply by 100.' },
    { q: 'Can I use this for discounts?', a: 'Yes! Use "What is X% of Y?" to find discount amounts, or "Decrease by X%" to find final prices.' },
  ],
  'age-calculator': [
    { q: 'How accurate is the age calculation?', a: 'Very accurate — it accounts for leap years and varying month lengths.' },
    { q: 'Can I calculate age at a specific date?', a: 'Yes! The optional "Target Date" field lets you calculate age at any past or future date.' },
    { q: 'How are total days calculated?', a: 'We count the actual number of days between your birth date and the target date.' },
    { q: 'Is my date of birth stored anywhere?', a: 'No. All calculations are done locally in your browser. Nothing is stored or transmitted.' },
  ],
};

const genericFaqs = [
  { q: 'Is this calculator free?', a: 'Yes — all toolooo calculators are 100% free, forever. No signup, no ads, no paywalls.' },
  { q: 'When will this calculator be available?', a: 'We\'re actively building calculators for all categories. Follow @khizooo for launch announcements.' },
  { q: 'Are calculations private?', a: 'All calculations happen in your browser. Nothing is sent to any server.' },
];
---

<BaseLayout
  title={type === 'category'
    ? `${category?.title} Calculators — Free Online by toolooo`
    : `${calc?.name} — Free Online Calculator by toolooo`}
  description={type === 'category'
    ? `Free ${category?.title?.toLowerCase()} calculators. ${category?.description}`
    : `Free online ${calc?.name}. ${calc?.description} No signup required.`}
  accentColor={ACCENT}
>

{type === 'category' && category ? (
  <>
    <!-- CATEGORY LISTING PAGE -->
    <section class="cc-hero">
      <div class="k-container">
        <Breadcrumb
          crumbs={[{ label: 'Toolbox', href: url('/toolbox') }, { label: 'Calculators', href: url('/toolbox') }, { label: category.title }]}
          accentColor={ACCENT}
        />
        <div class="cc-hero-inner">
          <div class="cc-hero-icon" style="background: color-mix(in srgb, #F7933C 15%, transparent)">
            <span>{category.icon}</span>
          </div>
          <div class="cc-hero-text">
            <span class="k-section-label" style={`color: ${ACCENT}`}>toolooo · Calculators</span>
            <h1 class="cc-hero-title">{category.title} Calculators</h1>
            <p class="cc-hero-desc">{category.description}</p>
            <div class="cc-hero-meta">
              <span class="cc-meta-chip" style={`color: ${ACCENT}`}>{category.count}+ calculators</span>
              <span class="cc-meta-sep">·</span>
              <span class="cc-meta-chip">Free</span>
              <span class="cc-meta-sep">·</span>
              <span class="cc-meta-chip">No signup</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="k-section cc-calc-section">
      <div class="k-container">
        <div class="cc-section-header">
          <span class="k-section-label" style={`color: ${ACCENT}`}>Available Calculators</span>
          <h2 class="cc-section-title">{category.count} {category.title} Calculators — Coming Soon</h2>
        </div>

        <div class="cc-chip-grid">
          {category.items.map(item => (
            <div class="cc-item-chip">
              <span class="cc-chip-icon">{category.icon}</span>
              <span class="cc-chip-name">{item}</span>
              <span class="cc-chip-soon">Soon</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="cc-related-section">
      <div class="k-container">
        <h2 class="cc-related-title">Other Calculator Categories</h2>
        <div class="cc-related-grid">
          {relatedCats.map(rc => (
            <a href={url(`/toolbox/calculators/${rc.slug}-calculator`)} class="cc-related-card">
              <span class="cc-related-icon">{rc.icon}</span>
              <span class="cc-related-name">{rc.title}</span>
              <span class="cc-related-count">{rc.count}+</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </>
) : type === 'calculator' && calc ? (
  <>
    <!-- INDIVIDUAL CALCULATOR DETAIL PAGE -->
    <section class="cd-hero">
      <div class="k-container">
        <Breadcrumb
          crumbs={[
            { label: 'Toolbox', href: url('/toolbox') },
            { label: 'Calculators', href: url('/toolbox') },
            { label: category?.title ?? 'Calculator', href: url(`/toolbox/calculators/${categorySlug}-calculator`) },
            { label: calc.name },
          ]}
          accentColor={ACCENT}
        />
        <div class="cd-hero-inner">
          <div class="cd-hero-icon-wrap">
            <span class="cd-hero-icon">{calc.icon}</span>
          </div>
          <div class="cd-hero-text">
            <div class="cd-hero-badges">
              <span class="cd-badge live">Live</span>
              <span class="cd-badge free">Free</span>
            </div>
            <h1 class="cd-hero-title">{calc.name}</h1>
            <p class="cd-hero-desc">{calc.description}</p>
            <div class="cd-hero-meta">
              <span>{category?.icon} {category?.title}</span>
              <span>·</span>
              <span>No signup</span>
              <span>·</span>
              <span>Instant results</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="cd-calc-section k-section">
      <div class="k-container">
        <div class="cd-layout">
          <div class="cd-main">
            <div class="cd-calc-wrap">
              {calc.slug === 'profit-margin-calculator' && <ProfitMarginCalc client:load />}
              {calc.slug === 'website-cost-calculator' && <WebsiteCostCalc client:load />}
              {calc.slug === 'percentage-calculator' && <PercentageCalc client:load />}
              {calc.slug === 'age-calculator' && <AgeCalc client:load />}
            </div>

            <div class="cd-about">
              <h2 class="cd-section-h2">About {calc.name}</h2>
              <p class="cd-about-text">{calc.description} This calculator provides instant, accurate results right in your browser — no downloads, no accounts, no ads.</p>
              <p class="cd-about-text">Simply fill in the required fields above and click calculate. You can copy your results or use the shareable result card to save your work.</p>
            </div>

            <div class="cd-faq">
              <h2 class="cd-section-h2">Frequently Asked Questions</h2>
              <div class="cd-faq-list">
                {(calcFaqs[calc.slug] ?? genericFaqs).map(faq => (
                  <details class="cd-faq-item">
                    <summary class="cd-faq-q">{faq.q}</summary>
                    <p class="cd-faq-a">{faq.a}</p>
                  </details>
                ))}
              </div>
            </div>
          </div>

          <aside class="cd-sidebar">
            <div class="cd-sidebar-card">
              <h3 class="cd-sidebar-h3">Calculator Info</h3>
              <div class="cd-info-rows">
                <div class="cd-info-row"><span class="cd-info-label">Category</span><span class="cd-info-val">{category?.title}</span></div>
                <div class="cd-info-row"><span class="cd-info-label">Type</span><span class="cd-info-val">Calculator</span></div>
                <div class="cd-info-row"><span class="cd-info-label">Price</span><span class="cd-info-val" style="color:#22c55e;font-weight:700">Free</span></div>
                <div class="cd-info-row"><span class="cd-info-label">Login</span><span class="cd-info-val">Not required</span></div>
                <div class="cd-info-row"><span class="cd-info-label">Status</span><span class="cd-info-val" style="color:#22c55e;font-weight:700">Live ✓</span></div>
              </div>
            </div>

            <div class="cd-sidebar-card">
              <h3 class="cd-sidebar-h3">More khizology</h3>
              <div class="cd-monsters">
                {monsters.filter(m => m.status === 'active' && m.id !== 'toolooo').map(m => (
                  <a href={url(m.route)} class="cd-monster-link" style={`--mc: ${m.color}`}>
                    <img src={`${base}${m.image}`} alt={m.name} width="22" height="22" />
                    <span>{m.module}</span>
                  </a>
                ))}
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </>
) : null}

</BaseLayout>

<style>
  /* ── CATEGORY PAGE STYLES ── */
  .cc-hero { background: var(--k-bg); padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--k-border); }
  .cc-hero-inner { display: flex; gap: 1.25rem; align-items: center; margin-top: 1rem; flex-wrap: wrap; }
  .cc-hero-icon { width: 64px; height: 64px; border-radius: 1rem; display: flex; align-items: center; justify-content: center; font-size: 1.875rem; flex-shrink: 0; }
  .cc-hero-text { flex: 1; }
  .cc-hero-title { font-family: 'Poppins', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 900; color: var(--k-text); line-height: 1.1; margin: .25rem 0 .75rem; }
  .cc-hero-desc { font-size: .9rem; color: var(--k-text-muted); line-height: 1.6; margin: 0 0 .75rem; }
  .cc-hero-meta { display: flex; gap: .5rem; flex-wrap: wrap; }
  .cc-meta-chip { font-size: .78rem; font-weight: 600; }
  .cc-meta-sep { color: var(--k-text-muted); font-size: .78rem; }

  .cc-calc-section { background: var(--k-bg); }
  .cc-section-header { margin-bottom: 1.75rem; }
  .cc-section-title { font-family: 'Poppins', sans-serif; font-size: clamp(1.125rem, 2.5vw, 1.5rem); font-weight: 800; color: var(--k-text); margin: .25rem 0 0; }

  .cc-chip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: .75rem;
  }
  .cc-item-chip {
    display: flex; align-items: center; gap: .625rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-left: 3px solid #F7933C;
    border-radius: 0 .75rem .75rem 0;
    padding: .75rem 1rem;
    font-size: .825rem; color: var(--k-text); font-family: 'Poppins', sans-serif;
    font-weight: 600;
  }
  .cc-chip-icon { font-size: 1rem; flex-shrink: 0; }
  .cc-chip-name { flex: 1; }
  .cc-chip-soon {
    font-size: .6rem; font-weight: 700; text-transform: uppercase;
    padding: .1rem .4rem; border-radius: 999px;
    background: color-mix(in srgb, #F7933C 10%, transparent);
    color: #F7933C; border: 1px solid color-mix(in srgb, #F7933C 25%, transparent);
    white-space: nowrap;
  }

  .cc-related-section { padding: 2rem 0; background: var(--k-bg-card); border-top: 1px solid var(--k-border); }
  .cc-related-title { font-family: 'Poppins', sans-serif; font-size: 1.0625rem; font-weight: 800; color: var(--k-text); margin: 0 0 1.25rem; }
  .cc-related-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: .75rem; }
  .cc-related-card { display: flex; flex-direction: column; gap: .25rem; padding: .875rem 1rem; background: var(--k-bg); border: 1.5px solid var(--k-border); border-radius: .875rem; text-decoration: none; color: var(--k-text-muted); transition: border-color .2s, color .2s; }
  .cc-related-card:hover { border-color: #F7933C; color: #F7933C; }
  .cc-related-icon { font-size: 1.375rem; }
  .cc-related-name { font-weight: 700; font-family: 'Poppins', sans-serif; color: var(--k-text); font-size: .8rem; }
  .cc-related-count { font-size: .7rem; font-weight: 600; }

  /* ── INDIVIDUAL CALC DETAIL PAGE STYLES ── */
  .cd-hero { background: var(--k-bg); padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--k-border); }
  .cd-hero-inner { display: flex; gap: 1.25rem; align-items: flex-start; margin-top: 1rem; flex-wrap: wrap; }
  .cd-hero-icon-wrap { width: 64px; height: 64px; border-radius: 1rem; background: color-mix(in srgb, #F7933C 15%, transparent); border: 2px solid color-mix(in srgb, #F7933C 30%, transparent); display: flex; align-items: center; justify-content: center; font-size: 1.875rem; flex-shrink: 0; }
  .cd-hero-icon { line-height: 1; }
  .cd-hero-text { flex: 1; min-width: 260px; }
  .cd-hero-badges { display: flex; gap: .375rem; flex-wrap: wrap; margin-bottom: .625rem; }
  .cd-badge { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; padding: .15rem .5rem; border-radius: 999px; font-family: 'Poppins', sans-serif; }
  .cd-badge.live { background: color-mix(in srgb, #22c55e 15%, transparent); color: #16a34a; border: 1px solid color-mix(in srgb, #22c55e 30%, transparent); }
  .cd-badge.free { background: color-mix(in srgb, #22c55e 15%, transparent); color: #16a34a; border: 1px solid color-mix(in srgb, #22c55e 30%, transparent); }
  .cd-hero-title { font-family: 'Poppins', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 900; color: var(--k-text); margin: .375rem 0 .75rem; line-height: 1.1; }
  .cd-hero-desc { font-size: 1rem; color: var(--k-text-muted); line-height: 1.7; max-width: 540px; margin: 0 0 .75rem; }
  .cd-hero-meta { display: flex; gap: .5rem; font-size: .8rem; color: var(--k-text-muted); flex-wrap: wrap; }

  .cd-calc-section { background: var(--k-bg); }
  .cd-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) { .cd-layout { grid-template-columns: 1fr 280px; } }

  .cd-calc-wrap { margin-bottom: 2rem; }
  .cd-about { background: var(--k-bg-card); border: 1px solid var(--k-border); border-radius: 1rem; padding: 1.5rem; margin-bottom: 1.25rem; }
  .cd-faq { background: var(--k-bg-card); border: 1px solid var(--k-border); border-radius: 1rem; padding: 1.5rem; margin-bottom: 1.25rem; }
  .cd-section-h2 { font-family: 'Poppins', sans-serif; font-size: 1.0625rem; font-weight: 800; color: var(--k-text); margin: 0 0 .875rem; }
  .cd-about-text { font-size: .9rem; color: var(--k-text-muted); line-height: 1.75; margin: 0 0 .625rem; }
  .cd-faq-list { display: flex; flex-direction: column; gap: .625rem; }
  .cd-faq-item { background: var(--k-bg); border: 1px solid var(--k-border); border-radius: .75rem; overflow: hidden; }
  .cd-faq-q { padding: .875rem 1rem; cursor: pointer; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: .875rem; color: var(--k-text); list-style: none; display: flex; justify-content: space-between; }
  .cd-faq-q::after { content: '+'; color: var(--k-text-muted); }
  details[open] .cd-faq-q::after { content: '–'; }
  .cd-faq-a { padding: 0 1rem .875rem; font-size: .875rem; color: var(--k-text-muted); line-height: 1.7; margin: 0; }

  .cd-sidebar { display: flex; flex-direction: column; gap: 1rem; }
  .cd-sidebar-card { background: var(--k-bg-card); border: 1px solid var(--k-border); border-radius: 1rem; padding: 1.25rem; }
  .cd-sidebar-h3 { font-family: 'Poppins', sans-serif; font-size: .875rem; font-weight: 800; color: var(--k-text); margin: 0 0 .75rem; }
  .cd-info-rows { display: flex; flex-direction: column; gap: .375rem; }
  .cd-info-row { display: flex; justify-content: space-between; font-size: .825rem; padding: .375rem 0; border-bottom: 1px solid var(--k-border); }
  .cd-info-row:last-child { border-bottom: none; }
  .cd-info-label { color: var(--k-text-muted); font-weight: 600; }
  .cd-info-val { color: var(--k-text); font-weight: 600; font-family: 'Poppins', sans-serif; }
  .cd-monsters { display: flex; flex-direction: column; gap: .375rem; }
  .cd-monster-link { display: flex; align-items: center; gap: .5rem; padding: .5rem .625rem; border-radius: .625rem; border: 1px solid var(--k-border); text-decoration: none; color: var(--k-text-muted); font-size: .8rem; font-weight: 600; transition: border-color .2s, color .2s; }
  .cd-monster-link:hover { border-color: var(--mc); color: var(--mc); }
  .cd-monster-link img { border-radius: .25rem; object-fit: contain; }
</style>
