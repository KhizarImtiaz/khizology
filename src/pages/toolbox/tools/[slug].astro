---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import { toolGroups, allTools } from '../../../data/toolsData';
import { monsters } from '../../../data/monsters';
import { url } from '../../../utils/url';
import InstagramBioScore from '../../../components/tools/InstagramBioScore';

export async function getStaticPaths() {
  return allTools.map(tool => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
const ACCENT = '#F7933C';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const group = toolGroups.find(g => g.slug === tool.category)!;
const related = allTools.filter(t => t.slug !== tool.slug && t.category === tool.category).slice(0, 3);

const useCases: Record<string, string[]> = {
  'instagram-bio-score': [
    'Profile optimization before a brand launch or rebrand',
    'Comparing bio versions for A/B testing',
    'Coaching clients through their social media presence',
    'Quick audit after niche pivot or audience shift',
    'Benchmarking bios before running paid promotions',
  ],
};
const faqs: Record<string, {q: string; a: string}[]> = {
  'instagram-bio-score': [
    { q: 'Is this tool 100% free?', a: 'Yes. The Instagram Bio Score Checker is completely free with no signup required.' },
    { q: 'How is the score calculated?', a: 'We analyze 8 key dimensions: bio length, emoji usage, niche clarity, CTA presence, structural formatting, specifics, power words, and brand presence. Each is weighted to a total of 100 points.' },
    { q: 'Does this access my Instagram account?', a: 'No. This is a purely client-side tool. You paste your bio text and we analyze it locally — no account access, no login, no data sent anywhere.' },
    { q: 'Can I use the improved bio suggestions directly?', a: 'Yes! The suggestions are starting points. Edit them to match your exact voice and update your Instagram bio directly.' },
    { q: 'How often should I audit my bio?', a: 'We recommend auditing your bio every 1–3 months, or any time you change your niche, offer, or content focus.' },
  ],
};

const comingSoonUseCases = [
  'Quick content creation on the go',
  'Streamlining repetitive writing tasks',
  'Improving content quality and consistency',
  'Saving hours per week on copy creation',
];
const comingSoonFaqs = [
  { q: 'When will this tool be available?', a: 'We\'re actively building and testing this tool. Follow @khizooo for launch updates.' },
  { q: 'Is there a waitlist?', a: 'Not yet, but all tools launch free. Bookmark this page and check back soon.' },
  { q: 'Will it remain free?', a: 'Yes — all toolooo tools are free, always. No hidden tiers.' },
];
---

<BaseLayout
  title={`${tool.name} — Free Tool by khizooo`}
  description={tool.description}
  accentColor={ACCENT}
>
  <!-- Hero -->
  <section class="td-hero" style={`--tc: ${group?.color ?? ACCENT}`}>
    <div class="k-container">
      <Breadcrumb
        crumbs={[
          { label: 'toolooo', href: '/toolbox' },
          { label: 'Tools', href: '/toolbox/tools' },
          { label: tool.name },
        ]}
        accentColor={ACCENT}
      />
      <div class="td-hero-inner">
        <div class="td-hero-icon-wrap">
          <span class="td-hero-icon">{tool.icon}</span>
        </div>
        <div class="td-hero-text">
          <div class="td-hero-badges">
            {tool.isMVP && <span class="td-badge mvp">MVP</span>}
            {tool.isNew && <span class="td-badge new">New</span>}
            {tool.isPopular && <span class="td-badge popular">Popular</span>}
            {!tool.live && <span class="td-badge soon">Coming Soon</span>}
            <span class="td-badge free">Free</span>
          </div>
          <h1 class="td-hero-title">{tool.name}</h1>
          <p class="td-hero-desc">{tool.description}</p>
          <div class="td-hero-meta">
            <span>🔧 {group?.title}</span>
            <span>·</span>
            <span>No signup required</span>
            <span>·</span>
            <span>100% free</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tool area -->
  <section class="td-tool-section k-section">
    <div class="k-container">
      <div class="td-layout">
        <!-- Main: Tool form OR coming soon -->
        <div class="td-main">

          {tool.slug === 'instagram-bio-score' ? (
            <InstagramBioScore client:load />
          ) : (
            <!-- Coming soon state -->
            <div class="td-coming-soon">
              <div class="td-cs-wrap">
                <div class="td-cs-icon-ring" style={`border-color: color-mix(in srgb, ${ACCENT} 40%, transparent)`}>
                  <span class="td-cs-icon">{tool.icon}</span>
                </div>
                <div class="td-cs-badge-row">
                  <span class="td-cs-badge">🔨 Under Construction</span>
                </div>
                <h2 class="td-cs-title">This Tool Is Coming Soon</h2>
                <p class="td-cs-desc">
                  We're building {tool.name}. When it launches, you'll be able to {tool.description.toLowerCase().replace(/\.$/, '')} — all for free, no signup needed.
                </p>
                <div class="td-cs-features">
                  <h3 class="td-cs-feat-h">What to expect:</h3>
                  <ul class="td-cs-feat-list">
                    <li>✦ Instant results, no backend needed</li>
                    <li>✦ Copy & share your results</li>
                    <li>✦ Mobile-friendly design</li>
                    <li>✦ Always free, no account required</li>
                  </ul>
                </div>
                <div class="td-cs-actions">
                  <a href={url("/toolbox/tools")} class="td-cs-btn-primary">← Back to All Tools</a>
                  <a href={url("/toolbox")} class="td-cs-btn-secondary">Explore Toolbox</a>
                </div>
              </div>
            </div>
          )}

          <!-- How to use -->
          <div class="td-how-to">
            <h2 class="td-section-h2">How to Use {tool.name}</h2>
            {tool.slug === 'instagram-bio-score' ? (
              <ol class="td-steps">
                <li class="td-step"><span class="td-step-num" style={`background: ${ACCENT}`}>1</span><div><strong>Enter your details</strong> — Add your name/brand, niche, and current bio.</div></li>
                <li class="td-step"><span class="td-step-num" style={`background: ${ACCENT}`}>2</span><div><strong>Set your goal</strong> — Tell us your CTA goal and preferred tone/style.</div></li>
                <li class="td-step"><span class="td-step-num" style={`background: ${ACCENT}`}>3</span><div><strong>Click Analyze</strong> — Get your score, breakdown, improved bio, and 7-day content ideas instantly.</div></li>
                <li class="td-step"><span class="td-step-num" style={`background: ${ACCENT}`}>4</span><div><strong>Copy & Apply</strong> — Use the improved bio suggestion or copy your score card to share.</div></li>
              </ol>
            ) : (
              <ol class="td-steps">
                <li class="td-step"><span class="td-step-num" style={`background: ${ACCENT}`}>1</span><div><strong>Fill in the inputs</strong> — Enter the required information for your calculation.</div></li>
                <li class="td-step"><span class="td-step-num" style={`background: ${ACCENT}`}>2</span><div><strong>Run the tool</strong> — Hit the action button to get your results instantly.</div></li>
                <li class="td-step"><span class="td-step-num" style={`background: ${ACCENT}`}>3</span><div><strong>Copy your results</strong> — Use the copy button to save or share your output.</div></li>
              </ol>
            )}
          </div>

          <!-- Use cases -->
          <div class="td-use-cases">
            <h2 class="td-section-h2">Use Cases</h2>
            <ul class="td-uc-list">
              {(useCases[tool.slug] ?? comingSoonUseCases).map(uc => (
                <li class="td-uc-item">
                  <span class="td-uc-dot" style={`background: ${ACCENT}`}></span>
                  {uc}
                </li>
              ))}
            </ul>
          </div>

          <!-- FAQ -->
          <div class="td-faq">
            <h2 class="td-section-h2">Frequently Asked Questions</h2>
            <div class="td-faq-list">
              {(faqs[tool.slug] ?? comingSoonFaqs).map(faq => (
                <details class="td-faq-item">
                  <summary class="td-faq-q">{faq.q}</summary>
                  <p class="td-faq-a">{faq.a}</p>
                </details>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="td-sidebar">
          <!-- Tool info -->
          <div class="td-sidebar-card">
            <h3 class="td-sidebar-h3">Tool Info</h3>
            <div class="td-info-grid">
              <div class="td-info-row"><span class="td-info-label">Category</span><span class="td-info-val">{group?.title}</span></div>
              <div class="td-info-row"><span class="td-info-label">Type</span><span class="td-info-val">Web Tool</span></div>
              <div class="td-info-row"><span class="td-info-label">Price</span><span class="td-info-val" style="color: #22c55e; font-weight: 700">Free</span></div>
              <div class="td-info-row"><span class="td-info-label">Login</span><span class="td-info-val">Not required</span></div>
              <div class="td-info-row"><span class="td-info-label">Status</span>
                <span class="td-info-val" style={`color: ${tool.live ? '#22c55e' : ACCENT}; font-weight: 700`}>
                  {tool.live ? 'Live' : 'Coming Soon'}
                </span>
              </div>
            </div>
          </div>

          <!-- Related tools -->
          {related.length > 0 && (
            <div class="td-sidebar-card">
              <h3 class="td-sidebar-h3">Related Tools</h3>
              <div class="td-related-list">
                {related.map(rt => (
                  <a href={url(`/toolbox/tools/${rt.slug}`)} class="td-related-item">
                    <span class="td-related-icon">{rt.icon}</span>
                    <div>
                      <div class="td-related-name">{rt.name}</div>
                      <div class="td-related-desc">{rt.description.slice(0, 55)}…</div>
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Other monsters -->
          <div class="td-sidebar-card">
            <h3 class="td-sidebar-h3">More khizology</h3>
            <div class="td-monsters">
              {monsters.filter(m => m.status === 'active' && m.id !== 'toolooo').map(m => (
                <a href={url(m.route)} class="td-monster-link" style={`--mc: ${m.color}`}>
                  <img src={`${base}${m.image}`} alt={m.name} width="22" height="22" />
                  <span>{m.module}</span>
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .td-hero { background: var(--k-bg); padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--k-border); }
  .td-hero-inner { display: flex; gap: 1.25rem; align-items: flex-start; margin-top: 1rem; flex-wrap: wrap; }
  .td-hero-icon-wrap { width: 64px; height: 64px; border-radius: 1rem; background: color-mix(in srgb, var(--tc) 15%, transparent); border: 2px solid color-mix(in srgb, var(--tc) 30%, transparent); display: flex; align-items: center; justify-content: center; font-size: 1.875rem; flex-shrink: 0; }
  .td-hero-text { flex: 1; min-width: 260px; }
  .td-hero-badges { display: flex; gap: .375rem; flex-wrap: wrap; margin-bottom: .625rem; }
  .td-badge { font-size: .62rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; padding: .15rem .5rem; border-radius: 999px; font-family: 'Poppins', sans-serif; }
  .td-badge.mvp { background: color-mix(in srgb, #F7933C 15%, transparent); color: #c45e10; border: 1px solid color-mix(in srgb, #F7933C 30%, transparent); }
  .td-badge.new { background: color-mix(in srgb, #5CCFAF 15%, transparent); color: #2a9175; border: 1px solid color-mix(in srgb, #5CCFAF 30%, transparent); }
  .td-badge.popular { background: color-mix(in srgb, #F5CF5C 15%, transparent); color: #b08a00; border: 1px solid color-mix(in srgb, #F5CF5C 30%, transparent); }
  .td-badge.soon { background: var(--k-bg-elevated); color: var(--k-text-muted); border: 1px solid var(--k-border); }
  .td-badge.free { background: color-mix(in srgb, #22c55e 15%, transparent); color: #16a34a; border: 1px solid color-mix(in srgb, #22c55e 30%, transparent); }
  .td-hero-title { font-family: 'Poppins', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 900; color: var(--k-text); line-height: 1.1; margin: .375rem 0 .75rem; }
  .td-hero-desc { font-size: 1rem; color: var(--k-text-muted); line-height: 1.7; max-width: 540px; margin: 0 0 .75rem; }
  .td-hero-meta { display: flex; gap: .5rem; font-size: .8rem; color: var(--k-text-muted); flex-wrap: wrap; }

  /* Layout */
  .td-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) { .td-layout { grid-template-columns: 1fr 280px; } }

  /* Coming soon */
  .td-coming-soon { background: var(--k-bg-card); border: 2px dashed var(--k-border); border-radius: 1.25rem; padding: 3rem 1.5rem; margin-bottom: 2rem; }
  .td-cs-wrap { text-align: center; max-width: 480px; margin: 0 auto; }
  .td-cs-icon-ring { width: 90px; height: 90px; border-radius: 50%; border: 3px solid; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
  .td-cs-icon { font-size: 2.5rem; }
  .td-cs-badge-row { margin-bottom: .75rem; }
  .td-cs-badge { font-size: .72rem; font-weight: 700; padding: .25rem .875rem; border-radius: 999px; background: var(--k-bg-elevated); border: 1px solid var(--k-border); color: var(--k-text-muted); font-family: 'Poppins', sans-serif; }
  .td-cs-title { font-family: 'Poppins', sans-serif; font-size: 1.25rem; font-weight: 800; color: var(--k-text); margin: 0 0 .625rem; }
  .td-cs-desc { font-size: .875rem; color: var(--k-text-muted); line-height: 1.7; margin: 0 0 1.25rem; }
  .td-cs-features { text-align: left; background: var(--k-bg); border: 1px solid var(--k-border); border-radius: .875rem; padding: 1rem 1.25rem; margin-bottom: 1.5rem; }
  .td-cs-feat-h { font-family: 'Poppins', sans-serif; font-size: .825rem; font-weight: 700; color: var(--k-text-muted); margin: 0 0 .5rem; text-transform: uppercase; letter-spacing: .06em; }
  .td-cs-feat-list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: .375rem; }
  .td-cs-feat-list li { font-size: .875rem; color: var(--k-text); }
  .td-cs-actions { display: flex; gap: .75rem; justify-content: center; flex-wrap: wrap; }
  .td-cs-btn-primary { background: #F7933C; color: #fff; padding: .6rem 1.5rem; border-radius: .625rem; font-weight: 700; font-size: .875rem; font-family: 'Poppins', sans-serif; text-decoration: none; }
  .td-cs-btn-secondary { background: var(--k-bg); color: var(--k-text-muted); padding: .6rem 1.5rem; border-radius: .625rem; font-weight: 700; font-size: .875rem; font-family: 'Poppins', sans-serif; text-decoration: none; border: 1px solid var(--k-border); }

  /* How-to / Use cases / FAQ */
  .td-how-to, .td-use-cases, .td-faq { margin-bottom: 2rem; padding: 1.5rem; background: var(--k-bg-card); border: 1px solid var(--k-border); border-radius: 1rem; }
  .td-section-h2 { font-family: 'Poppins', sans-serif; font-size: 1.0625rem; font-weight: 800; color: var(--k-text); margin: 0 0 1rem; }
  .td-steps { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: .875rem; }
  .td-step { display: flex; gap: .875rem; align-items: flex-start; font-size: .9rem; color: var(--k-text); line-height: 1.5; }
  .td-step-num { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: .72rem; font-weight: 800; color: #fff; flex-shrink: 0; font-family: 'Poppins', sans-serif; }
  .td-uc-list { margin: 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: .625rem; }
  .td-uc-item { display: flex; gap: .75rem; align-items: flex-start; font-size: .9rem; color: var(--k-text); line-height: 1.5; }
  .td-uc-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 6px; }
  .td-faq-list { display: flex; flex-direction: column; gap: .625rem; }
  .td-faq-item { background: var(--k-bg); border: 1px solid var(--k-border); border-radius: .75rem; overflow: hidden; }
  .td-faq-q { padding: .875rem 1rem; cursor: pointer; font-family: 'Poppins', sans-serif; font-weight: 700; font-size: .875rem; color: var(--k-text); list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .td-faq-q::after { content: '+'; color: var(--k-text-muted); }
  details[open] .td-faq-q::after { content: '–'; }
  .td-faq-a { padding: 0 1rem .875rem; font-size: .875rem; color: var(--k-text-muted); line-height: 1.7; margin: 0; }

  /* Sidebar */
  .td-sidebar { display: flex; flex-direction: column; gap: 1rem; }
  .td-sidebar-card { background: var(--k-bg-card); border: 1px solid var(--k-border); border-radius: 1rem; padding: 1.25rem; }
  .td-sidebar-h3 { font-family: 'Poppins', sans-serif; font-size: .875rem; font-weight: 800; color: var(--k-text); margin: 0 0 .75rem; }
  .td-info-grid { display: flex; flex-direction: column; gap: .5rem; }
  .td-info-row { display: flex; justify-content: space-between; align-items: center; font-size: .825rem; padding: .375rem 0; border-bottom: 1px solid var(--k-border); }
  .td-info-row:last-child { border-bottom: none; }
  .td-info-label { color: var(--k-text-muted); font-weight: 600; }
  .td-info-val { color: var(--k-text); font-weight: 600; font-family: 'Poppins', sans-serif; }
  .td-related-list { display: flex; flex-direction: column; gap: .625rem; }
  .td-related-item { display: flex; gap: .75rem; align-items: flex-start; text-decoration: none; color: inherit; padding: .5rem; border-radius: .5rem; transition: background .2s; }
  .td-related-item:hover { background: var(--k-bg); }
  .td-related-icon { font-size: 1.25rem; flex-shrink: 0; }
  .td-related-name { font-size: .825rem; font-weight: 700; color: var(--k-text); font-family: 'Poppins', sans-serif; }
  .td-related-desc { font-size: .75rem; color: var(--k-text-muted); line-height: 1.4; }
  .td-monsters { display: flex; flex-direction: column; gap: .375rem; }
  .td-monster-link { display: flex; align-items: center; gap: .5rem; padding: .5rem .625rem; border-radius: .625rem; border: 1px solid var(--k-border); text-decoration: none; color: var(--k-text-muted); font-size: .8rem; font-weight: 600; transition: border-color .2s, color .2s; }
  .td-monster-link:hover { border-color: var(--mc); color: var(--mc); }
  .td-monster-link img { border-radius: .25rem; object-fit: contain; }
</style>
