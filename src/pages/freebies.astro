---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { freebiesCategories } from '../data/freebies';
import { monsters } from '../data/monsters';

const ACCENT = '#6CA6FF';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const totalResources = freebiesCategories.reduce((sum, c) => sum + c.resourceCount, 0);
---

<BaseLayout
  title="freeooo — Free Design & Dev Resources by khizooo"
  description={`${totalResources}+ curated free resources across ${freebiesCategories.length} categories — icons, illustrations, photos, tools, fonts, and more. Always free.`}
  accentColor={ACCENT}
>
  <!-- Hero -->
  <section class="fr-hero">
    <div class="k-container">
      <Breadcrumb crumbs={[{ label: 'freeooo', href: '/freebies' }]} accentColor={ACCENT} />
      <div class="fr-hero-inner">
        <div class="fr-hero-text">
          <div class="fr-hero-badge">
            <img src={`${base}/images/Monsters/freeooo.png`} alt="freeooo" width="40" height="40" class="fr-hero-monster" />
            <span class="k-section-label" style={`color: ${ACCENT}`}>freeooo · Freebies</span>
          </div>
          <h1 class="fr-hero-title">
            {totalResources}+ Free Resources.<br />
            <span class="fr-hero-accent">For Creators.</span>
          </h1>
          <p class="fr-hero-lead">
            The best free icons, illustrations, photos, fonts, tools, and more —
            hand-curated across {freebiesCategories.length} categories. No paywalls. No BS.
          </p>
          <div class="fr-hero-stats">
            <div class="fr-stat">
              <span class="fr-stat-num">{totalResources}+</span>
              <span class="fr-stat-label">Resources</span>
            </div>
            <div class="fr-stat">
              <span class="fr-stat-num">{freebiesCategories.length}</span>
              <span class="fr-stat-label">Categories</span>
            </div>
            <div class="fr-stat">
              <span class="fr-stat-num">100%</span>
              <span class="fr-stat-label">Free</span>
            </div>
          </div>
        </div>
        <div class="fr-hero-visual">
          <div class="fr-cat-chips">
            {freebiesCategories.slice(0, 8).map((c, i) => (
              <a href={`/freebies/${c.slug}`} class="fr-chip" style={`--fc: ${c.color}; --idx: ${i}`}>
                <span>{c.icon}</span>
                <span>{c.title}</span>
                <span class="fr-chip-count">{c.resourceCount}</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- All Categories -->
  <section class="k-section fr-cats-section">
    <div class="k-container">
      <div class="fr-section-header">
        <span class="k-section-label" style={`color: ${ACCENT}`}>The Library</span>
        <h2 class="fr-section-title">Browse All {freebiesCategories.length} Categories</h2>
        <p class="fr-section-sub">Every category is hand-curated — only the best resources make the cut.</p>
      </div>

      <div class="fr-cats-grid">
        {freebiesCategories.map(cat => (
          <a href={`/freebies/${cat.slug}`} class="fr-cat-card" style={`--fc: ${cat.color}`}>
            <div class="fr-cat-glow"></div>
            <div class="fr-cat-top">
              <div class="fr-cat-icon-wrap">
                <span class="fr-cat-icon">{cat.icon}</span>
              </div>
              <span class="fr-cat-count-badge">{cat.resourceCount} resources</span>
            </div>
            <h3 class="fr-cat-title">{cat.title}</h3>
            <p class="fr-cat-desc">{cat.description}</p>
            <div class="fr-cat-tags">
              {cat.tags.map(t => <span class="fr-tag">{t}</span>)}
            </div>
            <span class="fr-cat-cta">Browse →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why freeooo -->
  <section class="fr-why-section">
    <div class="k-container">
      <div class="fr-why-inner">
        <div class="fr-why-text">
          <span class="k-section-label" style={`color: ${ACCENT}`}>Why freeooo?</span>
          <h2 class="fr-why-title">Stop searching. Start creating.</h2>
          <p class="fr-why-desc">
            Hours wasted hunting for the right icon, illustration, or font. freeooo is
            the curated shortcut — every resource handpicked so you can focus on building.
          </p>
          <ul class="fr-why-list">
            <li>✦ Curated by a designer, not a bot</li>
            <li>✦ Only free-tier and open licenses included</li>
            <li>✦ Updated regularly with new finds</li>
            <li>✦ Organized for fast browsing</li>
          </ul>
        </div>
        <div class="fr-why-cta">
          <div class="fr-cta-card" style={`--fc: ${ACCENT}`}>
            <img src={`${base}/images/Monsters/freeooo.png`} alt="freeooo" width="80" height="80" />
            <h3>Know a great resource?</h3>
            <p>Drop a vibe and suggest a resource to add to the library.</p>
            <a href="/drop-a-vibe" class="fr-cta-btn" style={`background: ${ACCENT}`}>Suggest a Resource →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Other monsters -->
  <section class="fr-other-section">
    <div class="k-container">
      <div class="fr-other-inner">
        <p class="fr-other-label">More khizology monsters →</p>
        <div class="fr-other-links">
          {monsters.filter(m => m.status === 'active' && m.id !== 'freeooo').map(m => (
            <a href={m.route} class="fr-other-link" style={`--mc: ${m.color}`}>
              <img src={`${base}${m.image}`} alt={m.name} width="28" height="28" />
              <span>{m.module}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .fr-hero {
    background: var(--k-bg); padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--k-border);
  }
  .fr-hero-inner {
    display: grid; grid-template-columns: 1fr; gap: 3rem;
    align-items: center; margin-top: 1rem;
  }
  @media (min-width: 900px) { .fr-hero-inner { grid-template-columns: 1fr 1fr; } }
  .fr-hero-badge { display: flex; align-items: center; gap: .625rem; margin-bottom: .5rem; }
  .fr-hero-monster { border-radius: .5rem; object-fit: contain; }
  .fr-hero-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 900; line-height: 1.1; color: var(--k-text); margin: .25rem 0 1rem;
  }
  .fr-hero-accent { color: #6CA6FF; }
  .fr-hero-lead {
    font-size: 1rem; color: var(--k-text-muted); line-height: 1.7;
    max-width: 480px; margin: 0 0 1.5rem;
  }
  .fr-hero-stats { display: flex; gap: 2rem; }
  .fr-stat { display: flex; flex-direction: column; gap: .125rem; }
  .fr-stat-num {
    font-family: 'Poppins', sans-serif; font-size: 1.5rem;
    font-weight: 900; color: #6CA6FF; line-height: 1;
  }
  .fr-stat-label {
    font-size: .72rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--k-text-muted);
  }

  /* Chips */
  .fr-cat-chips { display: flex; flex-wrap: wrap; gap: .5rem; }
  .fr-chip {
    display: inline-flex; align-items: center; gap: .5rem;
    background: var(--k-bg-card); border: 1.5px solid color-mix(in srgb, var(--fc) 40%, transparent);
    border-radius: 999px; padding: .45rem .875rem;
    font-size: .8rem; font-weight: 600; color: var(--k-text);
    text-decoration: none; font-family: 'Poppins', sans-serif;
    transition: border-color .2s, background .2s;
    animation: fadeIn .3s ease both;
    animation-delay: calc(var(--idx) * .05s);
  }
  .fr-chip:hover { border-color: var(--fc); background: color-mix(in srgb, var(--fc) 8%, transparent); }
  .fr-chip-count {
    font-size: .68rem; color: var(--fc); font-weight: 700;
    background: color-mix(in srgb, var(--fc) 12%, transparent);
    padding: .1rem .4rem; border-radius: 999px;
  }

  /* Section header */
  .fr-section-header { margin-bottom: 2rem; }
  .fr-section-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800;
    color: var(--k-text); margin: .25rem 0 .5rem;
  }
  .fr-section-sub { font-size: .9rem; color: var(--k-text-muted); margin: 0; }

  /* Cards */
  .fr-cats-section { background: var(--k-bg-card); border-top: 1px solid var(--k-border); }
  .fr-cats-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem;
  }
  .fr-cat-card {
    position: relative; background: var(--k-bg); border: 1.5px solid var(--k-border);
    border-radius: 1.25rem; padding: 1.5rem; overflow: hidden;
    display: flex; flex-direction: column; gap: .625rem;
    text-decoration: none; transition: border-color .2s, transform .2s;
  }
  .fr-cat-card:hover { border-color: var(--fc); transform: translateY(-3px); }
  .fr-cat-glow {
    position: absolute; top: -20px; right: -20px;
    width: 80px; height: 80px; border-radius: 50%;
    background: var(--fc); opacity: .07; filter: blur(20px);
    pointer-events: none; transition: opacity .3s;
  }
  .fr-cat-card:hover .fr-cat-glow { opacity: .18; }
  .fr-cat-top { display: flex; align-items: center; justify-content: space-between; }
  .fr-cat-icon-wrap {
    width: 48px; height: 48px; border-radius: .75rem;
    background: color-mix(in srgb, var(--fc) 15%, transparent);
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; font-family: initial;
  }
  .fr-cat-count-badge {
    font-size: .7rem; font-weight: 700; color: var(--fc);
    background: color-mix(in srgb, var(--fc) 10%, transparent);
    padding: .2rem .6rem; border-radius: 999px; font-family: 'Poppins', sans-serif;
  }
  .fr-cat-title {
    font-family: 'Poppins', sans-serif; font-size: 1rem;
    font-weight: 800; color: var(--k-text); margin: 0;
  }
  .fr-cat-desc { font-size: .8rem; color: var(--k-text-muted); line-height: 1.5; margin: 0; flex: 1; }
  .fr-cat-tags { display: flex; gap: .375rem; flex-wrap: wrap; }
  .fr-tag {
    font-size: .65rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em;
    color: var(--k-text-muted); background: var(--k-border);
    padding: .15rem .5rem; border-radius: 999px; font-family: 'Poppins', sans-serif;
  }
  .fr-cat-cta {
    font-size: .8rem; font-weight: 700; color: var(--fc);
    font-family: 'Poppins', sans-serif; margin-top: .25rem;
  }

  /* Why */
  .fr-why-section { background: var(--k-bg); padding: 5rem 0; border-top: 1px solid var(--k-border); }
  .fr-why-inner {
    display: grid; grid-template-columns: 1fr; gap: 3rem; align-items: center;
  }
  @media (min-width: 768px) { .fr-why-inner { grid-template-columns: 1fr 1fr; } }
  .fr-why-title {
    font-family: 'Poppins', sans-serif; font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 900; color: var(--k-text); margin: .5rem 0 1rem;
  }
  .fr-why-desc { font-size: .95rem; color: var(--k-text-muted); line-height: 1.7; margin: 0 0 1.25rem; }
  .fr-why-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: .5rem; }
  .fr-why-list li { font-size: .875rem; color: var(--k-text-muted); }

  .fr-cta-card {
    background: var(--k-bg-card); border: 1.5px solid var(--fc);
    border-radius: 1.5rem; padding: 2rem; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: .875rem;
  }
  .fr-cta-card img { border-radius: .75rem; }
  .fr-cta-card h3 {
    font-family: 'Poppins', sans-serif; font-size: 1.25rem;
    font-weight: 800; color: var(--k-text); margin: 0;
  }
  .fr-cta-card p { font-size: .875rem; color: var(--k-text-muted); margin: 0; }
  .fr-cta-btn {
    display: inline-flex; align-items: center; padding: .65rem 1.5rem;
    color: #2A3439; border-radius: .625rem; font-family: 'Poppins', sans-serif;
    font-weight: 700; font-size: .875rem; text-decoration: none; transition: opacity .2s;
  }
  .fr-cta-btn:hover { opacity: .85; }

  /* Other */
  .fr-other-section {
    background: var(--k-bg-card); border-top: 1px solid var(--k-border); padding: 2rem 0;
  }
  .fr-other-inner {
    display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; justify-content: space-between;
  }
  .fr-other-label { font-size: .8rem; font-weight: 700; color: var(--k-text-muted); }
  .fr-other-links { display: flex; gap: .625rem; flex-wrap: wrap; }
  .fr-other-link {
    display: flex; flex-direction: column; align-items: center; gap: .25rem;
    padding: .625rem; background: var(--k-bg);
    border: 1px solid var(--k-border); border-radius: .75rem;
    text-decoration: none; color: var(--k-text-muted);
    font-size: .7rem; font-weight: 600; min-width: 64px;
    transition: border-color .2s, color .2s;
  }
  .fr-other-link:hover { border-color: var(--mc); color: var(--mc); }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
</style>
