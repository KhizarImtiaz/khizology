---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { allInfographicSections, getInfographicSection } from '../../data/infographicsData';
import { monsters } from '../../data/monsters';

export async function getStaticPaths() {
  return allInfographicSections.map(section => ({
    params: { slug: section.slug },
    props: { section },
  }));
}

const { section } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const ACCENT = '#5CCFAF';

// All sections except current for related
const relatedSections = allInfographicSections
  .filter(s => s.slug !== section.slug)
  .slice(0, 6);

const hasPosts = section.posts.length > 0;

// Sample "coming soon" card data to fill empty listing
const sampleTitles: Record<string, string[]> = {
  'self-improvements': ['10 Habits of Highly Productive People', 'The Science of Building Better Habits', 'How to Rewire Your Brain for Success', '7 Mindset Shifts That Change Everything', 'The Procrastination Cure: Visual Guide'],
  'tech-and-coding': ['Every Developer Must Know These Git Commands', 'How the Internet Actually Works', 'REST vs GraphQL: A Visual Comparison', '10 Clean Code Principles Visualized', 'The Complete Linux Command Cheat Sheet'],
  'career-productivity': ['The Ultimate Time Management Framework', 'Deep Work vs Shallow Work Explained', '10 Career Mistakes to Avoid in Your 20s', 'How to Negotiate a Higher Salary', 'The Eisenhower Matrix for Productivity'],
  'human-psychology': ['The 12 Cognitive Biases That Rule Your Life', 'How Memory Actually Works', 'The Psychology of Motivation Explained', '7 Dark Patterns in UX Design', 'Social Media and the Dopamine Loop'],
  'finance': ['Compound Interest: The 8th Wonder Visualized', 'How to Start Investing with $100', 'The FIRE Movement Explained', 'Budgeting Methods Compared Side by Side', 'Understanding Your Credit Score'],
  'humanity-and-wisdom': ['Stoicism in 60 Seconds', 'The History of Money Visualized', 'Philosophy Schools Every Thinker Should Know', 'Ancient Wisdom for Modern Problems', '100 Years of World History in One Chart'],
  'kids-and-learning': ['The Solar System: Size & Scale', 'How Plants Make Food', 'The Water Cycle Explained Simply', 'Human Body Systems for Kids', 'Basic Math Operations Visualized'],
  'art-and-creativity': ['Color Theory: The Complete Guide', 'Typography Rules Every Designer Needs', 'The Golden Ratio in Design', 'How to Build a Mood Board', 'Design Principles Cheat Sheet'],
  'market-trend': ['The Rise of AI Tools in 2025', 'Remote Work Statistics Worth Knowing', 'E-commerce Growth Trends Visualized', 'The Creator Economy by the Numbers', 'Tech Industry Salary Trends'],
  'cost-breakdown': ['How Much a Website Really Costs', 'The True Cost of a Coffee Shop', 'Breaking Down SaaS Pricing Models', 'What You Actually Pay for a Smartphone', 'Hidden Costs of Running a Business'],
  'decision-trees': ['Should You Freelance or Get a Job?', 'Choosing the Right Tech Stack', 'Career Change Decision Framework', 'When to Quit Your Job', 'Should You Start a Business?'],
  'comparison': ['React vs Vue vs Angular in 2025', 'iOS vs Android: The Complete Comparison', 'Traditional Learning vs Online Learning', 'Freelance vs Agency: What\'s Right for You?', 'Coffee vs Tea: Health Benefits Compared'],
  'cheat-sheet-framework': ['The Complete CSS Flexbox Cheat Sheet', 'Git Commands Every Developer Needs', 'Python for Beginners Cheat Sheet', 'The AARRR Pirate Metrics Framework', 'The Ultimate Productivity System'],
  'data-stats': ['Internet Usage Statistics 2025', 'The World\'s Top Programming Languages', 'Social Media User Stats by Platform', 'Global Mental Health Statistics', 'The State of AI Adoption'],
  'step-by-step-process': ['How to Start a Side Hustle in 5 Steps', 'The Design Thinking Process Visualized', 'How to Write a Blog Post Step by Step', 'Building a Personal Brand From Zero', 'The MVP Development Process'],
  'mistakes-fixes': ['10 Common CSS Mistakes and Fixes', 'Resume Mistakes That Cost You Interviews', 'Business Launch Mistakes to Avoid', 'Common Investment Mistakes Beginners Make', 'Social Media Mistakes That Kill Engagement'],
};

const fallbackTitles = sampleTitles[section.slug] || ['Coming Soon: Visual Content', 'More Infographics Loading', 'New Visuals In Production', 'Content Being Created', 'Knowledge Incoming'];
---

<BaseLayout
  title={section.seoTitle}
  description={section.seoDesc}
  accentColor={ACCENT}
>
  <!-- Hero -->
  <section class="ig-cat-hero">
    <div class="k-container">
      <Breadcrumb
        crumbs={[
          { label: 'Infographics', href: '/infographics' },
          { label: section.title },
        ]}
        accentColor={ACCENT}
      />
      <div class="ig-cat-hero-inner">
        <div class="ig-cat-icon-wrap" style={`--ic: ${section.color}`}>
          <span class="ig-cat-emoji">{section.icon}</span>
        </div>
        <div class="ig-cat-hero-text">
          <div class="ig-cat-kind-badge" style={`background: color-mix(in srgb, ${section.color} 12%, transparent); color: ${section.color}; border: 1px solid color-mix(in srgb, ${section.color} 30%, transparent)`}>
            {section.kind === 'topic' ? '📚 Learning Topic' : '📊 Infographic Type'}
          </div>
          <h1 class="ig-cat-title">{section.title}</h1>
          <p class="ig-cat-desc">{section.description}</p>
          <div class="ig-cat-stats">
            <span class="ig-cat-stat">
              {hasPosts ? `${section.posts.length} infographics` : 'Coming soon'}
            </span>
            <span class="ig-cat-sep">·</span>
            <span class="ig-cat-stat">infooo collection</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Listing -->
  <section class="k-section ig-listing-section">
    <div class="k-container">

      {hasPosts ? (
        <div class="ig-posts-grid">
          {section.posts.map(post => (
            <a href={`/infographics/${section.slug}/${post.slug}`} class="ig-post-card" style={`--ic: ${section.color}`}>
              <div class="ig-post-img-placeholder skeleton"></div>
              <div class="ig-post-body">
                <div class="ig-post-meta">
                  <span class="ig-post-cat">{post.category}</span>
                  <span class="ig-post-time">{post.readingTime}</span>
                </div>
                <h2 class="ig-post-title">{post.title}</h2>
                <p class="ig-post-summary">{post.summary}</p>
                <div class="ig-post-tags">
                  {post.tags.slice(0,3).map(t => <span class="ig-tag">{t}</span>)}
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="ig-coming-section">
          <div class="ig-coming-header">
            <span class="k-section-label" style={`color: ${ACCENT}`}>Preview</span>
            <h2 class="ig-coming-title">What's Coming to {section.title}</h2>
            <p class="ig-coming-sub">These infographics are being created. Each one will be fully visual, shareable, and packed with value.</p>
          </div>
          <!-- Skeleton previews -->
          <div class="ig-preview-grid">
            {fallbackTitles.map((title, i) => (
              <div class="ig-preview-card" style={`--ic: ${section.color}; --delay: ${i * 0.08}s`}>
                <div class="ig-preview-thumb skeleton"></div>
                <div class="ig-preview-body">
                  <div class="ig-preview-coming-badge">Coming Soon</div>
                  <h3 class="ig-preview-title">{title}</h3>
                  <div class="ig-preview-tags">
                    <span class="ig-tag">{section.title}</span>
                    <span class="ig-tag">Visual</span>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <!-- CTA -->
          <div class="ig-coming-cta">
            <div class="ig-cta-card">
              <span class="ig-cta-icon">{section.icon}</span>
              <h3>Be first when {section.title} drops</h3>
              <p>Follow khizology and get notified when new infographics go live.</p>
              <a href="/drop-a-vibe" class="ig-cta-btn" style={`background: ${ACCENT}`}>Stay in the Loop →</a>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Related categories -->
  <section class="ig-related-section">
    <div class="k-container">
      <h2 class="ig-related-title">More Infographic Categories</h2>
      <div class="ig-related-grid">
        {relatedSections.map(s => (
          <a href={`/infographics/${s.slug}`} class="ig-related-card" style={`--rc: ${s.color}`}>
            <span class="ig-related-icon">{s.icon}</span>
            <span class="ig-related-name">{s.title}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-sell -->
  <section class="ig-cross-section">
    <div class="k-container">
      <div class="ig-cross-inner">
        <div class="ig-cross-text">
          <p class="ig-cross-label">Explore more khizology →</p>
          <h2 class="ig-cross-title">While you wait, check out these monsters</h2>
        </div>
        <div class="ig-cross-links">
          {monsters.filter(m => m.status === 'active').map(m => (
            <a href={m.route} class="ig-cross-link" style={`--mc: ${m.color}`}>
              <img src={`${base}${m.image}`} alt={m.name} width="28" height="28" />
              <span>{m.module}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .ig-cat-hero {
    background: var(--k-bg); padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--k-border);
  }
  .ig-cat-hero-inner {
    display: flex; gap: 1.5rem; align-items: flex-start; margin-top: 1rem; flex-wrap: wrap;
  }
  .ig-cat-icon-wrap {
    width: 72px; height: 72px; border-radius: 1.125rem; flex-shrink: 0;
    background: color-mix(in srgb, var(--ic) 15%, transparent);
    display: flex; align-items: center; justify-content: center; font-size: 2rem;
  }
  .ig-cat-hero-text { flex: 1; min-width: 280px; }
  .ig-cat-kind-badge {
    display: inline-flex; align-items: center; gap: .375rem;
    padding: .25rem .75rem; border-radius: 999px; font-size: .72rem;
    font-weight: 700; font-family: 'Poppins', sans-serif; margin-bottom: .75rem;
  }
  .ig-cat-title {
    font-family: 'Poppins', sans-serif; font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900; color: var(--k-text); margin: 0 0 .75rem; line-height: 1.1;
  }
  .ig-cat-desc { font-size: .975rem; color: var(--k-text-muted); line-height: 1.7; margin: 0 0 .875rem; max-width: 600px; }
  .ig-cat-stats { display: flex; align-items: center; gap: .5rem; font-size: .78rem; color: var(--k-text-muted); }
  .ig-cat-sep { opacity: .4; }

  /* Listing section */
  .ig-listing-section { background: var(--k-bg); }

  /* Posts grid */
  .ig-posts-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;
  }
  .ig-post-card {
    background: var(--k-bg-card); border: 1.5px solid var(--k-border);
    border-radius: 1.25rem; overflow: hidden; text-decoration: none;
    display: flex; flex-direction: column; transition: border-color .2s, transform .2s;
  }
  .ig-post-card:hover { border-color: var(--ic); transform: translateY(-3px); }
  .ig-post-img-placeholder { height: 180px; width: 100%; }
  .ig-post-body { padding: 1.25rem; display: flex; flex-direction: column; gap: .5rem; flex: 1; }
  .ig-post-meta { display: flex; align-items: center; justify-content: space-between; }
  .ig-post-cat { font-size: .7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--ic); font-family: 'Poppins', sans-serif; }
  .ig-post-time { font-size: .7rem; color: var(--k-text-muted); }
  .ig-post-title { font-family: 'Poppins', sans-serif; font-size: .975rem; font-weight: 800; color: var(--k-text); margin: 0; line-height: 1.3; }
  .ig-post-summary { font-size: .8rem; color: var(--k-text-muted); line-height: 1.5; margin: 0; flex: 1; }
  .ig-post-tags { display: flex; gap: .375rem; flex-wrap: wrap; }

  /* Tags */
  .ig-tag {
    font-size: .65rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em;
    color: var(--k-text-muted); background: var(--k-bg);
    padding: .15rem .5rem; border-radius: 999px; font-family: 'Poppins', sans-serif;
    border: 1px solid var(--k-border);
  }

  /* Coming soon */
  .ig-coming-header { margin-bottom: 2.5rem; }
  .ig-coming-title {
    font-family: 'Poppins', sans-serif; font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800; color: var(--k-text); margin: .25rem 0 .5rem;
  }
  .ig-coming-sub { font-size: .9rem; color: var(--k-text-muted); margin: 0; }

  .ig-preview-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; margin-bottom: 3rem;
  }
  .ig-preview-card {
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-radius: 1.125rem; overflow: hidden;
    display: flex; flex-direction: column;
    opacity: .85; transition: opacity .2s, border-color .2s, transform .2s;
    animation: fadeIn .35s ease both; animation-delay: var(--delay, 0s);
  }
  .ig-preview-card:hover { opacity: 1; border-color: var(--ic); transform: translateY(-2px); }
  .ig-preview-thumb { height: 140px; width: 100%; }
  .ig-preview-body { padding: 1rem; display: flex; flex-direction: column; gap: .5rem; }
  .ig-preview-coming-badge {
    display: inline-flex; font-size: .65rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .08em; color: var(--k-text-muted);
    background: var(--k-bg); padding: .15rem .5rem; border-radius: 999px;
    border: 1px solid var(--k-border); font-family: 'Poppins', sans-serif;
    align-self: flex-start;
  }
  .ig-preview-title {
    font-family: 'Poppins', sans-serif; font-size: .875rem;
    font-weight: 700; color: var(--k-text); margin: 0; line-height: 1.4;
  }
  .ig-preview-tags { display: flex; gap: .375rem; }

  .ig-coming-cta { max-width: 480px; margin: 0 auto; }
  .ig-cta-card {
    background: var(--k-bg-card); border: 1.5px solid #5CCFAF;
    border-radius: 1.5rem; padding: 2.5rem; text-align: center;
    display: flex; flex-direction: column; align-items: center; gap: .875rem;
  }
  .ig-cta-icon { font-size: 3rem; }
  .ig-cta-card h3 { font-family: 'Poppins', sans-serif; font-size: 1.25rem; font-weight: 800; color: var(--k-text); margin: 0; }
  .ig-cta-card p { font-size: .875rem; color: var(--k-text-muted); margin: 0; }
  .ig-cta-btn {
    display: inline-flex; align-items: center; padding: .65rem 1.5rem;
    color: #2A3439; border-radius: .625rem; font-family: 'Poppins', sans-serif;
    font-weight: 700; font-size: .875rem; text-decoration: none; transition: opacity .2s;
  }
  .ig-cta-btn:hover { opacity: .85; }

  /* Related */
  .ig-related-section { background: var(--k-bg-card); padding: 2.5rem 0; border-top: 1px solid var(--k-border); }
  .ig-related-title { font-family: 'Poppins', sans-serif; font-size: 1rem; font-weight: 800; color: var(--k-text); margin: 0 0 1.25rem; }
  .ig-related-grid { display: flex; gap: .625rem; flex-wrap: wrap; }
  .ig-related-card {
    display: flex; align-items: center; gap: .5rem;
    background: var(--k-bg); border: 1px solid var(--k-border);
    border-radius: .75rem; padding: .5rem .875rem;
    text-decoration: none; color: var(--k-text-muted); font-size: .8rem; font-weight: 600;
    transition: border-color .2s, color .2s;
  }
  .ig-related-card:hover { border-color: var(--rc); color: var(--rc); }
  .ig-related-icon { font-size: 1rem; }
  .ig-related-name { font-family: 'Poppins', sans-serif; font-size: .78rem; }

  /* Cross-sell */
  .ig-cross-section { background: var(--k-bg); padding: 2rem 0; border-top: 1px solid var(--k-border); }
  .ig-cross-inner { display: flex; flex-wrap: wrap; align-items: center; gap: 1.25rem; justify-content: space-between; }
  .ig-cross-label { font-size: .72rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: var(--k-text-muted); margin: 0 0 .125rem; }
  .ig-cross-title { font-family: 'Poppins', sans-serif; font-size: .975rem; font-weight: 800; color: var(--k-text); margin: 0; }
  .ig-cross-links { display: flex; gap: .625rem; flex-wrap: wrap; }
  .ig-cross-link {
    display: flex; flex-direction: column; align-items: center; gap: .25rem;
    padding: .625rem; background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-radius: .75rem; text-decoration: none; color: var(--k-text-muted);
    font-size: .7rem; font-weight: 600; min-width: 64px; transition: border-color .2s, color .2s;
  }
  .ig-cross-link:hover { border-color: var(--mc); color: var(--mc); }

  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
</style>
