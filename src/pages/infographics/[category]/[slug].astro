---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import { url } from '../../../utils/url';
import Breadcrumb from '../../../components/ui/Breadcrumb.astro';
import { allInfographicSections, getAllInfographicPosts } from '../../../data/infographicsData';
import type { InfographicSocialPost } from '../../../data/infographicsData';
import { monsters } from '../../../data/monsters';

// ── Social platform meta ──────────────────────────────────────────────────
const PLATFORM_META: Record<InfographicSocialPost['platform'], { label: string; color: string; shareUrl?: string }> = {
  instagram:  { label: 'Instagram',   color: '#E1306C' },
  facebook:   { label: 'Facebook',    color: '#1877F2', shareUrl: 'https://www.facebook.com/sharer/sharer.php?u={url}' },
  x:          { label: '𝕏 (Twitter)', color: '#000000', shareUrl: 'https://twitter.com/intent/tweet?text={title}&url={url}' },
  tiktok:     { label: 'TikTok',      color: '#FF0050' },
  pinterest:  { label: 'Pinterest',   color: '#E60023', shareUrl: 'https://pinterest.com/pin/create/button/?url={url}&description={title}' },
  threads:    { label: 'Threads',     color: '#101010', shareUrl: 'https://www.threads.net/intent/post?text={title}%20{url}' },
  linkedin:   { label: 'LinkedIn',    color: '#0A66C2', shareUrl: 'https://www.linkedin.com/sharing/share-offsite/?url={url}' },
};

// All share platforms in display order
const SHARE_PLATFORMS: InfographicSocialPost['platform'][] = [
  'x', 'facebook', 'linkedin', 'pinterest', 'threads',
  'instagram', 'tiktok'
];
import AIAgentsOfficeWork from '../../../components/infographics/AIAgentsOfficeWork.astro';

export async function getStaticPaths() {
  const allPosts = getAllInfographicPosts();
  return allPosts.map(({ section, post }) => ({
    params: { category: section.slug, slug: post.slug },
    props: { section, post },
  }));
}

const { section, post } = Astro.props;
const ACCENT = '#5CCFAF';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Related posts from the same section (excluding current)
const related = section.posts.filter(p => p.slug !== post.slug).slice(0, 3);
// Cross-section related (different sections, same kind)
const crossSections = allInfographicSections
  .filter(s => s.slug !== section.slug && s.kind === section.kind)
  .slice(0, 4);

const SITE_URL = 'https://khizarooo.github.io/khizology';
const postUrl  = `${SITE_URL}/infographics/${section.slug}/${post.slug}`;

// ── JSON-LD: Article + BreadcrumbList ──────────────────────────────────────
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.title,
    description: post.summary,
    url: postUrl,
    datePublished: post.publishedAt ?? '2026-05-10',
    dateModified: post.updatedAt ?? post.publishedAt ?? '2026-05-10',
    author: {
      '@type': 'Person',
      name: 'khizooo',
      url: `${SITE_URL}/my-portfolio`,
      sameAs: [
        'https://github.com/KhizaroOo',
        'https://www.linkedin.com/in/khizar-imtiaz',
        'https://www.instagram.com/khizooo_art',
      ],
    },
    publisher: {
      '@type': 'Organization',
      name: 'khizology',
      url: SITE_URL,
      logo: { '@type': 'ImageObject', url: `${SITE_URL}/images/Monsters/khizooo.png` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
    articleSection: section.title,
    keywords: post.tags.join(', '),
    image: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/images/site/khizooo.png`,
      width: 1200,
      height: 630,
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home',         item: SITE_URL },
      { '@type': 'ListItem', position: 2, name: 'Infographics', item: `${SITE_URL}/infographics` },
      { '@type': 'ListItem', position: 3, name: section.title,  item: `${SITE_URL}/infographics/${section.slug}` },
      { '@type': 'ListItem', position: 4, name: post.title,     item: postUrl },
    ],
  },
];
---

<BaseLayout
  title={`${post.title} — infooo by khizooo`}
  description={post.summary}
  ogType="article"
  keywords={[...post.tags, section.title, 'infographic', 'khizooo', 'infooo'].join(', ')}
  publishedAt={post.publishedAt}
  updatedAt={post.updatedAt}
  articleTags={post.tags}
  jsonLd={jsonLd}
  accentColor={ACCENT}
>
  <!-- Hero -->
  <section class="id-hero" style={`--ic: ${ACCENT}`}>
    <div class="k-container">
      <Breadcrumb
        crumbs={[
          { label: 'infooo', href: url('/infographics') },
          { label: section.title, href: url(`/infographics/${section.slug}`) },
          { label: post.title },
        ]}
        accentColor={ACCENT}
      />
      <div class="id-hero-inner">
        <div class="id-hero-meta">
          <span class="id-kind-badge" style={`background: color-mix(in srgb, ${ACCENT} 15%, transparent); color: ${ACCENT}; border-color: color-mix(in srgb, ${ACCENT} 30%, transparent)`}>
            {section.icon} {section.title}
          </span>
          {post.tags.map(t => <span class="id-tag">{t}</span>)}
        </div>
        <h1 class="id-hero-title">{post.title}</h1>
        <p class="id-hero-summary">{post.summary}</p>
        <div class="id-hero-reading">
          <span>📖 {post.readingTime} read</span>
          <span>·</span>
          <span>by khizooo</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Main content -->
  <section class="id-body k-section">
    <div class="k-container">
      <div class="id-layout">
        <!-- Left: Main -->
        <div class="id-main">

          <!-- Visual area -->
          <div class="id-visual-area" style={`--ic: ${ACCENT}`}>
            {post.live ? (
              <div class="id-live-infographic">
                {post.slug === 'ai-agents-replacing-office-work' && <AIAgentsOfficeWork />}
              </div>
            ) : (
              <div class="id-coming-soon-visual">
                <div class="id-cs-ring" style={`border-color: color-mix(in srgb, ${ACCENT} 40%, transparent)`}>
                  <span class="id-cs-icon">{section.icon}</span>
                </div>
                <h2 class="id-cs-title">Infographic Coming Soon</h2>
                <p class="id-cs-desc">
                  We're designing the full infographic for this post. The visual breakdown,
                  chart, and shareable version will be published here shortly.
                </p>
                <div class="id-cs-badge">
                  <span>🎨 Visual in production</span>
                </div>
              </div>
            )}
          </div>

          <!-- Key Points -->
          {post.keyPoints && post.keyPoints.length > 0 && (
            <div class="id-section-block">
              <h2 class="id-section-h2">
                <span class="id-section-num" style={`background: color-mix(in srgb, ${ACCENT} 15%, transparent); color: ${ACCENT}`}>01</span>
                Key Takeaways
              </h2>
              <ul class="id-key-points">
                {post.keyPoints.map(kp => (
                  <li class="id-key-point">
                    <span class="id-kp-dot" style={`background: ${ACCENT}`}></span>
                    <span>{kp}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}

          <!-- Summary deep dive -->
          <div class="id-section-block">
            <h2 class="id-section-h2">
              <span class="id-section-num" style={`background: color-mix(in srgb, ${ACCENT} 15%, transparent); color: ${ACCENT}`}>02</span>
              What This Infographic Covers
            </h2>
            {post.coverText ? (
              <p class="id-body-text">{post.coverText}</p>
            ) : (
              <>
                <p class="id-body-text">{post.summary}</p>
                <p class="id-body-text">
                  This visual guide is part of our <strong>{section.title}</strong> collection — breaking down
                  {section.kind === 'type' ? ' complex information into clear, shareable visuals' : ' important knowledge into digestible visual formats'}.
                  Each infographic is designed to give you the key insight in under 5 minutes.
                </p>
              </>
            )}
          </div>

          <!-- ── Share bar 1: platform share buttons ── -->
          <div class="id-share-bar">
            <span class="id-share-label">Share this</span>
            <div class="id-share-btns">
              <!-- Copy link -->
              <button class="id-share-btn" id="ig-copy-link-btn" data-action="copy">
                🔗 Copy Link
              </button>
              <!-- Platform share buttons -->
              {SHARE_PLATFORMS.map(platform => {
                const meta = PLATFORM_META[platform];
                const hasShare = !!meta.shareUrl;
                return (
                  <button
                    class="id-share-btn"
                    data-action={hasShare ? 'share' : 'copy-for'}
                    data-platform={platform}
                    data-share-url={meta.shareUrl ?? ''}
                    data-color={meta.color}
                    style={`--pc: ${meta.color}`}
                  >
                    {meta.label}
                  </button>
                );
              })}
              <!-- Download (live posts only) -->
              {post.live && (
                <button class="id-share-btn id-download-btn" id="ig-download-btn">
                  ⬇ Download
                </button>
              )}
            </div>
          </div>

          <!-- ── Share bar 2: "Find this post on" ── -->
          {post.socialPosts && post.socialPosts.length > 0 && (
            <div class="id-share-bar id-social-posts-bar">
              <span class="id-share-label">Find this on</span>
              <div class="id-share-btns">
                {post.socialPosts.map(sp => {
                  const meta = PLATFORM_META[sp.platform];
                  return (
                    <a
                      href={sp.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="id-share-btn id-social-post-link"
                      style={`--pc: ${meta.color}`}
                    >
                      {meta.label}
                    </a>
                  );
                })}
              </div>
            </div>
          )}

        </div>

        <!-- Right: Sidebar -->
        <aside class="id-sidebar">
          <!-- About this category -->
          <div class="id-sidebar-card">
            <div class="id-sidebar-icon" style={`background: color-mix(in srgb, ${ACCENT} 15%, transparent)`}>
              {section.icon}
            </div>
            <h3 class="id-sidebar-h3">{section.title}</h3>
            <p class="id-sidebar-desc">{section.description}</p>
            <a href={url(`/infographics/${section.slug}`)} class="id-sidebar-link" style={`color: ${ACCENT}`}>
              See all {section.title} →
            </a>
          </div>

          <!-- Tags -->
          <div class="id-sidebar-card">
            <h3 class="id-sidebar-h3">Tags</h3>
            <div class="id-tags-wrap">
              {post.tags.map(t => <span class="id-tag-chip">{t}</span>)}
            </div>
          </div>

          <!-- Other monsters -->
          <div class="id-sidebar-card">
            <h3 class="id-sidebar-h3">More khizology</h3>
            <div class="id-monsters-list">
              {monsters.filter(m => m.status === 'active' && m.id !== 'infooo').map(m => (
                <a href={url(m.route)} class="id-monster-pill" style={`--mc: ${m.color}`}>
                  <img src={`${base}${m.image}`} alt={m.name} width="22" height="22" />
                  <span>{m.module}</span>
                </a>
              ))}
            </div>
          </div>
        </aside>
      </div>

      <!-- Related from same section -->
      {related.length > 0 && (
        <div class="id-related-section">
          <span class="k-section-label" style={`color: ${ACCENT}`}>More from {section.title}</span>
          <h2 class="id-related-title">Related Infographics</h2>
          <div class="id-related-grid">
            {related.map(rp => (
              <a href={url(`/infographics/${section.slug}/${rp.slug}`)} class="id-related-card" style={`--ic: ${ACCENT}`}>
                <div class="id-related-icon">{section.icon}</div>
                <h3 class="id-related-name">{rp.title}</h3>
                <p class="id-related-summary">{rp.summary.slice(0, 90)}…</p>
                <div class="id-related-tags">
                  {rp.tags.slice(0, 3).map(t => <span class="id-tag">{t}</span>)}
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- Other categories strip -->
      {crossSections.length > 0 && (
        <div class="id-cross-section">
          <span class="k-section-label" style={`color: ${ACCENT}`}>Explore</span>
          <h2 class="id-related-title">Other {section.kind === 'type' ? 'Formats' : 'Topics'}</h2>
          <div class="id-cross-grid">
            {crossSections.map(cs => (
              <a href={url(`/infographics/${cs.slug}`)} class="id-cross-card">
                <span class="id-cross-icon">{cs.icon}</span>
                <span class="id-cross-name">{cs.title}</span>
                <span class="id-cross-count">{cs.posts.length} posts</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- FAQ -->
  <section class="id-faq">
    <div class="k-container">
      <span class="k-section-label" style={`color: ${ACCENT}`}>FAQ</span>
      <h2 class="id-faq-title">Frequently Asked Questions</h2>
      <div class="id-faq-list">
        {post.faq && post.faq.length > 0 ? (
          post.faq.map(item => (
            <details class="id-faq-item">
              <summary class="id-faq-q">{item.q}</summary>
              <p class="id-faq-a">{item.a}</p>
            </details>
          ))
        ) : (
          <>
            <details class="id-faq-item">
              <summary class="id-faq-q">When will the full infographic be available?</summary>
              <p class="id-faq-a">We're actively designing visuals for all upcoming infographics. New posts go live weekly — follow @khizooo on Instagram for first access.</p>
            </details>
            <details class="id-faq-item">
              <summary class="id-faq-q">Can I share or download this infographic?</summary>
              <p class="id-faq-a">Yes! Once published, all infographics are shareable. Download and share for free with credit to @khizooo.</p>
            </details>
            <details class="id-faq-item">
              <summary class="id-faq-q">Are there more {section.title.toLowerCase()} infographics?</summary>
              <p class="id-faq-a">Yes, we have {section.posts.length} planned in this category. <a href={url(`/infographics/${section.slug}`)} style={`color: ${ACCENT}`}>Browse all {section.title} infographics →</a></p>
            </details>
          </>
        )}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Share bar + Download logic ────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {

    // Helper: flash button text temporarily
    function flashBtn(btn: HTMLElement, msg: string, durationMs = 2200) {
      const orig = btn.textContent ?? '';
      btn.textContent = msg;
      setTimeout(() => { btn.textContent = orig; }, durationMs);
    }

    // ── Copy link button ─────────────────────────────────────────────
    const copyBtn = document.getElementById('ig-copy-link-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href).then(
          () => flashBtn(copyBtn, 'Copied! ✓'),
          () => flashBtn(copyBtn, 'Failed ✗', 2000),
        );
      });
    }

    // ── Platform share buttons ────────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('[data-action="share"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const tpl = btn.dataset.shareUrl ?? '';
        const url  = encodeURIComponent(window.location.href);
        const title = encodeURIComponent(document.title);
        const finalUrl = tpl.replace('{url}', url).replace('{title}', title);
        window.open(finalUrl, '_blank', 'noopener,width=600,height=480');
      });
    });

    // ── Copy-for-platform buttons (Instagram, TikTok) ─
    document.querySelectorAll<HTMLButtonElement>('[data-action="copy-for"]').forEach(btn => {
      btn.addEventListener('click', () => {
        const platform = btn.dataset.platform ?? 'platform';
        navigator.clipboard.writeText(window.location.href).then(
          () => flashBtn(btn, `Link copied ✓`, 2200),
          () => flashBtn(btn, 'Failed ✗', 2000),
        );
      });
    });

    // ── Download infographic as PNG ───────────────────────────────────
    const dlBtn = document.getElementById('ig-download-btn') as HTMLButtonElement | null;
    if (!dlBtn) return;

    dlBtn.addEventListener('click', async () => {
      const target = document.getElementById('ig-infographic-canvas');
      if (!target) return;

      const original = dlBtn.textContent ?? '⬇ Download';
      dlBtn.textContent = '⏳ Generating…';
      dlBtn.classList.add('loading');
      dlBtn.disabled = true;

      try {
        if (!(window as any).htmlToImage) {
          await new Promise<void>((resolve, reject) => {
            const s = document.createElement('script');
            s.src = 'https://unpkg.com/html-to-image@1.11.11/dist/html-to-image.js';
            s.onload = () => resolve();
            s.onerror = () => reject(new Error('CDN load failed'));
            document.head.appendChild(s);
          });
        }

        const dataUrl = await (window as any).htmlToImage.toPng(target, {
          pixelRatio: 2,
          cacheBust: true,
          style: { margin: '0', borderRadius: '1.5rem' },
        });

        const link = document.createElement('a');
        link.download = 'ai-agents-replacing-repetitive-office-work.png';
        link.href = dataUrl;
        link.click();

        dlBtn.textContent = '✓ Downloaded!';
        setTimeout(() => { dlBtn.textContent = original; }, 2500);
      } catch (err) {
        console.error('Infographic download failed:', err);
        dlBtn.textContent = '✗ Failed — try again';
        setTimeout(() => { dlBtn.textContent = original; }, 3000);
      } finally {
        dlBtn.classList.remove('loading');
        dlBtn.disabled = false;
      }
    });
  });
</script>

<style>
  .id-hero { background: var(--k-bg); padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--k-border); }
  .id-hero-inner { max-width: 720px; }
  .id-hero-meta { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: .875rem; margin-top: 1rem; }
  .id-kind-badge { font-size: .72rem; font-weight: 700; padding: .25rem .75rem; border-radius: 999px; border: 1px solid; font-family: 'Poppins', sans-serif; text-transform: uppercase; letter-spacing: .06em; }
  .id-tag { font-size: .68rem; font-weight: 600; padding: .15rem .5rem; border-radius: 999px; background: var(--k-bg-elevated); border: 1px solid var(--k-border); color: var(--k-text-muted); }
  .id-hero-title { font-family: 'Poppins', sans-serif; font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 900; color: var(--k-text); line-height: 1.2; margin: .5rem 0 .875rem; }
  .id-hero-summary { font-size: 1rem; color: var(--k-text-muted); line-height: 1.7; max-width: 640px; margin: 0 0 1rem; }
  .id-hero-reading { font-size: .8rem; color: var(--k-text-muted); display: flex; gap: .5rem; }

  /* Layout */
  .id-layout { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  @media (min-width: 900px) { .id-layout { grid-template-columns: 1fr 300px; } }

  /* Visual area */
  .id-visual-area {
    margin-bottom: 2rem;
  }
  .id-visual-area:has(.id-coming-soon-visual) {
    background: var(--k-bg-card);
    border: 2px dashed color-mix(in srgb, var(--ic) 40%, transparent);
    border-radius: 1.25rem;
    min-height: 340px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .id-live-infographic { width: 100%; }
  .id-coming-soon-visual { text-align: center; padding: 2rem; }
  .id-cs-ring { width: 90px; height: 90px; border-radius: 50%; border: 3px solid; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
  .id-cs-icon { font-size: 2.5rem; }
  .id-cs-title { font-family: 'Poppins', sans-serif; font-size: 1.25rem; font-weight: 800; color: var(--k-text); margin: 0 0 .5rem; }
  .id-cs-desc { font-size: .875rem; color: var(--k-text-muted); line-height: 1.6; max-width: 400px; margin: 0 auto .875rem; }
  .id-cs-badge { display: inline-flex; padding: .3rem .875rem; border-radius: 999px; background: var(--k-bg-elevated); border: 1px solid var(--k-border); font-size: .75rem; font-weight: 600; color: var(--k-text-muted); }
  .id-image-placeholder { text-align: center; color: var(--k-text-muted); }

  /* Section blocks */
  .id-section-block { margin-bottom: 2rem; }
  .id-section-h2 { display: flex; align-items: center; gap: .75rem; font-family: 'Poppins', sans-serif; font-size: 1.125rem; font-weight: 800; color: var(--k-text); margin: 0 0 1rem; }
  .id-section-num { font-size: .7rem; font-weight: 800; padding: .2rem .5rem; border-radius: .375rem; font-family: 'Poppins', sans-serif; }
  .id-key-points { margin: 0; padding: 0; display: flex; flex-direction: column; gap: .625rem; }
  .id-key-point { display: flex; align-items: flex-start; gap: .75rem; list-style: none; font-size: .9rem; color: var(--k-text); line-height: 1.5; }
  .id-kp-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; margin-top: 6px; }
  .id-body-text { font-size: .9rem; color: var(--k-text-muted); line-height: 1.75; margin: 0 0 .875rem; }
  .id-body-text strong { color: var(--k-text); }

  /* Share bars */
  .id-share-bar {
    display: flex; align-items: flex-start; gap: .625rem;
    padding: .875rem 1rem; background: var(--k-bg-card);
    border: 1px solid var(--k-border); border-radius: .875rem;
    flex-wrap: wrap; margin-bottom: .75rem;
  }
  .id-share-label {
    font-size: .72rem; font-weight: 700; color: var(--k-text-muted);
    font-family: 'Poppins', sans-serif;
    white-space: nowrap; padding-top: .35rem; min-width: 72px;
  }
  .id-share-btns { display: flex; flex-wrap: wrap; gap: .4rem; flex: 1; }

  /* Generic share button / link */
  .id-share-btn {
    padding: .35rem .75rem; border-radius: .5rem;
    border: 1px solid var(--k-border); background: var(--k-bg);
    color: var(--k-text-muted); font-size: .72rem; font-weight: 700;
    cursor: pointer; font-family: 'Poppins', sans-serif;
    transition: border-color .18s, color .18s, background .18s;
    text-decoration: none; display: inline-flex; align-items: center;
  }
  /* Platform-colored hover: uses --pc set per button */
  .id-share-btn:hover {
    border-color: var(--pc, var(--ic));
    color: var(--pc, var(--ic));
    background: color-mix(in srgb, var(--pc, var(--ic)) 8%, transparent);
  }

  /* Download button — always teal */
  .id-download-btn {
    border-color: color-mix(in srgb, #5CCFAF 50%, transparent);
    color: #5CCFAF; --pc: #5CCFAF;
  }
  .id-download-btn.loading { opacity: .6; cursor: wait; }

  /* "Find this on" second bar */
  .id-social-posts-bar { border-style: dashed; }
  .id-social-post-link { font-weight: 700; }
  .id-social-post-link:hover { text-decoration: none; }

  /* Sidebar */
