---
import BaseLayout from '../components/layout/BaseLayout.astro';
import MonsterCard from '../components/ui/MonsterCard.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import { monsters } from '../data/monsters';
import { featuredArtworks } from '../data/artworks';
import { infoCategories } from '../data/infographics';
import { url, img } from '../utils/url';

const featuredFreebieCategories = [
  { slug: 'icons', title: 'Icons', desc: '50+ curated icon libraries' },
  { slug: 'illustrations', title: 'Illustrations', desc: 'Free illustration packs' },
  { slug: 'backgrounds', title: 'Backgrounds', desc: 'Beautiful background assets' },
  { slug: 'typography', title: 'Typography', desc: 'Fonts and type resources' },
];
---

<BaseLayout
  title="khizology — A Monster-Powered Creative Universe"
  description="khizology is a creative knowledge universe by khizooo. Explore Artworks, Infographics, Toolbox calculators, and free design resources — all powered by monsters."
>

  <!-- HERO -->
  <section class="hero-section">
    <div class="k-container hero-inner">
      <div class="hero-content">
        <span class="hero-eyebrow">
          <span class="eyebrow-dot"></span>
          A Creative Knowledge Universe
        </span>
        <h1 class="hero-title">
          Where <span class="k-gradient-text">Art</span> meets
          <span class="k-gradient-text">Code</span>
        </h1>
        <p class="hero-subtitle">
          By luck, a programmer. By nature, an artist.<br />
          Welcome to <strong>khizology.</strong><br /><br />
          A monster-powered universe of Artworks, Infographics, free Tools, and curated Resources.
        </p>
        <div class="hero-ctas">
          <a href="#monsters" class="btn-primary">Explore Monsters</a>
          <a href={url('/toolbox')} class="btn-secondary">Try Toolbox</a>
          <a href={url('/artworks')} class="btn-ghost">View Artworks</a>
        </div>
        <div class="hero-stats">
          <div class="stat"><strong>168+</strong><span>Artworks</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><strong>16</strong><span>Info Sections</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><strong>50+</strong><span>Free Tools</span></div>
          <div class="stat-divider"></div>
          <div class="stat"><strong>13</strong><span>Freebie Sets</span></div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-monster-cluster">
          <div class="hm-card hm-main">
            <img src={img('/images/Monsters/artooo.png')} alt="artooo" width="72" height="72" />
            <span>artooo</span>
          </div>
          <div class="hm-card hm-secondary hm-top">
            <img src={img('/images/Monsters/infooo.png')} alt="infooo" width="48" height="48" />
            <span>infooo</span>
          </div>
          <div class="hm-card hm-secondary hm-right">
            <img src={img('/images/Monsters/toolooo.png')} alt="toolooo" width="48" height="48" />
            <span>toolooo</span>
          </div>
          <div class="hm-card hm-secondary hm-bottom">
            <img src={img('/images/Monsters/freeooo.png')} alt="freeooo" width="48" height="48" />
            <span>freeooo</span>
          </div>
        </div>
        <div class="hero-glow hero-glow-1"></div>
        <div class="hero-glow hero-glow-2"></div>
      </div>
    </div>
    <div class="scroll-indicator" aria-hidden="true">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- MONSTER UNIVERSE -->
  <section class="k-section monsters-section" id="monsters">
    <div class="k-container">
      <SectionHeader
        label="The Universe"
        title="Meet the Monsters"
        description="Each monster is a creative module. A world of its own. 4 are live. 5 are being unleashed."
        accentColor="var(--k-accent)"
        align="center"
      />
      <div class="monsters-grid">
        {monsters.map(m => <MonsterCard monster={m} />)}
      </div>
    </div>
  </section>

  <!-- FEATURED ARTWORKS -->
  <section class="k-section artworks-section">
    <div class="k-container">
      <SectionHeader
        label="artooo — Artworks"
        title="Visual Playground"
        description="A collection of 168+ original artworks — sketches, illustrations, emotions, and stories told through lines."
        accentColor="#F5CF5C"
        cta={{ label: 'View all Artworks', href: url('/artworks') }}
      />
      <div class="artworks-masonry">
        {featuredArtworks.slice(0, 8).map((art) => (
          <a href={url('/artworks')} class="artwork-thumb" aria-label={art.title}>
            <img
              src={img('/images/artworks/' + art.filename)}
              alt={art.title}
              loading="lazy"
              width="300"
              height="300"
            />
            <div class="artwork-hover">
              <span>{art.title}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TOOLBOX -->
  <section class="k-section toolbox-section">
    <div class="k-container">
      <SectionHeader
        label="toolooo — Toolbox"
        title="Tools That Work"
        description="Free online calculators and tools designed to solve real problems. The productivity engine of khizology."
        accentColor="#F7933C"
        cta={{ label: 'Open Toolbox', href: url('/toolbox') }}
      />
      <div class="toolbox-two-cats">
        <a href={url('/toolbox/calculators/finance-calculator')} class="tb-cat-card">
          <div class="tb-cat-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><line x1="8" y1="6" x2="16" y2="6"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="12" y2="14"/></svg>
          </div>
          <div class="tb-cat-body">
            <h3>Calculators</h3>
            <p>50+ calculators for finance, health, math &amp; more</p>
          </div>
          <span class="tb-cat-arrow">→</span>
        </a>
        <a href={url('/toolbox/tools')} class="tb-cat-card">
          <div class="tb-cat-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <div class="tb-cat-body">
            <h3>Tools</h3>
            <p>Free social media, SEO and content tools</p>
          </div>
          <span class="tb-cat-arrow">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- INFOGRAPHICS -->
  <section class="k-section infographics-section">
    <div class="k-container">
      <SectionHeader
        label="infooo — Infographics"
        title="Knowledge, Visualized"
        description="Complex ideas made simple through beautiful visual infographics. 16 knowledge sections and growing."
        accentColor="#5CCFAF"
        cta={{ label: 'Explore Infographics', href: url('/infographics') }}
      />
      <div class="info-categories-grid">
        {infoCategories.slice(0, 4).map(cat => (
          <a href={url('/infographics/' + cat.slug)} class="info-cat-card" style={`--cat-color: ${cat.color}`}>
            <span class="info-cat-icon">{cat.icon}</span>
            <div class="info-cat-body">
              <h3>{cat.title}</h3>
              <p>{cat.description}</p>
            </div>
            <span class="info-cat-arrow">→</span>
          </a>
        ))}
      </div>
      <div class="info-more-categories">
        {infoCategories.slice(4).map(cat => (
          <a href={url('/infographics/' + cat.slug)} class="info-more-chip" style={`--cat-color: ${cat.color}`}>
            {cat.title}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FREEBIES -->
  <section class="k-section freebies-section">
    <div class="k-container">
      <SectionHeader
        label="freeooo — Freebies"
        title="Free. Always."
        description="A curated library of free design resources, tools, icons, illustrations, and assets for creators and developers."
        accentColor="#6CA6FF"
        cta={{ label: 'Browse Freebies', href: url('/freebies') }}
      />
      <div class="freebies-preview">
        {featuredFreebieCategories.map(cat => (
          <a href={url('/freebies/' + cat.slug)} class="freebie-cat-card">
            <div class="freebie-icon-box">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            </div>
            <span class="freebie-title">{cat.title}</span>
            <span class="freebie-desc">{cat.desc}</span>
          </a>
        ))}
      </div>
      <div class="freebies-cta-banner">
        <div class="fcb-text">
          <strong>13 categories. Hundreds of resources.</strong>
          <span>Icons, illustrations, backgrounds, fonts, components — all free.</span>
        </div>
        <a href={url('/freebies')} class="btn-primary">Get Free Resources →</a>
      </div>
    </div>
  </section>

  <!-- BEHIND THE VIBES TEASER -->
  <section class="k-section btv-section">
    <div class="k-container">
      <div class="btv-inner">
        <div class="btv-content">
          <span class="k-section-label" style="color: var(--k-accent)">Behind the Vibes</span>
          <h2>By luck, a programmer.<br />By nature, an artist.</h2>
          <p>
            khizology isn't just a website — it's a living record of ideas, experiments,
            and creative exploration. Behind every monster is a story. Behind every artwork
            is an emotion. Behind every tool is a problem waiting to be solved.
          </p>
          <div class="btv-ctas">
            <a href={url('/behind-the-vibes')} class="btn-primary">Read the Story →</a>
            <a href={url('/my-portfolio')} class="btn-ghost">View Portfolio</a>
          </div>
        </div>
        <div class="btv-visual">
          <img src={img('/images/site/creative-01.png')} alt="khizooo creative" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- FOLLOW / REVISIT CTA -->
  <section class="k-section follow-section">
    <div class="k-container">
      <div class="follow-inner">
        <div class="follow-monsters">
          {monsters.map(m => (
            <img src={img(m.image)} alt={m.name} width="40" height="40" class="follow-monster-img" />
          ))}
        </div>
        <h2>Stay in the universe.</h2>
        <p>New artworks, infographics, tools, and freebies drop regularly. Don't miss it.</p>
        <div class="follow-ctas">
          <a href={url('/drop-a-vibe')} class="btn-primary-inv">Drop a Vibe</a>
          <a href={url('/you-ask-i-answer')} class="btn-outline-inv">You Ask, I Answer</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .hero-section {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding: 6rem 0 4rem;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Poppins', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--k-text-muted);
    margin-bottom: 1rem;
  }
  .eyebrow-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--k-accent);
    flex-shrink: 0;
    animation: blink 2s infinite;
  }
  @keyframes blink {
    0%,100% { opacity: 1; } 50% { opacity: 0.4; }
  }
  .hero-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--k-text);
    margin: 0 0 1.25rem;
  }
  .hero-subtitle {
    font-size: 1.05rem;
    color: var(--k-text-muted);
    line-height: 1.7;
    margin: 0 0 2rem;
    max-width: 480px;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 2.5rem;
  }
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .stat { display: flex; flex-direction: column; gap: 0.1rem; }
  .stat strong {
    font-family: 'Poppins', sans-serif;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--k-text);
  }
  .stat span {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--k-text-muted);
  }
  .stat-divider { width: 1px; height: 2rem; background: var(--k-border); }

  /* Hero visual */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 380px;
  }
  .hero-monster-cluster {
    position: relative;
    width: 260px;
    height: 260px;
  }
  .hm-card {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    background: var(--k-bg-card);
    border: 2px solid var(--k-border);
    border-radius: 1rem;
    padding: 0.75rem;
    font-family: 'Poppins', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--k-text-muted);
    box-shadow: 0 8px 24px var(--k-shadow);
  }
  .hm-main {
    width: 120px; height: 120px;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    border-color: #F5CF5C;
    z-index: 2;
    animation: floatMain 5s ease-in-out infinite;
  }
  .hm-secondary { width: 80px; height: 80px; }
  .hm-top { top: 0; left: 50%; transform: translateX(-50%); animation: floatY 5.5s ease-in-out infinite 0.5s; border-color: #5CCFAF; }
  .hm-right { top: 50%; right: 0; transform: translateY(-50%); animation: floatX 6s ease-in-out infinite 1s; border-color: #F7933C;}
  .hm-bottom { bottom: 0; left: 50%; transform: translateX(-50%); animation: floatYR 4.5s ease-in-out infinite 1.5s; border-color: #6CA6FF;}
  @keyframes floatMain { 0%,100%{transform:translate(-50%,-50%)} 50%{transform:translate(-50%,calc(-50% - 8px))} }
  @keyframes floatY { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(-6px)} }
  @keyframes floatX { 0%,100%{transform:translateY(-50%) translateX(0)} 50%{transform:translateY(-50%) translateX(6px)} }
  @keyframes floatYR { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }
  .hero-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
  }
  .hero-glow-1 { width:200px;height:200px;background:#F5CF5C;opacity:0.1;top:20%;left:20%; }
  .hero-glow-2 { width:150px;height:150px;background:#5CCFAF;opacity:0.08;bottom:10%;right:10%; }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--k-text-muted);
  }
  .scroll-line {
    width: 1px; height: 2.5rem;
    background: linear-gradient(to bottom, var(--k-text-muted), transparent);
    animation: scrollPulse 2s infinite;
  }
  @keyframes scrollPulse { 0%,100%{opacity:0.3} 50%{opacity:1} }

  /* BUTTONS */
  .btn-primary {
    display: inline-flex; align-items: center;
    padding: 0.65rem 1.5rem;
    background: var(--k-dark); color: var(--k-bg);
    border-radius: 0.625rem;
    font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 0.875rem;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
    border: none;
  }
  .btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }

  .btn-secondary {
    display: inline-flex; align-items: center;
    padding: 0.65rem 1.5rem;
    background: transparent; color: var(--k-text);
    border: 2px solid var(--k-dark);
    border-radius: 0.625rem;
    font-family: 'Poppins', sans-serif; font-weight: 700; font-size: 0.875rem;
    text-decoration: none;
    transition: background 0.2s, color 0.2s, transform 0.2s;
    white-space: nowrap;
  }
  .btn-secondary:hover { background: var(--k-dark); color: var(--k-bg); transform: translateY(-2px); }

  .btn-ghost {
    display: inline-flex; align-items: center;
    padding: 0.65rem 1.5rem;
    background: transparent; color: var(--k-text-muted);
    border: 1px solid var(--k-border);
    border-radius: 0.625rem;
    font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.875rem;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
    white-space: nowrap;
  }
  .btn-ghost:hover { border-color: var(--k-text); color: var(--k-text); }

  /* MONSTERS GRID */
  .monsters-section { background: var(--k-bg-card); }
  .monsters-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  /* ARTWORKS */
  .artworks-masonry {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.5rem;
  }
  .artwork-thumb {
    position: relative;
    border-radius: 0.75rem;
    overflow: hidden;
    aspect-ratio: 1;
    background: var(--k-border);
    display: block;
  }
  .artwork-thumb img { width:100%; height:100%; object-fit:cover; transition: transform 0.4s; }
  .artwork-thumb:hover img { transform: scale(1.07); }
  .artwork-hover {
    position: absolute; inset: 0;
    background: rgba(42,52,57,0.75);
    display: flex; align-items: flex-end; padding: 0.75rem;
    opacity: 0; transition: opacity 0.2s;
  }
  .artwork-hover span { color:#fff; font-size:0.75rem; font-weight:600; }
  .artwork-thumb:hover .artwork-hover { opacity: 1; }

  /* TOOLBOX - 2 categories */
  .toolbox-section { background: var(--k-bg); }
  .toolbox-two-cats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }
  .tb-cat-card {
    display: flex; align-items: center; gap: 1.25rem;
    padding: 1.5rem 1.75rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border); border-radius: 1rem;
    text-decoration: none; color: inherit;
    transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
  }
  .tb-cat-card:hover {
    border-color: #F7933C; transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(247,147,60,0.1);
  }
  .tb-cat-icon {
    width: 3rem; height: 3rem; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    background: rgba(247,147,60,0.1); border-radius: 0.75rem;
    color: #F7933C;
  }
  .tb-cat-body { flex: 1; }
  .tb-cat-body h3 { font-family: 'Poppins', sans-serif; font-size: 1rem; font-weight: 700; color: var(--k-text); margin: 0 0 0.25rem; }
  .tb-cat-body p { font-size: 0.8rem; color: var(--k-text-muted); margin: 0; }
  .tb-cat-arrow { color: var(--k-text-muted); font-size: 1.2rem; transition: transform 0.2s; }
  .tb-cat-card:hover .tb-cat-arrow { transform: translateX(4px); color: #F7933C; }

  /* INFOGRAPHICS */
  .infographics-section { background: var(--k-bg-card); }
  .info-categories-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin-bottom: 1rem; }
  .info-cat-card {
    display: flex; align-items: center; gap: 1rem;
    padding: 1.25rem;
    background: var(--k-bg-elevated, var(--k-bg)); border: 1px solid var(--k-border);
    border-left: 4px solid var(--cat-color, var(--k-border));
    border-radius: 0 0.875rem 0.875rem 0;
    text-decoration: none; color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .info-cat-card:hover { transform: translateX(4px); box-shadow: 0 4px 16px var(--k-shadow); }
  .info-cat-icon { font-size: 2rem; flex-shrink: 0; }
  .info-cat-body { flex: 1; }
  .info-cat-body h3 { font-family: 'Poppins', sans-serif; font-size: 0.9rem; font-weight: 700; color: var(--k-text); margin: 0 0 0.25rem; }
  .info-cat-body p { font-size: 0.8rem; color: var(--k-text-muted); margin: 0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
  .info-cat-arrow { color: var(--k-text-muted); transition: transform 0.2s, color 0.2s; }
  .info-cat-card:hover .info-cat-arrow { transform: translateX(4px); color: var(--cat-color); }
  .info-more-categories { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.5rem; }
  .info-more-chip {
    display: inline-flex; align-items: center; gap: 0.25rem;
    padding: 0.375rem 0.875rem;
    background: var(--k-bg); border: 1px solid var(--cat-color, var(--k-border));
    border-radius: 999px;
    font-size: 0.8rem; font-weight: 600; color: var(--k-text); text-decoration: none;
    transition: background 0.2s, color 0.2s;
  }
  .info-more-chip:hover { background: var(--cat-color); color: var(--k-dark); }

  /* FREEBIES */
  .freebies-section { background: var(--k-bg); }
  .freebies-preview {
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 1.5rem;
  }
  .freebie-cat-card {
    display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.5rem;
    padding: 1.5rem 1rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border); border-radius: 1rem;
    text-decoration: none; color: inherit;
    transition: transform 0.2s, border-color 0.2s;
  }
