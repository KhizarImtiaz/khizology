---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { url, img } from '../utils/url';

const stats = [
  { num: '8+', label: 'Years Experience' },
  { num: '20+', label: 'Projects Delivered' },
  { num: '168+', label: 'Original Artworks' },
  { num: '50+', label: 'Free Online Tools' },
];

const strengths = [
  'Full-Stack Development',
  'Technical Team Leadership',
  'Client & Stakeholder Management',
  'Blockchain & Web3',
  'AI / ML Integration',
  'Agile / Scrum Delivery',
  'System Architecture',
  'Creative Design',
  'Visual Communication',
  'Product Strategy',
];

const skillGroups = [
  {
    category: 'Programming & Frameworks',
    sub: [
      { label: 'Frontend Development', items: ['HTML5', 'CSS3', 'JavaScript', 'Bootstrap', 'TypeScript', 'React.js', 'Angular', 'Responsive & Mobile-First Design', 'UI/UX Design', 'Wireframing'] },
      { label: 'Backend Development', items: ['C#', '.NET Core', 'Blazor', 'React', 'Node.js'] },
      { label: 'Web API', items: ['RESTful APIs', 'SOAP APIs', 'GraphQL APIs', 'gRPC APIs', 'WebSockets', 'RPC API'] },
      { label: 'Authentication', items: ['Basic', 'Token-Based', 'OAuth 2.0', 'OpenID Connect', 'Multi-Factor Authentication', 'SAML'] },
      { label: 'Authorization', items: ['Role-Based Access Control', 'Attribute-Based Access Control', 'Permissions-Based Access Control', 'Discretionary Access Control', 'Mandatory Access Control'] },
    ],
  },
  {
    category: 'Blockchain & Web3 Development',
    sub: [
      { label: 'Applications', items: ['Exchange', 'Chain'] },
      { label: 'Smart Contract Development', items: ['Solidity', 'Rust'] },
      { label: 'Blockchain Frameworks & Tools', items: ['Web3.js', 'Ethers.js', 'Infura', 'Alchemy', 'DApps'] },
      { label: 'Consensus Mechanisms', items: ['PoW', 'PoS', 'DPoS', 'PoA', 'PoB', 'PoC', 'Hybrid (PoW + PoS)'] },
      { label: 'NFT Marketplaces', items: ['Buying/Selling NFTs', 'OnChain/OffChain Concept'] },
    ],
  },
  {
    category: 'Databases & Optimization',
    sub: [
      { label: 'SQL Database', items: ['MySQL', 'PostgreSQL', 'Microsoft SQL Server', 'Oracle DB'] },
      { label: 'NoSQL Database', items: ['MongoDB', 'Cassandra', 'DynamoDB', 'Redis', 'CouchDB'] },
      { label: 'Hybrid Database', items: ['FaunaDB', 'CosmosDB'] },
      { label: 'NewSQL Database', items: ['Google Spanner', 'CockroachDB'] },
      { label: 'In-Memory Database', items: ['RedisDB'] },
      { label: 'Distributed Database', items: ['CockroachDB', 'Google Spanner'] },
      { label: 'Graph Database', items: ['Neo4j', 'TigerGraph'] },
      { label: 'Time-Series Database', items: ['InfluxDB', 'TimescaleDB'] },
      { label: 'Multi-Tenant Database', items: ['PostgreSQL', 'AWS RDS'] },
      { label: 'Optimizations', items: ['Indexing', 'Query', 'Normalization/Denormalization', 'Partitioning/Sharding', 'Connection Pooling/Caching', 'Concurrency Control/Locking', 'R/W', 'Storage/Compression', 'Backup/Recovery', 'Monitoring/Performance'] },
    ],
  },
  {
    category: 'Cloud & DevOps',
    sub: [
      { label: 'Cloud Platforms', items: ['Microsoft Azure', 'AWS', 'Google Cloud Platform (GCP)', 'DigitalOcean'] },
      { label: 'Serverless Computing', items: ['AWS Lambda', 'Azure Functions', 'Firebase Cloud Functions'] },
      { label: 'CI/CD Pipelines', items: ['GitHub Actions', 'GitLab CI/CD', 'Azure DevOps'] },
      { label: 'Containerization & Orchestration', items: ['Docker', 'Kubernetes'] },
      { label: 'Monitoring & Logging', items: ['Grafana', 'Kibana'] },
    ],
  },
  {
    category: 'Security & Compliance',
    sub: [
      { label: 'Web Security Standards', items: ['OWASP Top 10', 'Secure Coding Practices'] },
    ],
  },
  {
    category: 'Artificial Intelligence',
    sub: [
      { label: 'AI Frameworks', items: ['OpenAI API', 'Claude'] },
      { label: 'AI-powered Development', items: ['GitHub Copilot', 'Claude Code'] },
    ],
  },
  {
    category: 'Architecture Frameworks',
    sub: [
      { label: 'Frameworks', items: ['Clean', 'Open Group Architecture', 'Microservices', 'MVC/MVVM', 'Event-Driven', 'Layered', 'Serverless'] },
    ],
  },
  {
    category: 'Version Control & Project Management',
    sub: [
      { label: 'Version Control Systems', items: ['Git', 'GitHub', 'GitLab', 'Bitbucket', 'TFS'] },
      { label: 'Agile Methodologies', items: ['Scrum', 'Kanban', 'Jira', 'Trello', 'ClickUp'] },
      { label: 'Collaboration Tools', items: ['Slack', 'Discord', 'Telegram', 'Microsoft Teams'] },
    ],
  },
  {
    category: 'Containerization & Virtualization',
    sub: [
      { label: 'Containerization', items: ['Docker', 'Podman'] },
      { label: 'Orchestration', items: ['Rancher'] },
      { label: 'Virtualization Platforms', items: ['VirtualBox'] },
    ],
  },
  {
    category: 'Additional Tech Skills',
    sub: [
      { label: 'Message Brokers', items: ['Apache Kafka', 'Redis Pub/Sub'] },
      { label: 'Search Engines & Indexing', items: ['Elasticsearch'] },
      { label: 'BI & Analytics', items: ['Power BI'] },
      { label: 'Game Development', items: ['Unity 3D'] },
    ],
  },
];

const experience = [
  {
    role: 'Technical Delivery Manager',
    company: 'VAIVAL Technologies',
    period: 'Jun 2022 — Present',
    current: true,
    bullets: [
      'Leading delivery of enterprise-grade web and mobile products end-to-end',
      'Managing cross-functional teams of 15+ engineers and designers',
      'Client success, sprint planning, and stakeholder communication',
      'Driving AI/ML and blockchain integration across projects',
      'Ensuring on-time delivery with zero-compromise quality standards',
    ],
  },
  {
    role: 'Technical Team Lead',
    company: 'VAIVAL Technologies',
    period: 'Jan 2020 — Jun 2022',
    current: false,
    bullets: [
      'Led frontend and full-stack development teams across multiple projects',
      'Architected React-based SPAs and Node.js backends',
      'Mentored junior developers and enforced coding standards',
      'Delivered 20+ production projects across diverse industries',
    ],
  },
  {
    role: 'Web Developer',
    company: 'VAIVAL Technologies',
    period: 'Mar 2017 — Jan 2020',
    current: false,
    bullets: [
      'Built full-stack web applications from scratch for various clients',
      'Specialised in React, JavaScript, and modern CSS',
      'Collaborated with design and product teams on 15+ projects',
    ],
  },
  {
    role: 'Co-founder / Technical Lead',
    company: 'Evento.pk (Startup)',
    period: 'Side Project',
    current: false,
    bullets: [
      'Co-founded an events discovery and ticketing platform',
      'Built the entire product from scratch — frontend and backend',
      'Hands-on experience with startup culture and product iteration',
    ],
  },
];

const projectGroups = [
  {
    group: 'Blockchain & Crypto Exchange Solutions',
    projects: [
      { name: 'BlackCard', period: '2020 – 2021', desc: 'Cryptocurrency exchange platform with trading and wallet features.', tags: ['Blockchain', 'Exchange', 'Wallet'] },
      { name: 'Moonix', period: '2019 – 2021', desc: 'Multi-asset crypto exchange supporting staking and liquidity pools.', tags: ['Crypto', 'Staking', 'Liquidity'] },
      { name: 'BitFast', period: '2020 – 2021', desc: 'High-performance trading engine for fast crypto transactions.', tags: ['Trading Engine', 'Performance', 'Crypto'] },
      { name: 'GoStake', period: '2019 – 2020', desc: 'Staking platform enabling rewards across multiple blockchain networks.', tags: ['Staking', 'Blockchain', 'DeFi'] },
      { name: 'VulcanX', period: 'Continue', desc: 'Exchange infrastructure supporting token trading and liquidity management.', tags: ['Exchange', 'Token Trading', 'Liquidity'] },
    ],
  },
  {
    group: 'Blockchain & NFT Platforms',
    projects: [
      { name: 'Vulcan Forged', period: '2019 – Present', desc: 'Blockchain gaming ecosystem with NFTs, marketplace, token utilities.', tags: ['Blockchain', 'NFT', 'Gaming', 'Marketplace'] },
      { name: 'Private Jet Pyjama Party', period: '2019 – 2021', desc: 'NFT-based membership platform with exclusive digital collectibles.', tags: ['NFT', 'Membership', 'Web3'] },
      { name: 'Vulcan Marketplace & Games Integrations', period: '2020 – Present', desc: 'NFT marketplace integrated across multiple blockchain-based games.', tags: ['NFT', 'Marketplace', 'Gaming'] },
      { name: 'Elysium Marketplace | Agora', period: '2022 – Present', desc: 'Decentralized marketplace supporting NFT trading and digital assets.', tags: ['Decentralized', 'NFT', 'dApp'] },
      { name: 'Boost Lottery', period: '2024 – 2025', desc: 'Blockchain-based lottery system ensuring fairness and transparency.', tags: ['Blockchain', 'Smart Contracts', 'Lottery'] },
      { name: 'BTC Lending (BTC Loan System)', period: 'Continue', desc: 'Bitcoin-backed lending platform with secure collateral management.', tags: ['Bitcoin', 'Lending', 'DeFi'] },
      { name: 'OPN Wallet', period: '2025', desc: 'Crypto wallet supporting assets, transactions, and browser extension usage.', tags: ['Wallet', 'Extension', 'Crypto'] },
    ],
  },
  {
    group: 'E-commerce & Shopify',
    projects: [
      { name: 'Amazon & Shopify Scraper', period: '2017 – 2018', desc: 'Product scraping tool for automated catalog data extraction.', tags: ['Scraping', 'E-commerce', 'Automation'] },
      { name: 'FBMessenger Shopify APP', period: '2019', desc: 'Messenger automation app for Shopify customer engagement.', tags: ['Shopify', 'Messenger', 'Automation'] },
      { name: 'Page Berry', period: '2018', desc: 'Landing page builder for Shopify stores conversion optimization.', tags: ['Shopify', 'Landing Pages', 'CRO'] },
      { name: 'BlackBird Shopify APP & Browser Extension', period: '2017 – 2018', desc: 'Shopify automation extension for product research and analysis.', tags: ['Shopify', 'Extension', 'Research'] },
      { name: 'Intelly Plan', period: '2025 – Present', desc: 'Business planning tool for forecasting and operational workflows.', tags: ['SaaS', 'Planning', 'Analytics'] },
    ],
  },
  {
    group: 'Fintech & Payment Solutions',
    projects: [
      { name: 'MPGE | Mobile Payment Gateway Eugene', period: '2021', desc: 'Mobile payment gateway supporting secure digital transactions.', tags: ['Fintech', 'Payments', 'Mobile'] },
    ],
  },
  {
    group: 'Business & Data Analytics',
    projects: [
      { name: 'Restaurant Analytics Hub', period: '2019 – 2021', desc: 'Analytics dashboard providing insights into restaurant performance metrics.', tags: ['Analytics', 'Dashboard', 'Restaurants'] },
      { name: 'Landing Page Launchpad', period: '2017', desc: 'Tool for quickly building and deploying marketing landing pages.', tags: ['Marketing', 'Landing Pages', 'Automation'] },
      { name: 'IntellyPlan', period: 'Continue', desc: 'Strategic planning platform with forecasting and operational insights.', tags: ['SaaS', 'Forecasting', 'Strategy'] },
      { name: 'IntellyStore', period: 'Continue', desc: 'Retail management system with inventory and analytics features.', tags: ['Retail', 'Inventory', 'Analytics'] },
      { name: 'IntellySight', period: 'Continue', desc: 'Business intelligence dashboards for data-driven decision making.', tags: ['BI', 'Dashboards', 'Data'] },
    ],
  },
  {
    group: 'Healthcare & Queue',
    projects: [
      { name: 'MyHealthCare Center', period: '2017', desc: 'Clinic management system with appointments and patient tracking.', tags: ['Healthcare', 'Clinic', 'Appointments'] },
      { name: 'MyScan', period: '2025', desc: 'Document scanning system with secure cloud organization.', tags: ['Scanning', 'Cloud', 'Documents'] },
      { name: 'PryvateNow', period: 'Continue', desc: 'Healthcare ecosystem connecting patients, nurses, doctors, and coordinators.', tags: ['Healthcare', 'Platform', 'Telemedicine'] },
    ],
  },
  {
    group: 'Enterprise Solutions',
    projects: [
      { name: 'FOS – Maple Leaf', period: '2016 – 2017', desc: 'Field operations system for enterprise workforce management.', tags: ['Enterprise', 'Workforce', 'Operations'] },
      { name: 'Vulcan Forged Gaming', period: '2019 – Present', desc: 'Blockchain gaming infrastructure supporting NFTs and token economies.', tags: ['Blockchain', 'Gaming', 'NFT'] },
      { name: 'ClaimToolkit', period: 'Continue', desc: 'Claims management platform automating processing and reducing errors.', tags: ['Enterprise', 'Claims', 'Automation'] },
    ],
  },
  {
    group: 'Personal & Open-Source',
    projects: [
      { name: 'khizology', period: '2024 – Present', desc: 'A monster-powered creative knowledge universe. Artworks, Infographics, Toolbox, and Freebies — all in one creative brand built with Astro, TypeScript, and React.', tags: ['Astro', 'TypeScript', 'React', 'Personal Brand'], link: url('/') },
    ],
  },
];

const softSkills = ['Leadership', 'Communication', 'Problem-Solving', 'Creativity', 'Empathy', 'Attention to Detail', 'Adaptability', 'Continuous Learning', 'Mentoring'];
const hobbies = ['Drawing & Illustration', 'Digital Art', 'Travel', 'Photography', 'Reading', 'Exploring New Tech', 'Playing with AI Tools'];
---

<BaseLayout
  title="My Portfolio — Khizar Imtiaz"
  description="Khizar Imtiaz (khizooo) — Technical Delivery Manager, full-stack developer, and artist. 8+ years at VAIVAL. Creator of khizology."
  accentColor="var(--k-accent)"
>
  <div class="k-container" style="padding-top: 2rem;">
    <Breadcrumb crumbs={[{ label: 'My Portfolio' }]} accentColor="var(--k-accent)" />
  </div>

  <!-- HERO -->
  <section class="pf-hero k-section">
    <div class="k-container">
      <div class="pf-hero-inner">
        <div class="pf-hero-content">
          <span class="k-section-label" style="color: var(--k-accent)">My Portfolio</span>
          <h1 class="pf-title">Khizar Imtiaz</h1>
          <p class="pf-role">Technical Delivery Manager &amp; Creative Developer</p>
          <div class="pf-bio">
            <p>
              8+ years at VAIVAL Technologies — leading teams, shipping products, and solving complex problems at scale. Expert in full-stack development, blockchain/Web3, and AI integration.
            </p>
            <p>
              By luck, a programmer. By nature, an artist. I believe the best digital experiences live at the intersection of technical excellence and creative vision. <strong>khizology</strong> is proof of that.
            </p>
          </div>
          <div class="pf-hero-ctas">
            <a href={url('/drop-a-vibe')} class="pf-btn-primary">Get in Touch →</a>
            <a href="https://www.linkedin.com/in/khizar-imtiaz" target="_blank" rel="noopener" class="pf-btn-ghost">LinkedIn</a>
            <a href="https://github.com/KhizaroOo" target="_blank" rel="noopener" class="pf-btn-ghost">GitHub</a>
          </div>
        </div>
        <div class="pf-hero-visual">
          <div class="pf-img-wrap">
            <img src={img('/images/site/lp-profile-img.png')} alt="Khizar Imtiaz" loading="eager" />
            <div class="pf-img-badge">Technical Delivery Manager</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <div class="pf-stats-strip">
    <div class="k-container">
      <div class="pf-stats-grid">
        {stats.map(s => (
          <div class="pf-stat">
            <span class="pf-stat-num">{s.num}</span>
            <span class="pf-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- PROFESSIONAL SUMMARY -->
  <section class="k-section pf-summary-section">
    <div class="k-container">
      <div class="pf-summary-card">
        <div class="pf-summary-label">Professional Summary</div>
        <p class="pf-summary-text">
          Technical Delivery Manager with 8+ years at VAIVAL Technologies. Expert in full-stack development, technical team leadership, client management, blockchain/Web3, AI/ML integration, and creative design. I bridge the gap between technical complexity and business objectives — ensuring products are not just built, but built right. Outside of engineering, I am an artist and the creator of khizology — a monster-powered creative universe.
        </p>
      </div>
    </div>
  </section>

  <!-- CAREER OBJECTIVES -->
  <section class="k-section pf-objective-section">
    <div class="k-container">
      <h2 class="pf-section-title">Career Objectives</h2>
      <div class="pf-objective-card">
        <p class="pf-objective-text">
          To leverage my experience in architecture, leadership, and modern technologies to build scalable digital products and drive technical innovation. I aim to contribute to organizations by delivering high-impact solutions, improving engineering processes, and leading teams to create reliable and future-ready systems.
        </p>
      </div>
    </div>
  </section>

  <!-- CORE STRENGTHS -->
  <section class="k-section pf-strengths-section">
    <div class="k-container">
      <h2 class="pf-section-title">Core Strengths</h2>
      <div class="strengths-grid">
        {strengths.map(s => (
          <div class="strength-chip">{s}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECHNICAL SKILLS -->
  <section class="k-section pf-skills-section">
    <div class="k-container">
      <h2 class="pf-section-title">Technical Skills</h2>
      <div class="skills-groups">
        {skillGroups.map(group => (
          <div class="skill-group-block">
            <h3 class="skill-group-heading">{group.category}</h3>
            <div class="skill-sub-list">
              {group.sub.map(sub => (
                <div class="skill-sub">
                  <span class="skill-sub-label">{sub.label}</span>
                  <div class="skill-tags">
                    {sub.items.map(skill => (
                      <span class="skill-tag">{skill}</span>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section class="k-section pf-exp-section">
    <div class="k-container">
      <h2 class="pf-section-title">Experience</h2>
      <div class="exp-timeline">
        {experience.map((job, i) => (
          <div class="exp-item">
            <div class="exp-connector">
              <div class={`exp-dot ${job.current ? 'exp-dot-current' : ''}`}></div>
              {i < experience.length - 1 && <div class="exp-line"></div>}
            </div>
            <div class="exp-content">
              <div class="exp-header">
                <div class="exp-title-group">
                  <h3 class="exp-role">{job.role}</h3>
                  <span class="exp-company">{job.company}</span>
                </div>
                <div class="exp-meta">
                  <span class="exp-period">{job.period}</span>
                  {job.current && <span class="exp-current-badge">Current</span>}
                </div>
              </div>
              <ul class="exp-bullets">
                {job.bullets.map(b => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="k-section pf-projects-section">
    <div class="k-container">
      <h2 class="pf-section-title">Projects &amp; Contributions</h2>
      <div class="project-groups">
        {projectGroups.map(pg => (
          <div class="project-group">
            <h3 class="project-group-heading">{pg.group}</h3>
            <div class="projects-grid">
              {pg.projects.map(p => (
                <div class="project-card">
                  <div class="project-card-inner">
                    <div class="pc-header">
                      <h4 class="pc-name">{p.name}</h4>
                      <span class="pc-period">{p.period}</span>
                    </div>
                    <p class="pc-desc">{p.desc}</p>
                    <div class="pc-tags">
                      {p.tags.map(tag => <span class="pc-tag">{tag}</span>)}
                    </div>
                  </div>
                  {'link' in p && p.link && (
                    <a href={p.link} class="pc-link">View →</a>
                  )}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOFT SKILLS + HOBBIES -->
  <section class="k-section pf-extras-section">
    <div class="k-container pf-extras-inner">
      <div class="pf-extra-block">
        <h2 class="pf-section-title">Soft Skills</h2>
        <div class="extras-chips">
          {softSkills.map(s => <span class="extra-chip">{s}</span>)}
        </div>
      </div>
      <div class="pf-extra-block">
        <h2 class="pf-section-title">Hobbies &amp; Interests</h2>
        <div class="extras-chips">
          {hobbies.map(h => <span class="extra-chip">{h}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="k-section pf-cta-section">
    <div class="k-container">
      <div class="pf-cta-inner">
        <img src={img('/images/Monsters/khizooo.png')} alt="" width="96" height="96" class="pf-cta-monster" />
        <h2>Want to work together or just say hi?</h2>
        <p>Open to creative collaborations, tech discussions, and good conversations about art and code.</p>
        <div class="pf-cta-btns">
          <a href={url('/drop-a-vibe')} class="pf-btn-primary">Drop a Vibe →</a>
          <a href={url('/behind-the-vibes')} class="pf-btn-ghost">Behind the Vibes</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .pf-hero { background: var(--k-bg-card); border-bottom: 1px solid var(--k-border); }
  .pf-hero-inner {
    display: grid; grid-template-columns: 1fr auto; gap: 4rem; align-items: center;
  }
  .pf-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1.1;
    color: var(--k-text); margin: 0.5rem 0 0.5rem;
  }
  .pf-role {
    font-family: 'Poppins', sans-serif; font-size: 1.05rem; font-weight: 600;
    color: var(--k-accent); margin: 0 0 1.5rem;
  }
  .pf-bio { display: flex; flex-direction: column; gap: 0.875rem; margin-bottom: 2rem; }
  .pf-bio p { font-size: 0.95rem; color: var(--k-text-muted); line-height: 1.7; margin: 0; }
  .pf-hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .pf-btn-primary {
    display: inline-flex; align-items: center; padding: 0.65rem 1.5rem;
    background: var(--k-dark); color: var(--k-bg);
    border-radius: 0.625rem; font-family: 'Poppins', sans-serif;
    font-weight: 700; font-size: 0.875rem; text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .pf-btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }

  .pf-btn-ghost {
    display: inline-flex; align-items: center; padding: 0.65rem 1.25rem;
    background: transparent; color: var(--k-text-muted);
    border: 1px solid var(--k-border); border-radius: 0.625rem;
    font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.875rem;
    text-decoration: none; transition: border-color 0.2s, color 0.2s;
  }
  .pf-btn-ghost:hover { border-color: var(--k-accent); color: var(--k-accent); }

  .pf-img-wrap {
    position: relative; width: 300px; max-width: 100%;
    border-radius: 1.25rem; overflow: hidden;
    border: 2px solid var(--k-border);
  }
  .pf-img-wrap img { width: 100%; object-fit: cover; display: block; }
  .pf-img-badge {
    position: absolute; bottom: 0.875rem; left: 50%; transform: translateX(-50%);
    background: var(--k-bg-card); backdrop-filter: blur(8px);
    padding: 0.35rem 0.875rem; border-radius: 999px;
    font-family: 'Poppins', sans-serif; font-size: 0.75rem; font-weight: 700;
    color: var(--k-text); white-space: nowrap;
    border: 1px solid var(--k-border);
  }

  /* STATS STRIP */
  .pf-stats-strip {
    background: var(--k-bg); border-bottom: 1px solid var(--k-border);
    padding: 1.5rem 0;
  }
  .pf-stats-grid {
    display: flex; align-items: center; gap: 0; flex-wrap: wrap;
    justify-content: space-around;
  }
  .pf-stat {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.5rem 2rem;
    border-right: 1px solid var(--k-border);
  }
  .pf-stat:last-child { border-right: none; }
  .pf-stat-num {
    font-family: 'Poppins', sans-serif; font-size: 1.75rem; font-weight: 900;
    color: var(--k-accent);
  }
  .pf-stat-label {
    font-size: 0.72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--k-text-muted);
  }

