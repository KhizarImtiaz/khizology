---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import { url, img } from '../utils/url';

const stats = [
  { num: '8+', label: 'Years Experience' },
  { num: '20+', label: 'Projects Delivered' },
  { num: '168+', label: 'Original Artworks' },
  { num: '50+', label: 'Free Online Tools' },
];

const strengths = [
  'Full-Stack Development',
  'Technical Team Leadership',
  'Client & Stakeholder Management',
  'Blockchain & Web3',
  'AI / ML Integration',
  'Agile / Scrum Delivery',
  'System Architecture',
  'Creative Design',
  'Visual Communication',
  'Product Strategy',
];

const skillGroups = [
  {
    category: 'Programming & Frameworks',
    items: ['React', 'Next.js', 'Node.js', 'TypeScript', 'JavaScript', 'Python', 'HTML / CSS', 'Astro', 'Tailwind CSS'],
  },
  {
    category: 'Blockchain & Web3',
    items: ['Solidity', 'Ethereum', 'Smart Contracts', 'NFTs', 'DeFi', 'Web3.js'],
  },
  {
    category: 'Databases & Cloud',
    items: ['MongoDB', 'PostgreSQL', 'MySQL', 'Redis', 'AWS (EC2, S3, Lambda)', 'GCP Basics'],
  },
  {
    category: 'AI & Architecture',
    items: ['OpenAI API', 'LangChain', 'Prompt Engineering', 'Microservices', 'REST API', 'GraphQL', 'Clean Architecture'],
  },
  {
    category: 'DevOps & Security',
    items: ['Docker', 'CI/CD Pipelines', 'Git / GitHub', 'JWT', 'OAuth', 'SSL', 'Jira', 'Agile / Scrum'],
  },
  {
    category: 'Design & Creative',
    items: ['Figma', 'Adobe Suite', 'Digital Illustration', 'Creative Direction', 'Infographic Design', 'Brand Building'],
  },
];

const experience = [
  {
    role: 'Technical Delivery Manager',
    company: 'VAIVAL Technologies',
    period: 'Jun 2022 — Present',
    current: true,
    bullets: [
      'Leading delivery of enterprise-grade web and mobile products end-to-end',
      'Managing cross-functional teams of 15+ engineers and designers',
      'Client success, sprint planning, and stakeholder communication',
      'Driving AI/ML and blockchain integration across projects',
      'Ensuring on-time delivery with zero-compromise quality standards',
    ],
  },
  {
    role: 'Technical Team Lead',
    company: 'VAIVAL Technologies',
    period: 'Jan 2020 — Jun 2022',
    current: false,
    bullets: [
      'Led frontend and full-stack development teams across multiple projects',
      'Architected React-based SPAs and Node.js backends',
      'Mentored junior developers and enforced coding standards',
      'Delivered 20+ production projects across diverse industries',
    ],
  },
  {
    role: 'Web Developer',
    company: 'VAIVAL Technologies',
    period: 'Mar 2017 — Jan 2020',
    current: false,
    bullets: [
      'Built full-stack web applications from scratch for various clients',
      'Specialised in React, JavaScript, and modern CSS',
      'Collaborated with design and product teams on 15+ projects',
    ],
  },
  {
    role: 'Co-founder / Technical Lead',
    company: 'Evento.pk (Startup)',
    period: 'Side Project',
    current: false,
    bullets: [
      'Co-founded an events discovery and ticketing platform',
      'Built the entire product from scratch — frontend and backend',
      'Hands-on experience with startup culture and product iteration',
    ],
  },
];

const projects = [
  {
    name: 'khizology',
    desc: 'A monster-powered creative knowledge universe. Artworks, Infographics, Toolbox, and Freebies — all in one creative brand built with Astro, TypeScript, and React.',
    tags: ['Astro', 'TypeScript', 'Tailwind', 'React', 'Personal Brand'],
    link: url('/'),
  },
  {
    name: 'artooo — 168+ Artworks',
    desc: 'Original artworks — sketches, illustrations, character designs, and emotional storytelling through lines. Every piece made by hand.',
    tags: ['Drawing', 'Illustration', 'Character Design', 'Digital Art'],
    link: url('/artworks'),
  },
  {
    name: 'toolooo — 50+ Free Tools',
    desc: 'Free online calculators and productivity tools. Built with React and deployed as interactive islands. Real utility for real people.',
    tags: ['React', 'Calculators', 'SEO', 'Tools'],
    link: url('/toolbox'),
  },
  {
    name: 'Enterprise SaaS Products',
    desc: 'Multiple enterprise-grade web platforms delivered at VAIVAL — covering fintech, HR tech, e-commerce, and operations management.',
    tags: ['React', 'Node.js', 'PostgreSQL', 'AWS'],
    link: null,
  },
  {
    name: 'Blockchain / Web3 dApps',
    desc: 'Smart contract development and Web3 frontend integrations for NFT marketplaces and DeFi applications.',
    tags: ['Solidity', 'Ethereum', 'Web3.js', 'Smart Contracts'],
    link: null,
  },
  {
    name: 'AI-Powered Applications',
    desc: 'Integrated OpenAI and LangChain into production applications, including AI content assistants, data extractors, and chat interfaces.',
    tags: ['OpenAI', 'LangChain', 'Python', 'Node.js'],
    link: null,
  },
];

const softSkills = ['Leadership', 'Communication', 'Problem-Solving', 'Creativity', 'Empathy', 'Attention to Detail', 'Adaptability', 'Continuous Learning', 'Mentoring'];
const hobbies = ['Drawing & Illustration', 'Digital Art', 'Travel', 'Photography', 'Reading', 'Exploring New Tech', 'Playing with AI Tools'];
---

<BaseLayout
  title="My Portfolio — Khizar Imtiaz"
  description="Khizar Imtiaz (khizooo) — Technical Delivery Manager, full-stack developer, and artist. 8+ years at VAIVAL. Creator of khizology."
  accentColor="var(--k-accent)"
>
  <div class="k-container" style="padding-top: 2rem;">
    <Breadcrumb crumbs={[{ label: 'My Portfolio' }]} accentColor="var(--k-accent)" />
  </div>

  <!-- HERO -->
  <section class="pf-hero k-section">
    <div class="k-container">
      <div class="pf-hero-inner">
        <div class="pf-hero-content">
          <span class="k-section-label" style="color: var(--k-accent)">My Portfolio</span>
          <h1 class="pf-title">Khizar Imtiaz</h1>
          <p class="pf-role">Technical Delivery Manager &amp; Creative Developer</p>
          <div class="pf-bio">
            <p>
              8+ years at VAIVAL Technologies — leading teams, shipping products, and solving complex problems at scale. Expert in full-stack development, blockchain/Web3, and AI integration.
            </p>
            <p>
              By luck, a programmer. By nature, an artist. I believe the best digital experiences live at the intersection of technical excellence and creative vision. <strong>khizology</strong> is proof of that.
            </p>
          </div>
          <div class="pf-hero-ctas">
            <a href={url('/drop-a-vibe')} class="pf-btn-primary">Get in Touch →</a>
            <a href="https://www.linkedin.com/in/khizar-imtiaz" target="_blank" rel="noopener" class="pf-btn-ghost">LinkedIn</a>
            <a href="https://github.com/KhizaroOo" target="_blank" rel="noopener" class="pf-btn-ghost">GitHub</a>
          </div>
        </div>
        <div class="pf-hero-visual">
          <div class="pf-img-wrap">
            <img src={img('/images/site/lp-profile-img.png')} alt="Khizar Imtiaz" loading="eager" />
            <div class="pf-img-badge">Technical Delivery Manager</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS STRIP -->
  <div class="pf-stats-strip">
    <div class="k-container">
      <div class="pf-stats-grid">
        {stats.map(s => (
          <div class="pf-stat">
            <span class="pf-stat-num">{s.num}</span>
            <span class="pf-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- PROFESSIONAL SUMMARY -->
  <section class="k-section pf-summary-section">
    <div class="k-container">
      <div class="pf-summary-card">
        <div class="pf-summary-label">Professional Summary</div>
        <p class="pf-summary-text">
          Technical Delivery Manager with 8+ years at VAIVAL Technologies. Expert in full-stack development, technical team leadership, client management, blockchain/Web3, AI/ML integration, and creative design. I bridge the gap between technical complexity and business objectives — ensuring products are not just built, but built right. Outside of engineering, I am an artist and the creator of khizology — a monster-powered creative universe.
        </p>
      </div>
    </div>
  </section>

  <!-- CORE STRENGTHS -->
  <section class="k-section pf-strengths-section">
    <div class="k-container">
      <h2 class="pf-section-title">Core Strengths</h2>
      <div class="strengths-grid">
        {strengths.map(s => (
          <div class="strength-chip">{s}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECHNICAL SKILLS -->
  <section class="k-section pf-skills-section">
    <div class="k-container">
      <h2 class="pf-section-title">Technical Skills</h2>
      <div class="skills-groups">
        {skillGroups.map(group => (
          <div class="skill-group">
            <h3 class="skill-group-label">{group.category}</h3>
            <div class="skill-tags">
              {group.items.map(skill => (
                <span class="skill-tag">{skill}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERIENCE -->
  <section class="k-section pf-exp-section">
    <div class="k-container">
      <h2 class="pf-section-title">Experience</h2>
      <div class="exp-timeline">
        {experience.map((job, i) => (
          <div class="exp-item">
            <div class="exp-connector">
              <div class={`exp-dot ${job.current ? 'exp-dot-current' : ''}`}></div>
              {i < experience.length - 1 && <div class="exp-line"></div>}
            </div>
            <div class="exp-content">
              <div class="exp-header">
                <div class="exp-title-group">
                  <h3 class="exp-role">{job.role}</h3>
                  <span class="exp-company">{job.company}</span>
                </div>
                <div class="exp-meta">
                  <span class="exp-period">{job.period}</span>
                  {job.current && <span class="exp-current-badge">Current</span>}
                </div>
              </div>
              <ul class="exp-bullets">
                {job.bullets.map(b => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="k-section pf-projects-section">
    <div class="k-container">
      <h2 class="pf-section-title">Projects &amp; Contributions</h2>
      <div class="projects-grid">
        {projects.map(p => (
          <div class="project-card">
            <div class="project-card-inner">
              <h3 class="pc-name">{p.name}</h3>
              <p class="pc-desc">{p.desc}</p>
              <div class="pc-tags">
                {p.tags.map(tag => <span class="pc-tag">{tag}</span>)}
              </div>
            </div>
            {p.link && (
              <a href={p.link} class="pc-link">View →</a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SOFT SKILLS + HOBBIES -->
  <section class="k-section pf-extras-section">
    <div class="k-container pf-extras-inner">
      <div class="pf-extra-block">
        <h2 class="pf-section-title">Soft Skills</h2>
        <div class="extras-chips">
          {softSkills.map(s => <span class="extra-chip">{s}</span>)}
        </div>
      </div>
      <div class="pf-extra-block">
        <h2 class="pf-section-title">Hobbies &amp; Interests</h2>
        <div class="extras-chips">
          {hobbies.map(h => <span class="extra-chip">{h}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="k-section pf-cta-section">
    <div class="k-container">
      <div class="pf-cta-inner">
        <img src={img('/images/Monsters/khizooo.png')} alt="" width="96" height="96" class="pf-cta-monster" />
        <h2>Want to work together or just say hi?</h2>
        <p>Open to creative collaborations, tech discussions, and good conversations about art and code.</p>
        <div class="pf-cta-btns">
          <a href={url('/drop-a-vibe')} class="pf-btn-primary">Drop a Vibe →</a>
          <a href={url('/behind-the-vibes')} class="pf-btn-ghost">Behind the Vibes</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* HERO */
  .pf-hero { background: var(--k-bg-card); border-bottom: 1px solid var(--k-border); }
  .pf-hero-inner {
    display: grid; grid-template-columns: 1fr auto; gap: 4rem; align-items: center;
  }
  .pf-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; line-height: 1.1;
    color: var(--k-text); margin: 0.5rem 0 0.5rem;
  }
  .pf-role {
    font-family: 'Poppins', sans-serif; font-size: 1.05rem; font-weight: 600;
    color: var(--k-accent); margin: 0 0 1.5rem;
  }
  .pf-bio { display: flex; flex-direction: column; gap: 0.875rem; margin-bottom: 2rem; }
  .pf-bio p { font-size: 0.95rem; color: var(--k-text-muted); line-height: 1.7; margin: 0; }
  .pf-hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

  .pf-btn-primary {
    display: inline-flex; align-items: center; padding: 0.65rem 1.5rem;
    background: var(--k-dark); color: var(--k-bg);
    border-radius: 0.625rem; font-family: 'Poppins', sans-serif;
    font-weight: 700; font-size: 0.875rem; text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
  }
  .pf-btn-primary:hover { opacity: 0.85; transform: translateY(-2px); }

  .pf-btn-ghost {
    display: inline-flex; align-items: center; padding: 0.65rem 1.25rem;
    background: transparent; color: var(--k-text-muted);
    border: 1px solid var(--k-border); border-radius: 0.625rem;
    font-family: 'Poppins', sans-serif; font-weight: 600; font-size: 0.875rem;
    text-decoration: none; transition: border-color 0.2s, color 0.2s;
  }
  .pf-btn-ghost:hover { border-color: var(--k-accent); color: var(--k-accent); }

  .pf-img-wrap {
    position: relative; width: 300px; max-width: 100%;
    border-radius: 1.25rem; overflow: hidden;
    border: 2px solid var(--k-border);
  }
  .pf-img-wrap img { width: 100%; object-fit: cover; display: block; }
  .pf-img-badge {
    position: absolute; bottom: 0.875rem; left: 50%; transform: translateX(-50%);
    background: var(--k-bg-card); backdrop-filter: blur(8px);
    padding: 0.35rem 0.875rem; border-radius: 999px;
    font-family: 'Poppins', sans-serif; font-size: 0.75rem; font-weight: 700;
    color: var(--k-text); white-space: nowrap;
    border: 1px solid var(--k-border);
  }

  /* STATS STRIP */
  .pf-stats-strip {
    background: var(--k-bg); border-bottom: 1px solid var(--k-border);
    padding: 1.5rem 0;
  }
  .pf-stats-grid {
    display: flex; align-items: center; gap: 0; flex-wrap: wrap;
    justify-content: space-around;
  }
  .pf-stat {
    display: flex; flex-direction: column; align-items: center; gap: 0.2rem;
    padding: 0.5rem 2rem;
    border-right: 1px solid var(--k-border);
  }
  .pf-stat:last-child { border-right: none; }
  .pf-stat-num {
    font-family: 'Poppins', sans-serif; font-size: 1.75rem; font-weight: 900;
    color: var(--k-accent);
  }
  .pf-stat-label {
    font-size: 0.72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--k-text-muted);
  }

  /* SECTION TITLE */
  .pf-section-title {
    font-family: 'Poppins', sans-serif; font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 800; color: var(--k-text); margin: 0 0 1.75rem;
  }

  /* PROFESSIONAL SUMMARY */
  .pf-summary-section { background: var(--k-bg-card); }
  .pf-summary-card {
    background: var(--k-bg); border: 1px solid var(--k-border);
    border-left: 4px solid var(--k-accent);
    border-radius: 0 1rem 1rem 0;
    padding: 2rem;
  }
  .pf-summary-label {
    font-family: 'Poppins', sans-serif; font-size: 0.7rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    color: var(--k-accent); margin-bottom: 0.875rem;
  }
  .pf-summary-text {
    font-size: 1rem; color: var(--k-text-muted); line-height: 1.8; margin: 0;
  }

  /* STRENGTHS */
  .pf-strengths-section { background: var(--k-bg); }
  .strengths-grid {
    display: flex; flex-wrap: wrap; gap: 0.625rem;
  }
  .strength-chip {
    display: inline-flex; padding: 0.5rem 1.125rem;
    background: var(--k-bg-card); border: 1px solid var(--k-accent);
    border-radius: 999px; font-family: 'Poppins', sans-serif;
    font-size: 0.825rem; font-weight: 600; color: var(--k-text);
    transition: background 0.2s, color 0.2s;
  }
  .strength-chip:hover { background: var(--k-accent); color: #fff; }

  /* SKILLS */
  .pf-skills-section { background: var(--k-bg-card); }
  .skills-groups { display: flex; flex-direction: column; gap: 1.75rem; }
  .skill-group { display: flex; flex-direction: column; gap: 0.625rem; }
  .skill-group-label {
    font-family: 'Poppins', sans-serif; font-size: 0.72rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--k-accent);
    margin: 0;
  }
  .skill-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .skill-tag {
    display: inline-flex; padding: 0.3rem 0.75rem;
    background: var(--k-bg); border: 1px solid var(--k-border);
    border-radius: 0.5rem; font-size: 0.8rem; font-weight: 600; color: var(--k-text);
  }

  /* EXPERIENCE */
  .pf-exp-section { background: var(--k-bg); }
  .exp-timeline { display: flex; flex-direction: column; gap: 0; }
  .exp-item { display: grid; grid-template-columns: 2rem 1fr; gap: 1.25rem; align-items: flex-start; }
  .exp-connector { display: flex; flex-direction: column; align-items: center; padding-top: 0.25rem; }
  .exp-dot {
    width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0;
    background: var(--k-border); border: 2px solid var(--k-accent);
  }
  .exp-dot-current { background: var(--k-accent); }
  .exp-line { width: 2px; flex: 1; min-height: 2rem; background: var(--k-border); margin: 4px 0; }
  .exp-content { padding-bottom: 2rem; }
  .exp-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 1rem; margin-bottom: 0.875rem; flex-wrap: wrap;
  }
  .exp-role {
    font-family: 'Poppins', sans-serif; font-size: 1rem; font-weight: 800;
    color: var(--k-text); margin: 0 0 0.2rem;
  }
  .exp-company {
    font-size: 0.85rem; font-weight: 600; color: var(--k-accent);
    font-family: 'Poppins', sans-serif;
  }
  .exp-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 0.3rem; }
  .exp-period { font-size: 0.8rem; color: var(--k-text-muted); white-space: nowrap; }
  .exp-current-badge {
    display: inline-flex; padding: 0.15rem 0.6rem;
    background: var(--k-accent); color: #fff;
    border-radius: 999px; font-size: 0.65rem; font-weight: 700;
    font-family: 'Poppins', sans-serif; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .exp-bullets {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .exp-bullets li {
    font-size: 0.875rem; color: var(--k-text-muted); line-height: 1.5;
    padding-left: 1rem; position: relative;
  }
  .exp-bullets li::before {
    content: '–'; position: absolute; left: 0;
    color: var(--k-accent); font-weight: 700;
  }

  /* PROJECTS */
  .pf-projects-section { background: var(--k-bg-card); }
  .projects-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.25rem;
  }
  .project-card {
    background: var(--k-bg); border: 1px solid var(--k-border); border-radius: 1rem;
    padding: 1.5rem; display: flex; flex-direction: column; gap: 1rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .project-card:hover { border-color: var(--k-accent); transform: translateY(-2px); }
  .project-card-inner { flex: 1; display: flex; flex-direction: column; gap: 0.625rem; }
  .pc-name { font-family: 'Poppins', sans-serif; font-size: 0.95rem; font-weight: 700; color: var(--k-text); margin: 0; }
  .pc-desc { font-size: 0.8rem; color: var(--k-text-muted); line-height: 1.6; margin: 0; flex: 1; }
  .pc-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .pc-tag {
    display: inline-flex; padding: 0.2rem 0.6rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-radius: 999px; font-size: 0.7rem; font-weight: 600; color: var(--k-text-muted);
  }
  .pc-link {
    display: inline-flex; align-items: center;
    font-family: 'Poppins', sans-serif; font-size: 0.8rem; font-weight: 700;
    color: var(--k-accent); text-decoration: none;
    transition: gap 0.2s;
  }
  .pc-link:hover { text-decoration: underline; }

  /* EXTRAS */
  .pf-extras-section { background: var(--k-bg); }
  .pf-extras-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; }
  .extras-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .extra-chip {
    display: inline-flex; padding: 0.375rem 0.875rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border);
    border-radius: 999px; font-size: 0.8rem; font-weight: 600; color: var(--k-text);
  }

  /* CTA */
  .pf-cta-section { background: var(--k-bg-card); }
  .pf-cta-inner { text-align: center; max-width: 540px; margin-inline: auto; }
  .pf-cta-monster {
    width: 80px; height: 80px; object-fit: contain;
    background: var(--k-accent); padding: 10px; border-radius: 50%;
    margin-bottom: 1rem; display: inline-block;
  }
  .pf-cta-inner h2 {
    font-family: 'Poppins', sans-serif; font-size: 1.5rem; font-weight: 800;
    color: var(--k-text); margin: 0 0 0.75rem;
  }
  .pf-cta-inner p { font-size: 0.95rem; color: var(--k-text-muted); margin: 0 0 1.5rem; }
  .pf-cta-btns { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }

  @media (max-width: 900px) {
    .pf-hero-inner { grid-template-columns: 1fr; }
    .pf-hero-visual { order: -1; }
    .pf-img-wrap { width: 240px; max-width: 100%; }
    .pf-extras-inner { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 600px) {
    .pf-stat { padding: 0.5rem 1rem; }
    .exp-item { grid-template-columns: 1.5rem 1fr; }
  }
</style>
