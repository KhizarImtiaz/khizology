---
import BaseLayout from '../components/layout/BaseLayout.astro';
import Breadcrumb from '../components/ui/Breadcrumb.astro';
import ArtworkGrid from '../components/artworks/ArtworkGrid';
import { artworks } from '../data/artworks';
import { monsters } from '../data/monsters';

const ACCENT = '#F5CF5C';
const monster = monsters.find(m => m.id === 'artooo')!;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="artooo — Artworks by khizooo"
  description={`168+ original artworks — sticky-note art, illustrations, digital paintings, and visual stories by khizooo. Browse the full gallery.`}
  accentColor={ACCENT}
>
  <!-- Hero -->
  <section class="art-hero">
    <div class="k-container">
      <div class="art-hero-inner">
        <div class="art-hero-text">
          <Breadcrumb crumbs={[{ label: 'artooo', href: '/artworks' }]} accentColor={ACCENT} />
          <div class="art-hero-badge">
            <img src={`${base}/public/images/Monsters/artooo.png`} alt="artooo" width="40" height="40" class="art-hero-monster" />
            <span class="k-section-label" style={`color: ${ACCENT}`}>artooo · Artworks</span>
          </div>
          <h1 class="art-hero-title">
            168+ Artworks.<br />
            <span class="art-hero-accent">Every one original.</span>
          </h1>
          <p class="art-hero-lead">
            Sticky-note art, digital illustrations, emotional portraits, and visual stories.
            Each piece is a feeling given form — scroll, search, explore.
          </p>
          <div class="art-hero-stats">
            <div class="art-stat">
              <span class="art-stat-num">{artworks.length}</span>
              <span class="art-stat-label">Artworks</span>
            </div>
            <div class="art-stat">
              <span class="art-stat-num">100%</span>
              <span class="art-stat-label">Original</span>
            </div>
            <div class="art-stat">
              <span class="art-stat-num">∞</span>
              <span class="art-stat-label">Vibes</span>
            </div>
          </div>
        </div>
        <div class="art-hero-visual">
          <div class="art-mosaic">
            {artworks.slice(0, 6).map((a, i) => (
              <div class={`art-mosaic-cell cell-${i}`}>
                <img
                  src={`${base}/public/images/artworks/${a.filename}`}
                  alt={a.title}
                  loading={i < 2 ? 'eager' : 'lazy'}
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section class="art-gallery k-section">
    <div class="k-container">
      <div class="art-gallery-header">
        <span class="k-section-label" style={`color: ${ACCENT}`}>The Gallery</span>
        <h2 class="art-gallery-title">Browse All Artworks</h2>
        <p class="art-gallery-sub">Click any artwork to see it up close.</p>
      </div>
      <ArtworkGrid artworks={artworks} base={base} client:load />
    </div>
  </section>

  <!-- CTA strip -->
  <section class="art-cta-strip">
    <div class="k-container">
      <div class="art-cta-inner">
        <div class="art-cta-text">
          <h2>Explore more monsters</h2>
          <p>artooo is just one corner of the khizology universe.</p>
        </div>
        <div class="art-cta-links">
          {monsters.filter(m => m.status === 'active' && m.id !== 'artooo').map(m => (
            <a href={m.route} class="art-cta-monster" style={`--mc: ${m.color}`}>
              <img src={`${base}${m.image}`} alt={m.name} width="32" height="32" />
              <span>{m.module}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Hero ── */
  .art-hero {
    background: var(--k-bg);
    padding: 3rem 0 2rem;
    border-bottom: 1px solid var(--k-border);
  }
  .art-hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 900px) {
    .art-hero-inner { grid-template-columns: 1fr 1fr; }
  }

  .art-hero-badge {
    display: flex;
    align-items: center;
    gap: .625rem;
    margin-bottom: .25rem;
  }
  .art-hero-monster {
    border-radius: .5rem;
    object-fit: contain;
  }

  .art-hero-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 900;
    line-height: 1.1;
    color: var(--k-text);
    margin: .5rem 0 1rem;
  }
  .art-hero-accent { color: #F5CF5C; }

  .art-hero-lead {
    font-size: 1rem;
    color: var(--k-text-muted);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 0 1.5rem;
  }

  .art-hero-stats {
    display: flex;
    gap: 2rem;
  }
  .art-stat { display: flex; flex-direction: column; gap: .125rem; }
  .art-stat-num {
    font-family: 'Poppins', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    color: #F5CF5C;
    line-height: 1;
  }
  .art-stat-label {
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--k-text-muted);
  }

  /* Mosaic */
  .art-mosaic {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 140px);
    gap: .5rem;
    border-radius: 1.25rem;
    overflow: hidden;
  }
  .art-mosaic-cell { overflow: hidden; border-radius: .5rem; }
  .art-mosaic-cell img { width: 100%; height: 100%; object-fit: cover; transition: transform .4s; }
  .art-mosaic-cell:hover img { transform: scale(1.06); }
  .cell-0 { grid-column: span 2; }
  .cell-3 { grid-column: span 2; }

  /* Gallery */
  .art-gallery-header { margin-bottom: 2rem; }
  .art-gallery-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    color: var(--k-text);
    margin: .25rem 0 .375rem;
  }
  .art-gallery-sub { font-size: .875rem; color: var(--k-text-muted); margin: 0; }

  /* CTA strip */
  .art-cta-strip {
    background: var(--k-bg-card);
    border-top: 1px solid var(--k-border);
    padding: 2.5rem 0;
  }
  .art-cta-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }
  .art-cta-text h2 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--k-text);
    margin: 0 0 .25rem;
  }
  .art-cta-text p { font-size: .875rem; color: var(--k-text-muted); margin: 0; }

  .art-cta-links { display: flex; gap: .75rem; flex-wrap: wrap; }
  .art-cta-monster {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .25rem;
    padding: .75rem;
    background: var(--k-bg);
    border: 1px solid var(--k-border);
    border-radius: .75rem;
    text-decoration: none;
    color: var(--k-text-muted);
    font-size: .7rem;
    font-weight: 600;
    min-width: 72px;
    transition: border-color .2s, color .2s;
  }
  .art-cta-monster:hover { border-color: var(--mc); color: var(--mc); }
</style>
