---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/ui/Breadcrumb.astro';
import { freebiesCategories } from '../../data/freebies';
import { freebiesResourceMap } from '../../data/freebiesResources';
import { monsters } from '../../data/monsters';

export async function getStaticPaths() {
  return freebiesCategories.map(cat => ({
    params: { slug: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props;
const resources = freebiesResourceMap[cat.slug] ?? [];
const ACCENT = '#6CA6FF';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const related = freebiesCategories.filter(c => c.slug !== cat.slug).slice(0, 6);
---

<BaseLayout
  title={`Free ${cat.title} — freeooo by khizooo`}
  description={`${cat.resourceCount}+ free ${cat.title.toLowerCase()} resources. ${cat.description}`}
  accentColor={cat.color}
>
  <!-- Hero -->
  <section class="fr-hero" style={`--fc: ${cat.color}`}>
    <div class="k-container">
      <Breadcrumb
        crumbs={[
          { label: 'freeooo', href: '/freebies' },
          { label: cat.title },
        ]}
        accentColor={cat.color}
      />
      <div class="fr-hero-inner">
        <div class="fr-hero-icon-wrap">
          <span class="fr-hero-icon">{cat.icon}</span>
        </div>
        <div class="fr-hero-text">
          <span class="k-section-label" style={`color: ${cat.color}`}>freeooo · {cat.title}</span>
          <h1 class="fr-hero-title">{cat.title}</h1>
          <p class="fr-hero-lead">{cat.description}</p>
          <div class="fr-hero-meta">
            <span class="fr-meta-pill" style={`background: color-mix(in srgb, ${cat.color} 15%, transparent); color: ${cat.color}`}>
              {cat.resourceCount}+ resources
            </span>
            {cat.tags.map(tag => (
              <span class="fr-tag-pill">{tag}</span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Resources grid -->
  <section class="fr-resources k-section">
    <div class="k-container">
      {resources.length > 0 ? (
        <>
          <div class="fr-section-header">
            <span class="k-section-label" style={`color: ${cat.color}`}>{resources.length} resources</span>
            <h2 class="fr-section-title">Free {cat.title} Resources</h2>
            <p class="fr-section-sub">Hand-picked, always free. Click any card to visit the resource.</p>
          </div>
          <div class="fr-grid">
            {resources.map(res => (
              <a
                href={res.url}
                target="_blank"
                rel="noopener noreferrer"
                class="fr-card"
                style={`--fc: ${cat.color}`}
              >
                <div class="fr-card-top">
                  <div class="fr-card-favicon-wrap">
                    <img
                      src={res.favicon}
                      alt={res.name}
                      width="32"
                      height="32"
                      class="fr-card-favicon"
                      loading="lazy"
                      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                    />
                    <div class="fr-card-favicon-fallback" style="display:none">
                      <span>🔗</span>
                    </div>
                  </div>
                  <span class="fr-card-free-badge">Free</span>
                </div>
                <h3 class="fr-card-name">{res.name}</h3>
                {res.description && (
                  <p class="fr-card-desc">{res.description}</p>
                )}
                {res.tags && res.tags.length > 0 && (
                  <div class="fr-card-tags">
                    {res.tags.map(tag => (
                      <span class="fr-card-tag">{tag}</span>
                    ))}
                  </div>
                )}
                <span class="fr-card-link">Visit →</span>
              </a>
            ))}
          </div>
        </>
      ) : (
        <div class="fr-coming-soon">
          <div class="fr-cs-icon">{cat.icon}</div>
          <h2 class="fr-cs-title">Resources Coming Soon</h2>
          <p class="fr-cs-desc">
            We're curating the best free {cat.title.toLowerCase()} resources. Check back soon!
          </p>
          <a href="/freebies" class="fr-cs-btn" style={`background: ${cat.color}`}>
            ← Back to freeooo
          </a>
        </div>
      )}
    </div>
  </section>

  <!-- Related categories -->
  <section class="fr-related">
    <div class="k-container">
      <span class="k-section-label" style={`color: ${cat.color}`}>More freebies</span>
      <h2 class="fr-related-title">Explore Other Categories</h2>
      <div class="fr-related-grid">
        {related.map(rc => (
          <a href={`/freebies/${rc.slug}`} class="fr-related-card" style={`--rc: ${rc.color}`}>
            <span class="fr-related-icon">{rc.icon}</span>
            <span class="fr-related-name">{rc.title}</span>
            <span class="fr-related-count">{rc.resourceCount}+</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Other monsters strip -->
  <section class="fr-monsters-strip">
    <div class="k-container">
      <div class="fr-monsters-inner">
        <p class="fr-monsters-label">More khizology →</p>
        <div class="fr-monsters-links">
          {monsters.filter(m => m.status === 'active' && m.id !== 'freeooo').map(m => (
            <a href={m.route} class="fr-monster-link" style={`--mc: ${m.color}`}>
              <img src={`${base}${m.image}`} alt={m.name} width="28" height="28" />
              <span>{m.module}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .fr-hero {
    background: var(--k-bg);
    padding: 3rem 0 2.5rem;
    border-bottom: 1px solid var(--k-border);
  }
  .fr-hero-inner {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
  .fr-hero-icon-wrap {
    width: 72px;
    height: 72px;
    border-radius: 1.25rem;
    background: color-mix(in srgb, var(--fc) 15%, transparent);
    border: 2px solid color-mix(in srgb, var(--fc) 30%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    flex-shrink: 0;
  }
  .fr-hero-text { flex: 1; min-width: 260px; }
  .fr-hero-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 900;
    color: var(--k-text);
    margin: .25rem 0 .75rem;
    line-height: 1.1;
  }
  .fr-hero-lead {
    font-size: 1rem;
    color: var(--k-text-muted);
    line-height: 1.7;
    max-width: 540px;
    margin: 0 0 1rem;
  }
  .fr-hero-meta { display: flex; gap: .5rem; flex-wrap: wrap; align-items: center; }
  .fr-meta-pill {
    font-size: .75rem;
    font-weight: 700;
    padding: .25rem .75rem;
    border-radius: 999px;
    font-family: 'Poppins', sans-serif;
  }
  .fr-tag-pill {
    font-size: .7rem;
    font-weight: 600;
    padding: .2rem .6rem;
    border-radius: 999px;
    background: var(--k-bg-elevated);
    border: 1px solid var(--k-border);
    color: var(--k-text-muted);
  }

  /* Resources */
  .fr-section-header { margin-bottom: 2rem; }
  .fr-section-title {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 800;
    color: var(--k-text);
    margin: .25rem 0 .375rem;
  }
  .fr-section-sub { font-size: .875rem; color: var(--k-text-muted); margin: 0; }

  .fr-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
  }

  .fr-card {
    background: var(--k-bg-card);
    border: 1.5px solid var(--k-border);
    border-radius: 1rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color .2s, transform .2s, box-shadow .2s;
  }
  .fr-card:hover {
    border-color: var(--fc);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--k-shadow);
  }
  .fr-card-top { display: flex; align-items: center; justify-content: space-between; }
  .fr-card-favicon-wrap {
    width: 40px;
    height: 40px;
    border-radius: .75rem;
    overflow: hidden;
    background: var(--k-bg);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .fr-card-favicon { width: 32px; height: 32px; object-fit: contain; border-radius: .5rem; }
  .fr-card-favicon-fallback {
    width: 32px; height: 32px;
    align-items: center; justify-content: center;
    font-size: 1.125rem;
  }
  .fr-card-free-badge {
    font-size: .62rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: .15rem .5rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--fc) 15%, transparent);
    color: var(--fc);
    border: 1px solid color-mix(in srgb, var(--fc) 30%, transparent);
    font-family: 'Poppins', sans-serif;
  }
  .fr-card-name {
    font-family: 'Poppins', sans-serif;
    font-size: .9rem;
    font-weight: 800;
    color: var(--k-text);
    margin: 0;
  }
  .fr-card-desc {
    font-size: .78rem;
    color: var(--k-text-muted);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
  .fr-card-tags { display: flex; gap: .3rem; flex-wrap: wrap; }
  .fr-card-tag {
    font-size: .65rem;
    font-weight: 600;
    padding: .1rem .4rem;
    border-radius: 999px;
    background: var(--k-bg);
    border: 1px solid var(--k-border);
    color: var(--k-text-muted);
  }
  .fr-card-link {
    font-size: .78rem;
    font-weight: 700;
    color: var(--fc);
    margin-top: .25rem;
    font-family: 'Poppins', sans-serif;
  }

  /* Coming soon */
  .fr-coming-soon {
    text-align: center;
    padding: 5rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .fr-cs-icon { font-size: 3.5rem; }
  .fr-cs-title {
    font-family: 'Poppins', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--k-text);
    margin: 0;
  }
  .fr-cs-desc { font-size: .9rem; color: var(--k-text-muted); max-width: 400px; margin: 0; }
  .fr-cs-btn {
    display: inline-block;
    padding: .6rem 1.5rem;
    border-radius: .625rem;
    color: #fff;
    font-weight: 700;
    font-size: .875rem;
    font-family: 'Poppins', sans-serif;
    text-decoration: none;
    margin-top: .5rem;
  }

  /* Related */
  .fr-related {
    background: var(--k-bg-card);
    border-top: 1px solid var(--k-border);
    padding: 2.5rem 0;
  }
  .fr-related-title {
    font-family: 'Poppins', sans-serif;
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--k-text);
    margin: .25rem 0 1.25rem;
  }
  .fr-related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: .75rem;
  }
  .fr-related-card {
    background: var(--k-bg);
    border: 1.5px solid var(--k-border);
    border-radius: .875rem;
    padding: .875rem 1rem;
    display: flex;
    flex-direction: column;
    gap: .25rem;
    text-decoration: none;
    color: var(--k-text-muted);
    font-size: .8rem;
    transition: border-color .2s, color .2s;
  }
  .fr-related-card:hover { border-color: var(--rc); color: var(--rc); }
  .fr-related-icon { font-size: 1.375rem; }
  .fr-related-name { font-weight: 700; font-family: 'Poppins', sans-serif; color: var(--k-text); font-size: .8rem; }
  .fr-related-count { font-size: .7rem; font-weight: 600; }

  /* Monsters strip */
  .fr-monsters-strip {
    background: var(--k-bg);
    border-top: 1px solid var(--k-border);
    padding: 2rem 0;
  }
  .fr-monsters-inner { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem; justify-content: space-between; }
  .fr-monsters-label { font-size: .8rem; font-weight: 700; color: var(--k-text-muted); }
  .fr-monsters-links { display: flex; gap: .625rem; flex-wrap: wrap; }
  .fr-monster-link {
    display: flex; flex-direction: column; align-items: center; gap: .25rem; padding: .625rem;
    background: var(--k-bg-card); border: 1px solid var(--k-border); border-radius: .75rem;
    text-decoration: none; color: var(--k-text-muted); font-size: .7rem; font-weight: 600; min-width: 64px;
    transition: border-color .2s, color .2s;
  }
  .fr-monster-link:hover { border-color: var(--mc); color: var(--mc); }
</style>
