---
import { SITE } from '../../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noindex?: boolean;
  keywords?: string;
  publishedAt?: string;
  updatedAt?: string;
  articleTags?: string[];
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  ogType = 'website',
  canonical,
  noindex = false,
  keywords,
  publishedAt,
  updatedAt,
  articleTags,
} = Astro.props;

const fullTitle = title ? `${title} — khizology` : SITE.title;
const canonicalURL = canonical
  ? new URL(canonical, SITE.url).href
  : new URL(Astro.url.pathname, SITE.url).href;
const ogImageURL = ogImage.startsWith('http') ? ogImage : `${SITE.url}${ogImage}`;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<title>{fullTitle}</title>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />
{keywords && <meta name="keywords" content={keywords} />}
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
{ogType === 'article' && publishedAt && <meta property="article:published_time" content={publishedAt} />}
{ogType === 'article' && updatedAt && <meta property="article:modified_time" content={updatedAt} />}
{ogType === 'article' && <meta property="article:author" content={SITE.author} />}
{ogType === 'article' && articleTags?.map(tag => <meta property="article:tag" content={tag} />)}

<!-- Twitter Card -->
<meta name="twitter:card" content={SITE.twitterCard} />
<meta name="twitter:site" content={SITE.authorHandle} />
<meta name="twitter:creator" content={SITE.authorHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Favicon -->
<link rel="icon" href={`${base}/favicon.png`} type="image/svg+xml" />
<link rel="icon" type="image/png" sizes="32x32" href={`${base}/favicon_32x32.png`} />
<link rel="icon" type="image/png" sizes="16x16" href={`${base}/favicon_16x16.png`} />

<!-- Theme color -->
<meta name="theme-color" content={SITE.themeColor} />
