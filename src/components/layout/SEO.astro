---
import { SITE } from '../../data/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title,
  description = SITE.description,
  ogImage = SITE.ogImage,
  canonical,
  noindex = false,
} = Astro.props;

const fullTitle = title ? `${title} — khizology` : SITE.title;
const canonicalURL = canonical
  ? new URL(canonical, SITE.url).href
  : new URL(Astro.url.pathname, SITE.url).href;
const ogImageURL = ogImage.startsWith('http') ? ogImage : `${SITE.url}${ogImage}`;
---

<title>{fullTitle}</title>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter Card -->
<meta name="twitter:card" content={SITE.twitterCard} />
<meta name="twitter:site" content={SITE.authorHandle} />
<meta name="twitter:creator" content={SITE.authorHandle} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<!-- Favicon -->
<link rel="icon" type="image/png" sizes="32x32" href="/public/favicon_32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/public/favicon_16x16.png" />

<!-- Theme color -->
<meta name="theme-color" content={SITE.themeColor} />
