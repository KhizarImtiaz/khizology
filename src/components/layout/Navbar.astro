---
const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'Artworks', href: '/artworks', accent: '#F5CF5C' },
  { label: 'Infographics', href: '/infographics', accent: '#5CCFAF' },
  { label: 'Toolbox', href: '/toolbox', accent: '#F7933C' },
  { label: 'Freebies', href: '/freebies', accent: '#6CA6FF' },
  { label: 'Portfolio', href: '/my-portfolio' },
];

const currentPath = Astro.url.pathname;
---

<header class="k-navbar" id="k-navbar">
  <div class="k-container">
    <nav class="k-nav-inner" aria-label="Main navigation">
      <!-- Logo -->
      <a href="/" class="k-logo" aria-label="khizology home">
        <img src="/public/images/Monsters/khizooo.png" alt="" width="32" height="32" class="k-logo-img" />
        <span class="k-logo-text">khiz<span class="k-logo-accent">ology</span></span>
      </a>

      <!-- Desktop nav links -->
      <ul class="k-nav-links" role="list">
        {navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class={`k-nav-link ${currentPath === link.href || currentPath.startsWith(link.href + '/') ? 'active' : ''}`}
              style={link.accent ? `--link-accent: ${link.accent}` : ''}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right controls -->
      <div class="k-nav-controls">
        <a href="/drop-a-vibe" class="k-cta-btn">Drop a Vibe</a>
        <button id="theme-toggle" class="k-theme-btn" aria-label="Toggle dark/light theme">
          <span class="theme-icon-sun">☀️</span>
          <span class="theme-icon-moon">🌙</span>
        </button>
        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="k-hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="k-mobile-menu" aria-hidden="true">
    <ul role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="k-mobile-link"
            style={link.accent ? `border-left-color: ${link.accent}` : ''}
          >
            {link.label}
          </a>
        </li>
      ))}
      <li>
        <a href="/drop-a-vibe" class="k-mobile-link k-mobile-cta">Drop a Vibe ✉️</a>
      </li>
    </ul>
  </div>
</header>

<style>
  .k-navbar {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--k-bg-card);
    border-bottom: 1px solid var(--k-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .k-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 4rem;
    gap: 1.5rem;
  }

  /* Logo */
  .k-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Poppins', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: var(--k-text);
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .k-logo-img {
    width: 35px;
    height: 35px;
    object-fit: contain;
    animation: float 6s ease-in-out infinite;
    background: var(--k-accent);
    padding: 4px;
    border-radius: 50%;
  }
  .k-logo-accent { color: var(--k-accent); }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  /* Desktop nav links */
  .k-nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .k-nav-link {
    padding: 0.375rem 0.75rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--k-text-muted);
    text-decoration: none;
    transition: color 0.2s, background 0.2s;
    position: relative;
  }
  .k-nav-link:hover,
  .k-nav-link.active {
    color: var(--link-accent, var(--k-text));
    background: var(--k-bg);
  }
  .k-nav-link.active::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--link-accent, var(--k-dark));
  }

  /* Right controls */
  .k-nav-controls {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .k-cta-btn {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 1rem;
    background: var(--k-dark);
    color: var(--k-bg);
    border-radius: 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.2s;
    white-space: nowrap;
  }
  .k-cta-btn:hover { opacity: 0.85; transform: translateY(-1px); }

  .k-theme-btn {
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid var(--k-border);
    border-radius: 0.5rem;
    background: transparent;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    transition: background 0.2s;
    color: var(--k-text);
  }
  .k-theme-btn:hover { background: var(--k-bg); }

  /* Sun/moon icons controlled by dark class */
  .theme-icon-moon { display: none; }
  html.dark .theme-icon-sun { display: none; }
  html.dark .theme-icon-moon { display: block; }

  /* Hamburger */
  .k-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }
  .k-hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--k-text);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  /* Mobile menu */
  .k-mobile-menu {
    display: none;
    border-top: 1px solid var(--k-border);
    background: var(--k-bg-card);
    padding: 1rem 0;
  }
  .k-mobile-menu.open { display: block; }
  .k-mobile-menu ul { list-style: none; margin: 0; padding: 0; }

  .k-mobile-link {
    display: block;
    padding: 0.75rem 1.5rem;
    color: var(--k-text-muted);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border-left: 3px solid transparent;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .k-mobile-link:hover {
    color: var(--k-text);
    background: var(--k-bg);
  }
  .k-mobile-cta {
    color: var(--k-dark);
    font-weight: 700;
    border-left-color: var(--k-accent) !important;
  }

  @media (max-width: 768px) {
    .k-nav-links { display: none; }
    .k-cta-btn { display: none; }
    .k-hamburger { display: flex; }
  }
</style>

<script>
  // Theme toggle
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    try { localStorage.setItem('khizology-theme', isDark ? 'dark' : 'light'); } catch (_) {}
  });

  // Mobile menu
  const hamburger = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  hamburger?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // Navbar scroll shadow
  const navbar = document.getElementById('k-navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });
</script>
