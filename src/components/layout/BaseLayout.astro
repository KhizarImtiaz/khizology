---
import SEO from './SEO.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import ScrollTop from '../ui/ScrollTop.astro';
import '../../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  accentColor?: string;
  accentColorLight?: string;
}

const {
  title,
  description,
  ogImage,
  canonical,
  noindex,
  accentColor,
  accentColorLight,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      canonical={canonical}
      noindex={noindex}
    />
    {accentColor && (
      <style define:vars={{ accentColor, accentColorLight: accentColorLight || accentColor }}>
        :root {
          --m-accent: var(--accentColor);
          --m-accent-light: var(--accentColorLight);
        }
      </style>
    )}
  </head>
  <body>
    <Navbar />
    <main class="page-enter">
      <slot />
    </main>
    <Footer />
    <ScrollTop />

    <!-- Theme persistence script (runs before paint to prevent flash) -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('khizology-theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (saved === 'dark' || (!saved && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (_) {}
      })();
    </script>
  </body>
</html>
