---
import SEO from './SEO.astro';
import Navbar from './Navbar.astro';
import Footer from './Footer.astro';
import ScrollTop from '../ui/ScrollTop.astro';
import '../../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noindex?: boolean;
  keywords?: string;
  publishedAt?: string;
  updatedAt?: string;
  articleTags?: string[];
  accentColor?: string;
  accentColorLight?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage,
  ogType,
  canonical,
  noindex,
  keywords,
  publishedAt,
  updatedAt,
  articleTags,
  accentColor,
  accentColorLight,
  jsonLd,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonical={canonical}
      noindex={noindex}
      keywords={keywords}
      publishedAt={publishedAt}
      updatedAt={updatedAt}
      articleTags={articleTags}
    />
    <!-- Theme persistence script (runs before paint to prevent flash) -->
    <script is:inline>
      (function () {
        try {
          const saved = localStorage.getItem('khizology-theme');
          const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          if (saved === 'dark' || (!saved && prefersDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (_) {}
      })();
    </script>
    {accentColor && (
      <style define:vars={{ accentColor, accentColorLight: accentColorLight || accentColor }}>
        :root {
          --m-accent: var(--accentColor);
          --m-accent-light: var(--accentColorLight);
        }
      </style>
    )}
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(jsonLd) ? jsonLd : [jsonLd])} />
    )}
  </head>
  <body>
    <Navbar />
    <main class="page-enter">
      <slot />
    </main>
    <Footer />
    <ScrollTop />
  </body>
</html>
