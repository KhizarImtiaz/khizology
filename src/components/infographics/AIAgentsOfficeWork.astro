---
/**
 * AIAgentsOfficeWork.astro — infooo design system v3
 * TO UPDATE CONTENT: edit the data arrays below only.
 * HTML and CSS are purely structural — no content lives there.
 * Color: #5CCFAF only. No other accent colors.
 */
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// ─── HERO ────────────────────────────────────────────────────────────────────
const hero = {
  hook:     { stat: '40%', l1: 'of all repetitive office tasks', l2: 'now automatable by AI agents' },
  title:    'AI Agents Are Replacing',
  titleAcc: 'Repetitive Office Work',
  stats: [
    { num: '$47B',  unit: '',  lbl: 'AI Agent Market',      sub: '44% CAGR · 2025' },
    { num: '3–8',   unit: 'h', lbl: 'Saved / Worker / Wk',  sub: 'through task delegation' },
    { num: '500M',  unit: '+', lbl: 'AI Workspace Actions', sub: 'daily across ecosystems' },
    { num: '78%',   unit: '',  lbl: 'Companies Upskilling', sub: 'not replacing workers' },
  ],
};

// ─── 01  TOP TASKS BEING AUTOMATED ───────────────────────────────────────────
// pct = adoption rate among enterprises (%)
const tasks = [
  { icon: '🗃️', name: 'Data Entry',        pct: 72 },
  { icon: '✉️',  name: 'Email Triage',      pct: 69 },
  { icon: '🗓️', name: 'Scheduling',         pct: 61 },
  { icon: '📊',  name: 'Reporting',          pct: 58 },
  { icon: '🎧',  name: 'Support Tier 1',     pct: 54 },
  { icon: '🔬',  name: 'Research',           pct: 47 },
  { icon: '📄',  name: 'Doc Formatting',     pct: 43 },
  { icon: '🔄',  name: 'CRM Updates',        pct: 41 },
  { icon: '🎙️', name: 'Meeting Notes',      pct: 38 },
  { icon: '🧾',  name: 'Invoice Sorting',    pct: 35 },
  { icon: '📚',  name: 'Knowledge Search',   pct: 33 },
  { icon: '⚡',  name: 'Workflow Routing',   pct: 29 },
];

// ─── 02  WHERE AI CREATES MOST VALUE ─────────────────────────────────────────
// pct = % of teams reporting strong AI value in this area
const values = [
  { icon: '🎧',  name: 'Support',          pct: 74 },
  { icon: '⚙️', name: 'Operations',        pct: 69 },
  { icon: '📈',  name: 'Sales',            pct: 63 },
  { icon: '🖥️', name: 'IT Helpdesk',      pct: 58 },
  { icon: '👥',  name: 'HR & Admin',       pct: 56 },
  { icon: '💳',  name: 'Finance',          pct: 54 },
  { icon: '📣',  name: 'Marketing',        pct: 51 },
  { icon: '📋',  name: 'Project Mgmt',     pct: 46 },
  { icon: '🤝',  name: 'Exec Assist',      pct: 42 },
  { icon: '⚖️', name: 'Legal',            pct: 37 },
  { icon: '🔒',  name: 'Cybersecurity',   pct: 33 },
  { icon: '🎓',  name: 'L&D Training',    pct: 29 },
];

// ─── 03  ADOPTION TIMELINE ───────────────────────────────────────────────────
// state: 'done' | 'now' | 'future'
const timeline = [
  {
    year: '2022', state: 'done',
    points: [
      'ChatGPT launched publicly',
      'AI writing tools go mainstream',
      'GitHub Copilot hits 1M+ devs',
      'GPT-4 previewed to enterprise',
      'First AI productivity pilots start',
    ],
  },
  {
    year: '2023', state: 'done',
    points: [
      'Microsoft 365 Copilot announced',
      'Google Workspace Duet AI GA',
      'GPT-4 with vision released',
      'Enterprise AI adoption triples',
      'Prompt engineering enters job specs',
    ],
  },
  {
    year: '2024', state: 'done',
    points: [
      'GPT-4o released, faster + cheaper',
      'Salesforce Agentforce announced',
      'Autonomous agents hit enterprise',
      'Claude 3 Opus enters large orgs',
      'AI replaces Tier 1 support broadly',
    ],
  },
  {
    year: '2025', state: 'done',
    points: [
      'Multi-step agents manage workflows',
      'OpenAI Operator handles browser tasks',
      'Gemini 2.0 agentic capabilities GA',
      'Claude scales across Fortune 500',
      'AI standard in Finance, HR, Ops',
    ],
  },
  {
    year: '2026', state: 'now',
    points: [
      'Cross-agent coordination standard',
      'AI-native roles emerge in most orgs',
      'Enterprise governance frameworks set',
      '40%+ of knowledge tasks AI-assisted',
      'Upskilling programs scale globally',
    ],
  },
  {
    year: '2027', state: 'future',
    points: [
      'AI agents in every workplace tool',
      '60%+ of routine work AI-managed',
      'Human roles shift to oversight',
      'AI literacy mandatory in hiring',
      'Productivity gap widens sharply',
    ],
  },
];

// ─── 04  PLATFORMS ───────────────────────────────────────────────────────────
const platforms = [
  { icon: '🪟', company: 'Microsoft',   products: 'Copilot · 365 AI · Teams AI' },
  { icon: '🌐', company: 'Google',      products: 'Gemini · Workspace AI' },
  { icon: '🤖', company: 'OpenAI',      products: 'ChatGPT · Operator · Agents' },
  { icon: '🧠', company: 'Anthropic',   products: 'Claude · Enterprise API' },
  { icon: '☁️', company: 'Salesforce',  products: 'Agentforce · Einstein' },
  { icon: '📒', company: 'Notion',      products: 'Notion AI · Docs AI' },
  { icon: '🔷', company: 'Atlassian',   products: 'Atl. Intelligence · Jira AI' },
  { icon: '🔧', company: 'ServiceNow',  products: 'Now Assist · IT workflows' },
  { icon: '🟠', company: 'HubSpot',     products: 'Breeze AI · CRM automation' },
  { icon: '📹', company: 'Zoom',        products: 'AI Companion · Meeting AI' },
  { icon: '💬', company: 'Slack',       products: 'Slack AI · Summaries' },
  { icon: '🏢', company: 'SAP / Oracle',products: 'Enterprise AI · Finance + HR' },
];

// ─── 05  WHAT CHANGES ────────────────────────────────────────────────────────
const shifts = [
  { bi: '⏳', bt: 'Manual repetitive execution',       ai: '🤖', at: 'AI-assisted execution + review' },
  { bi: '📋', bt: 'Hours lost to admin work',           ai: '🧠', at: 'Focus on strategy and creativity' },
  { bi: '🔁', bt: 'Copy-paste fragmented tools',        ai: '⚡', at: 'Connected intelligent workflows' },
  { bi: '🗂️',bt: 'Siloed knowledge access',            ai: '🔍', at: 'Instant AI-powered knowledge retrieval' },
  { bi: '🐢', bt: 'Slow reactive decisions',            ai: '🚀', at: 'Proactive AI-assisted insights' },
];

const teamCards = [
  {
    label: 'Individual Workers',
    points: ['Less repetitive admin daily', 'More creative output time', 'AI as personal task agent', 'Faster task completion'],
  },
  {
    label: 'Managers',
    points: ['AI-powered status summaries', 'Better real-time visibility', 'Faster reporting cycles', 'More strategic oversight'],
  },
  {
    label: 'Teams and Ops',
    points: ['Cross-tool coordination', 'Faster cross-team handoffs', 'Fewer process bottlenecks', 'AI-native workflow standards'],
  },
];

// ─── CALLOUT ──────────────────────────────────────────────────────────────────
const callout = {
  stat:  '78%',
  chip:  'upskill, not replace',
  head:  'Evolution, not replacement',
  body:  'Humans with AI beat humans without AI. The repetitive layer goes first. The competitive edge belongs to teams that adapt fast.',
};
---

<div class="ig-wrap" id="ig-infographic-canvas">

  <!-- ════ HEADER ════ -->
  <div class="ig-header">
    <div class="ig-hdr-brand">
      <img src={`${base}/images/Monsters/khizooo.png`} alt="khizooo" width="22" height="22" class="ig-hdr-logo" />
      <img src={`${base}/images/Monsters/infooo.png`}  alt="infooo"  width="22" height="22" class="ig-hdr-logo" />
      <span class="ig-hdr-name">infooo by khizooo</span>
    </div>
    <div class="ig-hdr-right">
      <span class="ig-hdr-dot"></span>
      <span class="ig-hdr-cat">Market Trend · 2026</span>
    </div>
  </div>

  <!-- ════ HERO ════ -->
  <div class="ig-hero">
    <div class="ig-hero-hook">
      <span class="ig-hook-num">{hero.hook.stat}</span>
      <div class="ig-hook-copy">
        <span class="ig-hook-l1">{hero.hook.l1}</span>
        <span class="ig-hook-l2">{hero.hook.l2}</span>
      </div>
    </div>
    <h2 class="ig-title">{hero.title} <span class="ig-t-acc">{hero.titleAcc}</span></h2>
    <div class="ig-hero-stats">
      {hero.stats.map((s, i) => (
        <div class={`ig-hs${i === 1 ? ' ig-hs--mid' : ''}`}>
          <span class="ig-hs-num">{s.num}<em>{s.unit}</em></span>
          <span class="ig-hs-lbl">{s.lbl}</span>
          <span class="ig-hs-sub">{s.sub}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- ════ 01 + 02  SPLIT ════ -->
  <div class="ig-sh ig-sh--split">
    <span class="ig-sh-n">01</span>
    <span class="ig-sh-t">Top Tasks Being Automated</span>
    <span class="ig-sh-rule"></span>
    <span class="ig-sh-n">02</span>
    <span class="ig-sh-t">Where AI Creates Most Value</span>
  </div>
  <div class="ig-split">
    <!-- LEFT: Tasks -->
    <div class="ig-split-l">
      <div class="ig-bar-grid">
        {tasks.map(t => (
          <div class="ig-bar-item">
            <div class="ig-bar-row">
              <span class="ig-bi-icon">{t.icon}</span>
              <span class="ig-bi-name">{t.name}</span>
              <span class="ig-bi-pct">{t.pct}%</span>
            </div>
            <div class="ig-bar-track"><div class="ig-bar-fill" style={`width:${t.pct}%`}></div></div>
          </div>
        ))}
      </div>
    </div>

    <!-- RIGHT: Values -->
    <div class="ig-split-r">
      <div class="ig-bar-grid">
        {values.map(v => (
          <div class="ig-bar-item">
            <div class="ig-bar-row">
              <span class="ig-bi-icon">{v.icon}</span>
              <span class="ig-bi-name">{v.name}</span>
              <span class="ig-bi-pct">{v.pct}%</span>
            </div>
            <div class="ig-bar-track"><div class="ig-bar-fill" style={`width:${v.pct}%`}></div></div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ════ 03  TIMELINE ════ -->
  <div class="ig-band ig-band--raised">
    <div class="ig-sh">
      <span class="ig-sh-n">03</span>
      <span class="ig-sh-t">Adoption Timeline</span>
    </div>
    <div class="ig-timeline">
      {timeline.map(yr => (
        <div class={`ig-tl-cell ig-tl-cell--${yr.state}`}>
          <div class="ig-tl-top">
            <span class={`ig-tl-badge ig-tl-badge--${yr.state}`}>{yr.year}</span>
            {yr.state === 'now' && <span class="ig-tl-now">NOW</span>}
          </div>
          <ul class="ig-tl-pts">
            {yr.points.map(p => <li>{p}</li>)}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <!-- ════ 04  PLATFORMS ════ -->
  <div class="ig-sh">
    <span class="ig-sh-n">04</span>
    <span class="ig-sh-t">Who Is Powering the Shift</span>
  </div>
  <div class="ig-platforms">
    {platforms.map(p => (
      <div class="ig-plat">
        <span class="ig-plat-ico">{p.icon}</span>
        <div class="ig-plat-info">
          <span class="ig-plat-co">{p.company}</span>
          <span class="ig-plat-prod">{p.products}</span>
        </div>
      </div>
    ))}
  </div>

  <!-- ════ 05  WHAT CHANGES ════ -->
  <div class="ig-band ig-band--raised">
    <div class="ig-sh">
      <span class="ig-sh-n">05</span>
      <span class="ig-sh-t">What Changes for Teams</span>
    </div>
    <div class="ig-changes">
      <!-- Before / After -->
      <div class="ig-ba">
        <div class="ig-ba-col ig-ba-col--b">
          <span class="ig-ba-hdr">Before AI Agents</span>
          {shifts.map(s => (
            <div class="ig-ba-item">
              <span class="ig-ba-ico">{s.bi}</span>
              <span>{s.bt}</span>
            </div>
          ))}
        </div>
        <div class="ig-ba-arrow">→</div>
        <div class="ig-ba-col ig-ba-col--a">
          <span class="ig-ba-hdr">With AI Agents</span>
          {shifts.map(s => (
            <div class="ig-ba-item">
              <span class="ig-ba-ico">{s.ai}</span>
              <span>{s.at}</span>
            </div>
          ))}
        </div>
      </div>
      <!-- Team Cards -->
      <div class="ig-team-grid">
        {teamCards.map(tc => (
          <div class="ig-team-card">
            <span class="ig-team-lbl">{tc.label}</span>
            {tc.points.map(pt => (
              <div class="ig-team-pt"><span class="ig-team-dot"></span><span>{pt}</span></div>
            ))}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- ════ CALLOUT ════ -->
  <div class="ig-callout">
    <div class="ig-callout-l">
      <span class="ig-callout-stat">{callout.stat}</span>
      <span class="ig-callout-chip">{callout.chip}</span>
    </div>
    <div class="ig-callout-r">
      <span class="ig-callout-head">{callout.head}</span>
      <span class="ig-callout-body">{callout.body}</span>
    </div>
  </div>

  <!-- ════ FOOTER ════ -->
  <div class="ig-footer">
    <div class="ig-ftr-l">
      <img src={`${base}/images/Monsters/khizooo.png`} alt="khizooo" width="26" height="26" class="ig-ftr-logo" />
      <img src={`${base}/images/Monsters/infooo.png`}  alt="infooo"  width="26" height="26" class="ig-ftr-logo" />
      <div class="ig-ftr-text">
        <span class="ig-ftr-brand">@khizooo</span>
        <span class="ig-ftr-site">khizology.com</span>
      </div>
    </div>
    <span class="ig-ftr-tag">infooo · Market Trend · 2026</span>
  </div>

</div>

<style>
/* ══════════════════════════════════════
   ROOT — theme-adaptive CSS variables
   Works in both light + dark themes.
   Base bg = lightest; elevated = slightly
   distinct; card = middle ground.
══════════════════════════════════════ */
.ig-wrap {
  --t:   #5CCFAF;
  --t06: color-mix(in srgb,#5CCFAF 6%,transparent);
  --t14: color-mix(in srgb,#5CCFAF 14%,transparent);
  --t26: color-mix(in srgb,#5CCFAF 26%,transparent);
  --t44: color-mix(in srgb,#5CCFAF 44%,transparent);
  /* Theme-aware surface layers (dark mode defaults shown) */
  --s0: var(--k-bg,          #13181D);   /* base surface */
  --s1: var(--k-bg-card,     #1B2229);   /* raised surface */
  --s2: var(--k-bg-elevated, #222C35);   /* further raised */
  --tx: var(--k-text,        #E8EDF2);
  --tm: var(--k-text-muted,  #7A8FA0);
  --bd: var(--k-border,      #2C3D4A);

  background: var(--s0);
  border: 2px solid var(--t26);
  border-radius: 1.125rem;
  overflow: hidden;
  font-family: 'Poppins', sans-serif;
  max-width: 100%;
  margin: 0 auto;
}

/* ── HEADER ── */
.ig-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: .55rem 1.125rem;
  background: var(--t14);
  border-bottom: 1px solid var(--t26);
}
.ig-hdr-brand { display: flex; align-items: center; gap: .4rem; }
.ig-hdr-logo  { border-radius: .3rem; object-fit: contain; }
.ig-hdr-name  { font-size: .72rem; font-weight: 700; color: var(--t); letter-spacing: .07em; text-transform: uppercase; }
.ig-hdr-right { display: flex; align-items: center; gap: .4rem; }
.ig-hdr-dot   { width: 7px; height: 7px; border-radius: 50%; background: var(--t); animation: ig-pulse 2s infinite; flex-shrink: 0; }
.ig-hdr-cat   { font-size: .7rem; font-weight: 600; color: var(--tm); }

/* ── HERO ── base surface */
.ig-hero { padding: 1rem 1.125rem .875rem; background: var(--s0); border-bottom: 1px solid var(--bd); }

.ig-hero-hook {
  display: flex; align-items: center; gap: 1rem;
  padding: .75rem 1rem; margin-bottom: .875rem;
  background: var(--t06); border: 1.5px solid var(--t26); border-radius: .875rem;
}
.ig-hook-num  { font-size: 3.25rem; font-weight: 900; color: var(--t); line-height: 1; flex-shrink: 0; }
.ig-hook-copy { display: flex; flex-direction: column; gap: .15rem; }
.ig-hook-l1   { font-size: .95rem; font-weight: 800; color: var(--tx); }
.ig-hook-l2   { font-size: .78rem; color: var(--tm); }

.ig-title {
  font-size: clamp(1.1rem, 2.2vw, 1.75rem); font-weight: 900;
  color: var(--tx); line-height: 1.2; margin: 0 0 .75rem;
}
.ig-t-acc { color: var(--t); }

/* Hero stat pills */
.ig-hero-stats {
  display: grid; grid-template-columns: repeat(4,1fr);
  border: 1px solid var(--bd); border-radius: .625rem; overflow: hidden;
}
.ig-hs { padding: .65rem .5rem; display: flex; flex-direction: column; gap: .1rem; text-align: center; border-right: 1px solid var(--bd); background: var(--s1); }
.ig-hs:last-child { border-right: none; }
.ig-hs--mid { background: var(--t06); }
.ig-hs-num  { font-size: 2rem; font-weight: 900; color: var(--t); line-height: 1.5; }
.ig-hs-num em { font-style: normal; font-size: .875rem; }
.ig-hs-lbl  { font-size: .8rem; font-weight: 700; color: var(--tx); line-height: 1.25; }
.ig-hs-sub  { font-size: .7rem; color: var(--tm); }

/* ── SECTION HEADER ── raised surface */
.ig-sh {
  display: flex; align-items: center; gap: .5rem;
  padding: .55rem 1.125rem .4rem;
  background: var(--s2);
  border-top: 1px solid var(--bd);
}
.ig-sh--split { background: var(--s2); }  /* explicitly raised for split label */
.ig-sh-n {
  font-size: 1rem; font-weight: 900; padding: .15rem .4rem;
  border-radius: .3rem; background: var(--t14); color: var(--t);
  letter-spacing: .04em; flex-shrink: 0;
}
.ig-sh-t { font-size: 1rem; font-weight: 800; color: var(--tx); text-transform: uppercase; letter-spacing: .06em; }
.ig-sh-rule { flex: 1; height: 1px; background: var(--bd); margin: 0 .625rem; }

/* ── SPLIT SECTION ── */
.ig-split { display: grid; grid-template-columns: 1fr 1fr; }
.ig-split-l { padding: .55rem 1rem .75rem; background: var(--s0); border-right: 1px solid var(--bd); }
.ig-split-r { padding: .55rem 1rem .75rem; background: var(--s1); }

/* Shared bar grid (used in both tasks + values) */
.ig-bar-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .45rem .625rem; }
.ig-bar-item { display: flex; flex-direction: column; gap: .2rem; }
.ig-bar-row  { display: flex; align-items: center; gap: .3rem; }
.ig-bi-icon  { font-size: .8rem; flex-shrink: 0; width: 1.1rem; text-align: center; }
.ig-bi-name  { font-size: .8rem; font-weight: 400; color: var(--tx); flex: 1; line-height: 1.2; }
.ig-bi-pct   { font-size: .72rem; font-weight: 900; color: var(--t); min-width: 2.25rem; text-align: right; }
.ig-bar-track {
  height: 5px; background: var(--s2);
  border-radius: 999px; overflow: hidden;
  border: 1px solid var(--bd);
}
.ig-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--t) 0%, color-mix(in srgb,var(--t) 50%,#b0ffe8) 100%);
  border-radius: 999px;
}

/* ── BAND WRAPPER — raised surface sections ── */
.ig-band { }
.ig-band--raised { background: var(--s1); }
/* section headers inside band inherit band bg, show own raised bg */
.ig-band--raised .ig-sh { background: var(--s2); }

/* ── TIMELINE ── */
.ig-timeline {
  display: grid; grid-template-columns: repeat(3,1fr);
  gap: .45rem; padding: .45rem 1.125rem .75rem;
}
.ig-tl-cell {
  border-radius: .625rem; padding: .5rem .625rem;
  display: flex; flex-direction: column; gap: .3rem;
  border: 1px solid var(--bd);
}
.ig-tl-cell--done   { background: var(--s0); }
.ig-tl-cell--now    { background: var(--t06); border-color: var(--t26); }
.ig-tl-cell--future { background: var(--s2); opacity: .75; border-style: dashed; }
.ig-tl-top   { display: flex; align-items: center; gap: .375rem; }
.ig-tl-badge {
  font-size: 1.25rem; font-weight: 900; padding: .18rem .55rem;
  border-radius: 999px; letter-spacing: .03em; flex-shrink: 0;
}
.ig-tl-badge--done   { background: var(--t); color: #13181D; }
.ig-tl-badge--now    { background: var(--t); color: #13181D; }
.ig-tl-badge--future { background: var(--s2); color: var(--tm); border: 1px solid var(--bd); }
.ig-tl-now   {
  font-size: .7rem; font-weight: 800; padding: .12rem .38rem;
  border-radius: 999px; background: var(--t44); color: var(--t);
}
.ig-tl-pts {
  list-style: none; margin: 0; padding: 0;
  display: flex; flex-direction: column; gap: .22rem;
}
.ig-tl-pts li {
  font-size: .8rem; color: var(--tm); line-height: 1.7;
  padding-left: .7rem; position: relative;
}
.ig-tl-pts li::before {
  content: ''; position: absolute; left: 0; top: 5px;
  width: 4px; height: 4px; border-radius: 50%; background: var(--t);
}
.ig-tl-cell--now    .ig-tl-pts li           { color: var(--tx); }
.ig-tl-cell--future .ig-tl-pts li::before   { background: var(--tm); }

/* ── PLATFORMS ── base surface */
.ig-platforms {
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: .4rem; padding: .45rem 1.125rem .75rem;
  background: var(--s0);
}
.ig-plat {
  display: flex; align-items: center; gap: .5rem;
  padding: .5rem .625rem;
  background: var(--s1); border: 1px solid var(--bd);
  border-left: 2.5px solid var(--t);
  border-radius: 0 .5rem .5rem 0;
}
.ig-plat-ico  { font-size: 1.05rem; flex-shrink: 0; }
.ig-plat-info { display: flex; flex-direction: column; gap: .06rem; }
.ig-plat-co   { font-size: .8rem; font-weight: 600; color: var(--tx); }
